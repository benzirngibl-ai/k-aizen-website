---
// KaizenLayout.astro — shared v2 layout for public back-pages.
// Homepage and /ki-pa are bespoke pages, but the visual language is the same.

interface BreadcrumbItem {
  name: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  jsonLd?: object | object[];
  breadcrumbs?: BreadcrumbItem[];
  activeNav?: 'audit' | 'pricing' | 'about' | 'faq' | 'kontakt' | 'home' | 'blog' | 'tutorials';
  noindex?: boolean;
  hideChrome?: boolean;
}

const {
  title,
  description,
  path,
  ogImage = '/og-image.png',
  jsonLd,
  breadcrumbs,
  activeNav = 'home',
  noindex = false,
  hideChrome = false,
} = Astro.props;

const SITE_URL = 'https://k-aizen.de';
const fullTitle = title.includes('k-AIzen') ? title : `${title} · k-AIzen`;
const toAbsoluteUrl = (href: string) => {
  const normalizedPath = href === '/' ? '/' : `${href.replace(/\/$/, '')}/`;
  return `${SITE_URL}${normalizedPath}`;
};
const canonical = toAbsoluteUrl(path);
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;
const robotsPolicy = noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large';
const crawlerPolicy = noindex ? 'noindex, nofollow' : 'index, follow';

const navItems = [
  { label: 'Angebot', href: '/#angebot', key: 'home' },
  { label: 'Ablauf', href: '/#ablauf', key: 'faq' },
  { label: 'KI-PA', href: '/ki-pa', key: 'audit' },
  { label: 'Preise', href: '/pricing', key: 'pricing' },
  { label: 'Über mich', href: '/about', key: 'about' },
  { label: 'Kontakt', href: '/kontakt', key: 'kontakt' },
];

const jsonLdArray = jsonLd
  ? Array.isArray(jsonLd) ? jsonLd : [jsonLd]
  : [];

if (breadcrumbs && breadcrumbs.length > 0) {
  jsonLdArray.push({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Start", "item": `${SITE_URL}/` },
      ...breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        "position": i + 2,
        "name": b.name,
        "item": toAbsoluteUrl(b.href),
      })),
    ],
  });
}
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content={robotsPolicy} />
  <meta name="author" content="Benjamin Zirngibl · k-AIzen" />
  <meta name="theme-color" content="#FCFCFD" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:site_name" content="k-AIzen" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <meta name="GPTBot" content={crawlerPolicy} />
  <meta name="ClaudeBot" content={crawlerPolicy} />
  <meta name="Claude-Web" content={crawlerPolicy} />
  <meta name="PerplexityBot" content={crawlerPolicy} />
  <meta name="Applebot" content={crawlerPolicy} />

  <link rel="icon" type="image/png" href="/icons/kaizen-favicon.png" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="apple-touch-icon" href="/icons/kaizen-favicon.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt" />
  <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLMs Full" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/v2/kz-v2.css?v=7" />
  <link rel="stylesheet" href="/v2/kz-v2-polish.css?v=7" />

  <link rel="alternate" hreflang="de" href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />

  {jsonLdArray.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <style is:global>
    :root {
      color-scheme: light;
      --bg: var(--paper);
      --fg: var(--ink);
      --fg-muted: var(--slate);
      --fg-inverse: var(--ink);
      --accent: var(--indigo);
      --kz-charcoal: var(--ink);
      --kz-cream: var(--paper);
      --kz-cream-deep: var(--card);
      --kz-border: var(--line);
      --kz-ember: var(--indigo);
      --kz-ember-text: var(--indigo-deep);
      --kz-ember-deep: var(--indigo-deep);
      --font-display: var(--font-sans);
    }

    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow-x: clip;
    }

    main {
      flex: 1;
      width: 100%;
      position: relative;
      padding-top: 82px;
    }
    main::before,
    main::after {
      content: none !important;
      display: none !important;
      background: none !important;
    }

    .kz-progress {
      position: fixed;
      top: 0;
      left: 0;
      height: 3px;
      width: 0;
      z-index: 200;
      background: linear-gradient(90deg, var(--indigo), var(--violet));
    }

    .kz-nav__brand {
      color: var(--ink);
      text-decoration: none;
    }
    .kz-nav__brand:hover {
      color: var(--ink);
      text-decoration: none;
    }
    .kz-logo-mark {
      width: 24px;
      height: 24px;
      object-fit: contain;
      display: block;
    }
    .kz-logo {
      font-weight: 800;
      letter-spacing: -0.02em;
    }
    .kz-logo__ai {
      background: linear-gradient(120deg, var(--indigo), var(--violet));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      font-weight: 800;
    }

    .kz-nav__links a.active {
      color: var(--ink);
    }
    .kz-nav__links a.active::after {
      width: 100%;
    }

    .kz-skip {
      position: absolute;
      left: 0;
      top: 0;
      transform: translateY(-120%);
      z-index: 300;
      background: var(--ink);
      color: #fff;
      padding: 10px 16px;
      text-decoration: none;
    }
    .kz-skip:focus {
      transform: translateY(0);
    }

    .kz-page {
      box-sizing: border-box;
      width: min(100%, 980px);
      margin: 0 auto;
      padding: clamp(54px, 8vw, 96px) var(--gutter) 0;
    }
    .kz-page--wide {
      width: min(100%, 1200px);
    }

    .kz-page-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--indigo-deep);
      padding: 7px 14px;
      border-radius: 999px;
      background: var(--indigo-wash);
      border: 1px solid rgba(232,90,43,0.16);
      margin-bottom: 28px;
    }
    .kz-page-eyebrow::before {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--violet);
    }
    .kz-page-eyebrow img {
      display: none !important;
    }

    .kz-page .kz-h1 {
      font-size: clamp(3rem, 7vw, 5.6rem);
      line-height: 1.02;
      letter-spacing: -0.04em;
      font-weight: 800;
      color: var(--ink);
      max-width: 12ch;
      overflow-wrap: anywhere;
      margin: 0;
    }
    .kz-page .kz-h1 .accent {
      background: linear-gradient(120deg, var(--indigo), var(--violet));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent !important;
      font-style: normal !important;
    }
    .kz-page .kz-lead {
      font-size: clamp(1.05rem, 2vw, 1.3rem);
      color: var(--slate);
      max-width: 60ch;
      margin: 28px 0 56px;
      line-height: 1.65;
    }
    .kz-page .kz-h2 {
      font-size: clamp(2rem, 4.2vw, 3.2rem);
      line-height: 1.08;
      letter-spacing: -0.03em;
      font-weight: 800;
      color: var(--ink);
      max-width: 18ch;
      margin: clamp(64px, 10vw, 120px) 0 22px;
    }
    .kz-page .kz-h3 {
      font-size: clamp(1.25rem, 2.4vw, 1.75rem);
      line-height: 1.18;
      letter-spacing: -0.02em;
      font-weight: 800;
      color: var(--ink);
      margin: 36px 0 12px;
    }
    .kz-page p {
      color: var(--slate);
      font-size: 1.05rem;
      line-height: 1.72;
      max-width: 72ch;
      margin: 0 0 18px;
    }
    .kz-page ul,
    .kz-page ol {
      color: var(--slate);
      font-size: 1.02rem;
      line-height: 1.7;
      max-width: 72ch;
      padding-left: 1.2rem;
      margin: 18px 0;
    }
    .kz-page li {
      margin-bottom: 10px;
    }
    .kz-page strong {
      color: var(--ink);
      font-weight: 800;
    }
    .kz-page a:not(.kz-btn) {
      color: var(--indigo-deep);
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }

    .kz-page section {
      position: relative;
    }
    .kz-page :is(section, div)[style*="background: var(--kz-cream-deep)"],
    .kz-page :is(section, div)[style*="background:var(--kz-cream-deep)"] {
      background: var(--card) !important;
      border: 1px solid var(--line) !important;
      box-shadow: var(--shadow-sm);
    }
    .kz-page :is(section, div)[style*="background: var(--kz-charcoal)"],
    .kz-page :is(section, div)[style*="background:var(--kz-charcoal)"] {
      background: var(--ink) !important;
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: var(--shadow-md);
    }
    .kz-page :is(section, div)[style*="background: var(--kz-charcoal)"] :is(h1,h2,h3,p,li,strong,span),
    .kz-page :is(section, div)[style*="background:var(--kz-charcoal)"] :is(h1,h2,h3,p,li,strong,span) {
      color: var(--paper);
    }
    .kz-page :is(section, div)[style*="background: var(--kz-charcoal)"] p,
    .kz-page :is(section, div)[style*="background:var(--kz-charcoal)"] p {
      color: rgba(255,255,255,0.72);
    }

    .kz-btn:not(.kz-btn--ghost):not(.kz-btn-ghost):not(.kz-btn--whatsapp):not(.kz-btn--audit) {
      background: linear-gradient(135deg, var(--indigo), var(--violet));
      color: #fff !important;
      border-radius: 999px;
      box-shadow: 0 8px 24px -6px rgba(232,90,43,0.45);
    }
    .kz-btn-ghost,
    .kz-btn--ghost {
      background: transparent !important;
      color: var(--ink) !important;
      border: 1.5px solid var(--line) !important;
      border-radius: 999px;
    }
    .kz-btn-ghost:hover,
    .kz-btn--ghost:hover {
      border-color: var(--indigo) !important;
      color: var(--indigo-deep) !important;
      box-shadow: none;
    }

    .kz-quote {
      border-left: 3px solid var(--indigo);
      padding-left: 22px;
      color: var(--slate);
      font-size: clamp(1.2rem, 2.4vw, 1.55rem);
      line-height: 1.5;
      font-style: normal;
      max-width: 680px;
      margin: 32px 0;
    }

    .kz-section-leaf,
    .kz-section-leaf-lg {
      display: none;
    }

    .kz-footer {
      margin-top: clamp(80px, 12vw, 150px);
      padding-block: 56px;
      border-top: 1px solid var(--line);
      color: var(--slate-2);
      font-size: 14px;
    }
    .kz-footer a {
      color: var(--slate);
      text-decoration: none;
    }
    .kz-footer a:hover {
      color: var(--indigo-deep);
    }
    .kz-footer-grid {
      max-width: var(--maxw);
      margin: 0 auto;
      padding-inline: var(--gutter);
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) repeat(3, minmax(0, 1fr));
      gap: clamp(24px, 5vw, 56px);
    }
    .kz-footer-brand img {
      width: 28px;
      height: 28px;
      object-fit: contain;
      display: block;
      margin-bottom: 14px;
    }
    .kz-footer-tag {
      color: var(--slate);
      max-width: 290px;
      margin: 0;
      line-height: 1.6;
    }
    .kz-footer-col h4 {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--ink);
      margin: 0 0 16px;
    }
    .kz-footer-col ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 10px;
    }
    .kz-footer-base {
      max-width: var(--maxw);
      margin: 44px auto 0;
      padding: 24px var(--gutter) 0;
      border-top: 1px solid var(--line);
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
      color: var(--slate-2);
    }

    @media (max-width: 760px) {
      main {
        padding-top: 78px;
      }
      .kz-page {
        padding-top: 48px;
      }
      .kz-page .kz-h1 {
        font-size: clamp(2.55rem, 13vw, 3.3rem);
      }
      .kz-footer-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="kz-progress"></div>
  <a href="#main" class="kz-skip">Zum Hauptinhalt springen</a>

  <nav class="kz-nav" role="banner" style={hideChrome ? 'display: none;' : ''}>
    <a href="/" class="kz-nav__brand" aria-label="k-AIzen Startseite">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-logo-mark" />
      <span class="kz-logo">k&#8209;<span class="kz-logo__ai">AI</span>zen</span>
    </a>
    <div class="kz-nav__links" aria-label="Hauptnavigation">
      {navItems.map((item) => (
        <a href={item.href} class={item.key === activeNav ? 'active' : ''}>{item.label}</a>
      ))}
    </div>
    <a href="/erstgespraech" class="kz-btn kz-btn--primary" style="padding:11px 22px;font-size:14px;">Erstgespräch</a>
  </nav>

  <main id="main" role="main">
    <slot />
  </main>

  <footer class="kz-footer" role="contentinfo" style={hideChrome ? 'display: none;' : ''}>
    <div class="kz-footer-grid">
      <div class="kz-footer-brand">
        <img src="/animations/claude-design/logo-mark.png" alt="" />
        <p class="kz-footer-tag">
          Ihr KI-Ansprechpartner im Unternehmen. Start mit KI-PA, danach Schritt für Schritt mehr System.
        </p>
      </div>
      <div class="kz-footer-col">
        <h4>Funnel</h4>
        <ul>
          <li><a href="/erstgespraech">Erstgespräch</a></li>
          <li><a href="/ki-pa">KI-PA verstehen</a></li>
          <li><a href="/pricing">Preise &amp; Einstieg</a></li>
          <li><a href="/audit">KI-Check</a></li>
        </ul>
      </div>
      <div class="kz-footer-col">
        <h4>Vertrauen</h4>
        <ul>
          <li><a href="/about">Über mich</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/kontakt">Kontakt</a></li>
        </ul>
      </div>
      <div class="kz-footer-col">
        <h4>Rechtliches</h4>
        <ul>
          <li><a href="/impressum">Impressum</a></li>
          <li><a href="/datenschutz">Datenschutz</a></li>
          <li><a href="/agb">AGB</a></li>
        </ul>
      </div>
    </div>
    <div class="kz-footer-base">
      <span>© 2026 Benjamin Zirngibl · k-AIzen</span>
      <span>KI-PA · Automatisierung · Systematisierung</span>
    </div>
  </footer>

  <script is:inline src="/v2/kz-v2.js?v=5" defer></script>

  <!-- k-AIzen OS Chat-Widget: Besucher-Chat mit KI, landet als Conversation in
       der OS-Inbox (Kanal „Website-Chat"). Eigenes Produkt im Eigeneinsatz. -->
  <script
    is:inline
    async
    src="https://kaizen-os.k-aizen.de/widget.js"
    data-channel-id="36c2c50b-f03f-46b8-93a9-4f5f9becb6b8"
    data-base-url="https://kaizen-os.k-aizen.de"
    data-title="Fragen? Schreiben Sie uns"
    data-accent="#E85A2B"></script>
</body>
</html>
