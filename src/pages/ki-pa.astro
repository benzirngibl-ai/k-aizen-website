---
// k-AIzen KI-PA Detailseite — im gleichen Funnel-Design wie die Startseite.

const siteUrl = "https://k-aizen.de";
const pageUrl = `${siteUrl}/ki-pa/`;
const pageTitle = "KI-PA — Ihr erster KI-Assistent im Betrieb · k-AIzen";
const pageDescription = "Der KI-PA ist der greifbare Einstieg in KI: Mail, Kalender, Aufgaben, Kontext und Freigaben. Kein Autopilot ohne Kontrolle, sondern ein betreuter Assistent für den Betrieb.";
const ogImage = `${siteUrl}/pitch/10-memory-retrieve.png`;
const asyncMail = `mailto:kontakt@k-aizen.de?subject=${encodeURIComponent("KI-PA Kurzcheck")}&body=${encodeURIComponent(`Hi Ben,

ich möchte erst einmal ohne Termin prüfen, ob der KI-PA für uns passt.

1. Branche / Teamgröße:
2. Wo verlieren wir gerade Zeit?
3. Welche Systeme nutzen wir? (z. B. Microsoft 365, Teams, Slack, Notion, CRM, Excel)

Beste Grüße`)}`;

const quellen = [
  {
    k: "Mail",
    title: "Mailverlauf",
    text: "Der PA betrachtet nicht nur die neue Nachricht, sondern auch bisherige Antworten, offene Zusagen und Rückfragen.",
  },
  {
    k: "Kalender",
    title: "Termine",
    text: "Anstehende Gespräche, Fristen und Vorbereitungen werden ins Tagesbriefing und in Antwortvorschläge einbezogen.",
  },
  {
    k: "Wissen",
    title: "Notizen & CRM",
    text: "Freigegebene Kundennotizen, Besonderheiten, frühere Beschwerden oder interne Regeln werden als Kontext genutzt.",
  },
  {
    k: "Regeln",
    title: "Freigaben",
    text: "Was gesendet, gebucht oder entschieden werden darf, wird klar begrenzt. Sensibles bleibt zur Prüfung bei Ihnen.",
  },
];

const funktionen = [
  {
    title: "Sortieren",
    text: "Mails, Aufgaben und Rückfragen werden nach Dringlichkeit und Bedeutung vorsortiert.",
  },
  {
    title: "Vorbereiten",
    text: "Antwortentwürfe, Tagesbriefings und kleine Entscheidungsvorlagen entstehen aus Ihren freigegebenen Quellen.",
  },
  {
    title: "Nachhalten",
    text: "Offene Zusagen, fehlende Rückmeldungen und Dinge, die sonst liegenbleiben, tauchen wieder auf.",
  },
  {
    title: "Weiterbauen",
    text: "Wenn der Einstieg trägt, werden weitere Abläufe angeschlossen: Belege, Telefon, Leads, Wissen oder Kaizen OS.",
  },
];

const ablauf = [
  {
    k: "01",
    title: "Erstgespräch",
    text: "Wir schauen 30 Minuten auf Ihren Alltag und prüfen, ob der KI-PA überhaupt der richtige Einstieg ist.",
  },
  {
    k: "02",
    title: "KI-Check",
    text: "Wir prüfen Quellen, Risiken, wiederkehrende Abläufe und den ersten sinnvollen Einsatzbereich. Danach gibt es eine klare Roadmap.",
  },
  {
    k: "03",
    title: "Pilot",
    text: "Wir starten mit einem begrenzten Bereich, meistens Mail, Kalender, Aufgaben oder Belege. Vorschläge vor Automatik.",
  },
  {
    k: "04",
    title: "Ausbau",
    text: "Wenn Nutzen sichtbar ist, wird aus dem Assistenten Schritt für Schritt mehr Betriebssystem für die Firma.",
  },
];

const pilotSchritte = [
  {
    k: "Tag 1-2",
    title: "Quellen und Grenzen",
    text: "Wir legen fest, welche Postfächer, Kalender, Notizen oder Listen genutzt werden dürfen und was tabu bleibt.",
  },
  {
    k: "Tag 3-5",
    title: "Erste Briefings",
    text: "Der PA sortiert echte Eingänge, erstellt Tagesbriefings und zeigt, wo Kontext noch fehlt.",
  },
  {
    k: "Tag 6-10",
    title: "Antworten mit Vorgeschichte",
    text: "Entwürfe entstehen aus Mailverlauf, offener Zusage und Kundennotiz. Sie prüfen Ton, Inhalt und Quellen.",
  },
  {
    k: "Tag 11-14",
    title: "Review statt Bauchgefühl",
    text: "Wir entscheiden anhand echter Artefakte, ob der Bereich weiterläuft, angepasst oder verworfen wird.",
  },
];

const guardrails = [
  "Der PA zeigt Quellen und Unsicherheiten, statt Kontext zu behaupten.",
  "Externe Antworten, Buchungen und sensible Entscheidungen bleiben an Freigabe gebunden.",
  "Neue Datenquellen werden bewusst angebunden, nicht nebenbei eingesammelt.",
  "Was die KI nicht sauber kann, wird markiert und nicht als erledigt verkauft.",
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      "name": "k-AIzen KI-PA",
      "serviceType": "KI-Assistent für Unternehmen",
      "url": pageUrl,
      "description": "Persönlicher KI-Assistent für KMU als Einstieg in ein dauerhaft betreutes KI-System: Mail, Kalender, Aufgaben, Kontext, Freigaben und laufende Weiterentwicklung.",
      "provider": {
        "@type": "ProfessionalService",
        "@id": `${siteUrl}/#organization`,
        "name": "k-AIzen",
        "url": siteUrl,
        "email": "kontakt@k-aizen.de"
      },
      "areaServed": ["DE", "AT", "CH"],
      "audience": {
        "@type": "BusinessAudience",
        "audienceType": "kleine und mittelständische Unternehmen"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "KI-PA Einstieg",
        "itemListElement": [
          { "@type": "Offer", "name": "Erstgespräch", "url": `${siteUrl}/erstgespraech` },
          { "@type": "Offer", "name": "Kostenloser KI-Check", "url": `${siteUrl}/audit` },
          { "@type": "Offer", "name": "KI-PA Tier 1 und Tier 2", "url": `${siteUrl}/pricing` }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Arbeitet der KI-PA automatisch ohne Kontrolle?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nein. Der KI-PA bereitet vor, priorisiert, fasst zusammen und schlägt Antworten vor. Sensible Aktionen bleiben an Freigaben gebunden."
          }
        },
        {
          "@type": "Question",
          "name": "Welche Datenquellen nutzt der KI-PA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nur freigegebene Quellen wie Mailverlauf, Kalender, Aufgabenlisten, Kundennotizen, CRM, Notion, Microsoft 365, Teams, SharePoint, Slack oder Excel-Listen."
          }
        },
        {
          "@type": "Question",
          "name": "Was passiert nach dem KI-PA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wenn der Einstieg trägt, können weitere Abläufe wie Belege, Telefon, Leads, interne Wissenssuche oder ein eigenes Kaizen OS angeschlossen werden."
          }
        },
        {
          "@type": "Question",
          "name": "Wie prüft man, ob der KI-PA wirklich funktioniert?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Der Einstieg wird als begrenzter Pilot bewertet: Quellen, Tagesbriefings, Antwortentwürfe, Freigaben und offene Unsicherheiten werden sichtbar. Danach wird anhand echter Arbeitsartefakte entschieden, ob der Bereich weiter ausgebaut wird."
          }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "KI-PA", "item": pageUrl }
      ]
    }
  ]
};
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <link rel="canonical" href={pageUrl} />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="author" content="Benjamin Zirngibl · k-AIzen" />
  <meta name="theme-color" content="#FCFCFD" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:site_name" content="k-AIzen" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="GPTBot" content="index, follow" />
  <meta name="ClaudeBot" content="index, follow" />
  <meta name="Claude-Web" content="index, follow" />
  <meta name="PerplexityBot" content="index, follow" />
  <meta name="Applebot" content="index, follow" />
  <link rel="icon" type="image/png" href="/icons/kaizen-favicon.png" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="apple-touch-icon" href="/icons/kaizen-favicon.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt" />
  <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLMs Full" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/v2/kz-v2.css?v=7" />
  <link rel="stylesheet" href="/v2/kz-v2-polish.css?v=7" />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</head>
<body>
  <div class="kz-progress"></div>

  <nav class="kz-nav">
    <a href="/" class="kz-nav__brand" aria-label="k-AIzen Startseite">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-logo-mark" />
      <span class="kz-logo">k&#8209;<span class="kz-logo__ai">AI</span>zen</span>
    </a>
    <div class="kz-nav__links">
      <a href="/#angebot">Angebot</a>
      <a href="/#ablauf">Ablauf</a>
      <a href="/#ein-tag">Ein Tag mit Lena</a>
      <a href="/pricing">Preise</a>
      <a href="/#kontakt">Kontakt</a>
    </div>
    <a href="/erstgespraech" class="kz-btn kz-btn--primary" style="padding:11px 22px;font-size:14px;">Erstgespräch</a>
  </nav>

  <header class="kz-hero pa-hero">
    <div class="kz-hero__grid"></div>
    <div class="kz-wrap pa-hero__wrap">
      <div class="pa-hero__copy">
        <div class="kz-hero__eyebrow kz-reveal"><span class="dot"></span> KI-PA Detailseite</div>
        <h1 class="kz-h1">Ihr KI-PA im Betrieb. <span class="accent">Mit nachvollziehbarem Kontext.</span></h1>
        <p class="kz-hero__sub kz-reveal" data-delay="2">
          Der KI-PA ist der Einstieg: Mails, Termine, Aufgaben, Kundennotizen und Freigaben werden so verbunden, dass Sie schneller sehen, was wichtig ist. Nicht als blinder Autopilot, sondern als vorbereitender Assistent mit Kontext.
        </p>
        <div class="kz-hero__cta kz-reveal" data-delay="3">
          <a href="/erstgespraech" class="kz-btn kz-btn--primary">Erstgespräch buchen <span class="kz-btn__arrow">→</span></a>
          <a href={asyncMail} class="kz-btn kz-btn--ghost">3-Fragen-Check per Mail</a>
          <a href="#kontext" class="kz-btn kz-btn--ghost">Wie der Kontext entsteht</a>
        </div>
      </div>

      <div class="pa-hero__media kz-reveal" data-delay="2">
        <img src="/pitch/10-memory-retrieve.png" alt="KI-PA bereitet eine Antwort mit Kundenkontext vor" />
        <div class="pa-hero__note">
          <span>#posteingang · 10:37</span>
          <strong>Antwort mit Kontext</strong>
          <p>Mailverlauf, Kundennotiz und offene Zusage liegen vor dem Entwurf.</p>
        </div>
      </div>
    </div>
  </header>

  <section class="kz-section">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Wofür er da ist</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">Der KI-PA nimmt nicht Ihr Urteil weg. Er nimmt Sucherei, Sortieren und Nachhalten ab.</h2>
      <div class="pa-grid">
        {funktionen.map((item, index) => (
          <article class="pa-card kz-reveal" data-delay={(index % 4) + 1}>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="kz-section" id="kontext" style="background:var(--paper-2);">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Woher weiß die KI das?</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">Kein Rätselraten. Freigegebene Quellen, klare Regeln und menschliche Freigabe.</h2>
      <p class="kz-lead kz-reveal" data-delay="2">
        Der PA kann nur mit dem arbeiten, was wir ihm sauber geben: Mailverläufe, Kalender, Aufgabenlisten, Kundennotizen, CRM oder Notion. Am Anfang wird bewusst begrenzt, was er sehen darf und was er nur vorbereiten darf.
      </p>

      <div class="pa-source-grid">
        {quellen.map((source, index) => (
          <article class="pa-source kz-reveal" data-delay={(index % 4) + 1}>
            <div class="pa-source__k">{source.k}</div>
            <h3>{source.title}</h3>
            <p>{source.text}</p>
          </article>
        ))}
      </div>

      <div class="pa-explain kz-reveal" data-delay="3">
        <div>
          <h3>Wichtig für Kundenverständnis</h3>
          <p>
            Wenn der PA eine Antwort vorbereitet, steht dabei, woher der Kontext kommt:
            zum Beispiel Mailverlauf, CRM, Kundennotiz oder Kalender. Dadurch bleibt nachvollziehbar, worauf sich der Vorschlag stützt.
          </p>
        </div>
        <ul>
          <li>Keine sensiblen Aktionen ohne Freigabe.</li>
          <li>Keine Datenquelle ohne bewusste Anbindung.</li>
          <li>Kein „alles automatisieren", bevor der erste Bereich funktioniert.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="kz-section">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">14-Tage-Realitätscheck</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">Ob der KI-PA etwas taugt, sieht man nicht an einer Demo. Man sieht es an echter Arbeit.</h2>
      <p class="kz-lead kz-reveal" data-delay="2">
        Deshalb ist der erste Pilot begrenzt. Nicht alles anschließen, nicht alles automatisieren.
        Erst ein Bereich, echte Quellen, echte Entwürfe und danach eine belastbare Entscheidung.
      </p>
      <div class="pa-pilot-grid">
        {pilotSchritte.map((step, index) => (
          <article class="pa-pilot-card kz-reveal" data-delay={(index % 4) + 1}>
            <div class="pa-pilot-card__k">{step.k}</div>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="kz-section" style="background:var(--ink);color:var(--paper);">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal" style="color:#FFB088;">Erster sinnvoller Bereich</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1" style="color:#fff;">Meistens starten wir mit Mail, Kalender und Aufgaben.</h2>
      <p class="kz-lead kz-reveal" data-delay="2" style="color:rgba(255,255,255,0.7);">
        Dort ist der Nutzen schnell sichtbar: weniger Rückstand, bessere Vorbereitung, weniger vergessene Zusagen. Erst wenn das trägt, lohnt es sich, Belege, Telefon, Leads oder interne Wissenssysteme dazuzunehmen.
      </p>
      <div class="pa-dark-grid">
        <div class="pa-dark-card kz-reveal" data-delay="1">
          <h3>Morgens</h3>
          <p>Ein kurzes Briefing: Termine, wichtige Mails, offene Entscheidungen und Dinge, die nicht liegenbleiben sollten.</p>
        </div>
        <div class="pa-dark-card kz-reveal" data-delay="2">
          <h3>Tagsüber</h3>
          <p>Antwortentwürfe mit Vorgeschichte, Kundendetails und offenen Zusagen statt wieder fünf Minuten suchen.</p>
        </div>
        <div class="pa-dark-card kz-reveal" data-delay="3">
          <h3>Abends</h3>
          <p>Was wurde erledigt, was bleibt offen, was muss morgen zuerst auftauchen?</p>
        </div>
      </div>
    </div>
  </section>

  <section class="kz-section" style="background:var(--paper-2);">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Sicherheitsrahmen</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">Vertrauen entsteht, wenn klar ist, was die KI nicht darf.</h2>
      <p class="kz-lead kz-reveal" data-delay="2">
        Der KI-PA soll Arbeit vorbereiten, nicht heimlich Verantwortung übernehmen. Deshalb bekommt jedes Setup eine klare Freigabe-Matrix.
      </p>
      <div class="pa-guardrail-panel kz-reveal" data-delay="3">
        <div>
          <h3>Freigabe-Matrix</h3>
          <p>Drei einfache Kategorien reichen am Anfang: darf vorbereiten, muss fragen, darf nie. So bleibt die KI nützlich, ohne unsichtbar Verantwortung zu übernehmen.</p>
        </div>
        <ul>
          {guardrails.map((rule) => <li>{rule}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="kz-section">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Ablauf</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">Der Einstieg bleibt klein genug, um ihn sauber zu steuern.</h2>
      <div class="pa-process">
        {ablauf.map((step, index) => (
          <article class="pa-process__step kz-reveal" data-delay={(index % 4) + 1}>
            <div class="pa-process__k">{step.k}</div>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="kz-section pa-cta" id="kontakt">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Nächster Schritt</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">Nicht sicher, ob der KI-PA für Ihren Betrieb passt?</h2>
      <p class="kz-lead kz-reveal" data-delay="2">
        Genau dafür ist das Erstgespräch da. Wir prüfen gemeinsam, ob Mail, Kalender, Aufgaben oder ein anderer Bereich der bessere Einstieg ist.
      </p>
      <div class="kz-reveal" data-delay="3" style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:34px;">
        <a href="/erstgespraech" class="kz-btn kz-btn--primary">Kostenloses Erstgespräch buchen <span class="kz-btn__arrow">→</span></a>
        <a href={asyncMail} class="kz-btn kz-btn--ghost">3-Fragen-Check per Mail</a>
        <a href="/pricing" class="kz-btn kz-btn--ghost">Preise und Einstieg ansehen</a>
      </div>
    </div>
  </section>

  <footer class="kz-footer">
    <div class="kz-wrap" style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px;">
      <span>© k-AIzen · Benjamin Zirngibl</span>
      <span style="font-family:var(--font-mono);">KI-PA · Kontext · Freigaben</span>
    </div>
  </footer>

  <style>
    .kz-nav__brand { color:var(--ink); text-decoration:none; }
    .kz-nav__brand:hover { color:var(--ink); text-decoration:none; }
    .kz-logo-mark { width:24px; height:24px; object-fit:contain; display:block; }
    .kz-logo { font-weight:800; letter-spacing:-0.02em; }
    .kz-logo__ai { background:linear-gradient(120deg,var(--indigo),var(--violet)); -webkit-background-clip:text; background-clip:text; color:transparent; font-weight:800; }
    .pa-hero { min-height:calc(100vh - 88px); display:grid; align-items:center; padding-top:86px; }
    .pa-hero .kz-h1 { font-size:clamp(3rem, 5.4vw, 4.9rem); }
    .pa-hero__wrap { display:grid; grid-template-columns:minmax(0,1fr) minmax(340px,0.82fr); gap:clamp(32px,6vw,82px); align-items:center; position:relative; z-index:1; }
    .pa-hero__copy { min-width:0; }
    .pa-hero__media { position:relative; border-radius:var(--radius-xl); overflow:hidden; box-shadow:var(--shadow-lg); background:var(--card); border:1px solid var(--line); }
    .pa-hero__media img { width:100%; display:block; aspect-ratio:4/5; object-fit:cover; }
    .pa-hero__note { position:absolute; left:18px; right:18px; bottom:18px; padding:18px; border-radius:18px; background:rgba(11,16,32,0.82); color:#fff; backdrop-filter:blur(14px); box-shadow:0 20px 44px -20px rgba(0,0,0,0.45); }
    .pa-hero__note span { display:block; font-family:var(--font-mono); font-size:12px; color:#FFB088; margin-bottom:8px; }
    .pa-hero__note strong { display:block; font-size:1.05rem; margin-bottom:6px; }
    .pa-hero__note p { margin:0; color:rgba(255,255,255,0.72); line-height:1.45; font-size:0.95rem; }
    .pa-grid, .pa-source-grid, .pa-dark-grid, .pa-process, .pa-pilot-grid { display:grid; gap:18px; margin-top:46px; }
    .pa-grid { grid-template-columns:repeat(4,minmax(0,1fr)); }
    .pa-source-grid { grid-template-columns:repeat(4,minmax(0,1fr)); }
    .pa-dark-grid { grid-template-columns:repeat(3,minmax(0,1fr)); }
    .pa-process { grid-template-columns:repeat(4,minmax(0,1fr)); }
    .pa-pilot-grid { grid-template-columns:repeat(4,minmax(0,1fr)); }
    .pa-card, .pa-source, .pa-process__step, .pa-pilot-card { border:1px solid var(--line); background:var(--card); border-radius:var(--radius-lg); box-shadow:var(--shadow-sm); padding:26px; }
