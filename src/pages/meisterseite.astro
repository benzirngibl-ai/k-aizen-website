---
import KaizenLayout from '../layouts/KaizenLayout.astro';

// Meisterseite — Produktseite des Einstiegsprodukts (297 €/Mo, Handwerk).
// Plan: k-aizen/10-sales/INTEGRATIONSPLAN-website-meisterseite-2026-07-21.md
// VSL-Video: Platzhalter-Block unten — sobald Bens Video da ist, YouTube-Embed
// einsetzen (Kommentar an der Stelle).

const leistungen = [
  {
    title: 'Website, komplett gebaut',
    text: 'Modern, schnell, auf dem Handy perfekt. Sie liefern Logo, Fotos und Ihre Leistungen — den Rest machen wir.',
  },
  {
    title: 'Anfragen sofort auf Ihrem Handy',
    text: 'Jemand füllt Ihr Formular aus — Sekunden später haben Sie Name, Nummer und Anliegen als Benachrichtigung. Kein Lead versauert im Postfach.',
  },
  {
    title: 'Online-Terminanfrage',
    text: 'Ihre Kunden buchen einen Rückruf-Termin — auch abends um zehn, auch wenn Sie auf dem Gerüst stehen.',
  },
  {
    title: 'Dauerhaft betreut',
    text: 'Hosting, Pflege, Änderungen — alles drin. Neues Foto, andere Öffnungszeiten? Eine kurze Nachricht genügt, ist am selben Tag drin. Sie loggen sich nie ein.',
  },
  {
    title: 'Datenschutz eingebaut',
    text: 'Deutsche Server, kein US-Tracking, Impressum und Datenschutzerklärung sauber. Keine Abmahn-Angst.',
  },
  {
    title: 'Gefunden werden',
    text: 'Sauberer Suchmaschinen-Unterbau ab Werk — für Google und für KI-Antworten (strukturierte Daten, Sitemap, llms.txt). Dieselbe Technik wie bei unseren eigenen Portalen.',
  },
];

const ablauf = [
  {
    title: 'Kurzes Gespräch',
    text: 'Wir klären, was Ihr Betrieb braucht und ob das Paket zu Ihnen passt. Ehrliche Antwort inklusive — auch wenn sie „noch nicht" lautet.',
  },
  {
    title: 'Ihre Seite entsteht',
    text: 'Sie liefern einmal Logo, Fotos, Leistungen. Wenige Tage später steht Ihre Website — Sie schauen drüber, wir passen an.',
  },
  {
    title: 'Läuft — dauerhaft',
    text: 'Anfragen landen auf Ihrem Handy, Termine im Kalender. Änderungen jederzeit per Zuruf. Monatlich kündbar, ohne Kleingedrucktes.',
  },
];

const faqs = [
  {
    q: 'Ist das wirklich monatlich kündbar?',
    a: 'Ja. Keine Mindestlaufzeit, keine Einrichtungsgebühr. Wenn Sie kündigen, endet das Paket zum Monatsende — Ihr Risiko ist ein Monat.',
  },
  {
    q: 'Wie schnell ist meine Website online?',
    a: 'Sobald Logo, Fotos und Ihre Leistungen da sind, steht die Seite in der Regel innerhalb weniger Tage. Sie sehen sie vor dem Livegang.',
  },
  {
    q: 'Was muss ich selbst machen?',
    a: 'Einmalig Material liefern (Logo, ein paar Fotos, Ihre Leistungen) — das war es. Sie loggen sich nirgendwo ein und pflegen nichts. Änderungswünsche schicken Sie formlos per Nachricht.',
  },
  {
    q: 'Wem gehört die Domain?',
    a: 'Ihre Domain gehört Ihnen bzw. wird auf Ihren Betrieb registriert. Wenn Sie gehen, nehmen Sie sie mit.',
  },
  {
    q: 'Für wen ist das nichts?',
    a: 'Für brandneue Betriebe ohne Kunden und Bewertungen. Da bringt eine Website allein noch zu wenig — das sagen wir dann auch so.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': 'https://k-aizen.de/meisterseite#webpage',
      url: 'https://k-aizen.de/meisterseite',
      name: 'Meisterseite — Website komplett gebaut und betreut, 297 €/Monat',
      description:
        'Das Website-Paket für Handwerksbetriebe: komplett gebaut, dauerhaft betreut, jede Anfrage sofort auf Ihrem Handy. 297 € im Monat, keine Einrichtungsgebühr, monatlich kündbar.',
      inLanguage: 'de-DE',
      isPartOf: { '@id': 'https://k-aizen.de/#website' },
    },
    {
      '@type': 'Service',
      '@id': 'https://k-aizen.de/meisterseite#service',
      name: 'Meisterseite — Website-Paket für Handwerksbetriebe',
      serviceType: 'Website-Erstellung und dauerhafte Betreuung',
      provider: {
        '@type': 'ProfessionalService',
        name: 'k-AIzen',
        url: 'https://k-aizen.de',
        email: 'kontakt@k-aizen.de',
      },
      areaServed: ['Nürnberg', 'Fürth', 'Erlangen', 'Schwabach'],
      offers: {
        '@type': 'Offer',
        price: '297',
        priceCurrency: 'EUR',
        priceSpecification: {
          '@type': 'UnitPriceSpecification',
          price: '297',
          priceCurrency: 'EUR',
          unitText: 'Monat',
        },
        availability: 'https://schema.org/InStock',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://k-aizen.de/meisterseite#faq',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<KaizenLayout
  title="Meisterseite — Ihre Website, komplett gemacht"
  description="Das Website-Paket für Handwerksbetriebe im Raum Nürnberg: komplett gebaut, dauerhaft betreut, jede Anfrage sofort auf Ihrem Handy. 297 €/Monat, keine Einrichtungsgebühr, monatlich kündbar."
  path="/meisterseite"
  activeNav="pricing"
  jsonLd={schema}
  breadcrumbs={[{ name: 'Meisterseite', href: '/meisterseite' }]}
>
  <article class="kz-page">
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" />
      <span>Meisterseite · für Handwerksbetriebe</span>
    </div>
    <h1 class="kz-h1">Ihre Website.<br /><span class="accent">Komplett gemacht.</span></h1>
    <p class="kz-lead">
      Wir bauen und betreuen Ihre Website komplett — und jede Anfrage landet direkt
      auf Ihrem Handy. Für Handwerksbetriebe im Raum Nürnberg, die gute Arbeit machen,
      aber online kaum zu finden sind.
    </p>

    <!-- Preis sofort sichtbar (Kai-Prinzip: Karten auf den Tisch) -->
    <section
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin: 0 0 24px;"
    >
      <div style="padding: 20px 22px; border-radius: 12px; background: var(--kz-cream-deep); border: 1px solid rgba(232,90,43,0.14); text-align: center;">
        <div style="font-size: 26px; font-weight: 800; color: var(--indigo-deep);">297 €/Monat</div>
        <div style="font-size: 13px; color: var(--fg-muted); margin-top: 4px;">alles inklusive</div>
      </div>
      <div style="padding: 20px 22px; border-radius: 12px; background: var(--kz-cream-deep); border: 1px solid rgba(232,90,43,0.14); text-align: center;">
        <div style="font-size: 26px; font-weight: 800; color: var(--indigo-deep);">0 €</div>
        <div style="font-size: 13px; color: var(--fg-muted); margin-top: 4px;">Einrichtungsgebühr</div>
      </div>
      <div style="padding: 20px 22px; border-radius: 12px; background: var(--kz-cream-deep); border: 1px solid rgba(232,90,43,0.14); text-align: center;">
        <div style="font-size: 26px; font-weight: 800; color: var(--indigo-deep);">monatlich</div>
        <div style="font-size: 13px; color: var(--fg-muted); margin-top: 4px;">kündbar</div>
      </div>
    </section>

    <div style="display: flex; flex-wrap: wrap; gap: 12px;">
      <a href="https://cal.k-aizen.de/ben-kaizen/rueckruf" class="kz-btn" target="_blank" rel="noopener">Rückruf-Termin wählen</a>
      <a href="https://muster.k-aizen.de" class="kz-btn kz-btn-ghost" target="_blank" rel="noopener">Muster-Website ansehen →</a>
    </div>

    <!-- VSL-Block — PLATZHALTER. Sobald Bens Video da ist (YouTube unlisted):
         den Inhalt dieses Blocks durch das Embed ersetzen:
         <div style="position:relative;aspect-ratio:16/9;border-radius:12px;overflow:hidden;">
           <iframe src="https://www.youtube-nocookie.com/embed/VIDEO_ID" title="Meisterseite in 5 Minuten"
             style="position:absolute;inset:0;width:100%;height:100%;border:0;" allowfullscreen loading="lazy"></iframe>
         </div>  -->
    <section style="margin-top: 64px; padding: 48px clamp(24px, 4vw, 48px); background: var(--kz-charcoal); border-radius: 12px;">
      <h2 class="kz-h2" style="margin-top: 0;">In fünf Minuten erklärt</h2>
      <p>
        Das kurze Video, das Paket und Preis komplett zeigt, entsteht gerade.
        Bis dahin gibt es etwas Besseres als jedes Video: die Muster-Website.
        Klicken Sie sich durch — genau so sieht Ihre Seite aus, nur mit Ihrem Namen drauf.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px;">
        <a href="https://muster.k-aizen.de" class="kz-btn" target="_blank" rel="noopener">Zur Muster-Website →</a>
      </div>
    </section>

    <!-- Live-Demo -->
    <section style="margin-top: 24px; padding: 28px 32px; background: var(--kz-cream-deep); border-radius: 12px;">
      <h3 style="margin: 0 0 8px; font-size: 18px; color: var(--fg-inverse);">Probieren Sie den wichtigsten Teil live aus</h3>
      <p style="margin: 0; color: var(--fg-inverse); font-size: 15px; line-height: 1.65;">
        Füllen Sie auf der Muster-Website ruhig das Anfrage-Formular aus und senden Sie es ab —
        genau diese Anfrage landet Sekunden später als Benachrichtigung auf einem Handy.
        Bei Ihrer Website ist es dann Ihres.
      </p>
    </section>

    <section style="margin-top: 56px;">
      <h2 class="kz-h2">Was alles drin ist</h2>
      <p>Ein Preis, alles inklusive — kein Baukasten, keine versteckten Extras.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; margin-top: 24px;">
        {
          leistungen.map((l) => (
            <article style="padding: 22px; border-radius: 12px; background: var(--kz-cream-deep); color: var(--fg-inverse); border: 1px solid rgba(232,90,43,0.14);">
              <h3 style="margin: 0 0 8px; font-size: 17px;">{l.title}</h3>
              <p style="margin: 0; color: var(--fg-inverse); font-size: 15px; line-height: 1.6;">{l.text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section style="margin-top: 56px;">
      <h2 class="kz-h2">So läuft es ab</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 14px; margin-top: 24px;">
        {
          ablauf.map((s, i) => (
            <article style="padding: 22px; border-radius: 12px; background: var(--kz-cream-deep); color: var(--fg-inverse); border: 1px solid rgba(232,90,43,0.14);">
              <div style="width: 36px; height: 36px; border-radius: 999px; background: linear-gradient(135deg, var(--indigo), var(--violet)); color: #fff; font-weight: 800; display: flex; align-items: center; justify-content: center; margin-bottom: 12px;">
                {i + 1}
              </div>
              <h3 style="margin: 0 0 8px; font-size: 17px;">{s.title}</h3>
              <p style="margin: 0; color: var(--fg-inverse); font-size: 15px; line-height: 1.6;">{s.text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section style="margin-top: 56px;">
      <h2 class="kz-h2">Rechnen Sie es kurz durch</h2>
      <p>
        Eine Agentur nimmt für so eine Website drei- bis zehntausend Euro — einmalig,
        und danach sind Sie wieder allein damit. Hier zahlen Sie am Anfang nichts,
        und die Betreuung ist dauerhaft dabei.
      </p>
      <p>
        Und die eigentliche Rechnung: Was ist ein einziger zusätzlicher Auftrag bei
        Ihnen wert? Bei den meisten Betrieben zahlt <strong>ein</strong> Auftrag im
        Jahr das ganze Paket. Alles darüber ist Ihres.
      </p>
    </section>

    <section style="margin-top: 56px;">
      <h2 class="kz-h2">Ganz ehrlich: für wen das nichts ist</h2>
      <p>
        Wenn Ihr Betrieb brandneu ist und noch keine Kunden und Bewertungen hat,
        bringt Ihnen eine Website allein noch nicht viel — dann sagen wir Ihnen das
        auch so. Am besten funktioniert das Paket für Betriebe, die gut arbeiten und
        gute Bewertungen haben, aber online praktisch unsichtbar sind. Wenn Sie sich
        da wiedererkennen: genau dafür ist es gebaut.
      </p>
    </section>

    <section style="margin-top: 56px;">
      <h2 class="kz-h2">Häufige Fragen</h2>
      <div style="display: grid; gap: 12px; margin-top: 24px;">
        {
          faqs.map((f) => (
            <details style="padding: 18px 22px; border-radius: 12px; background: var(--kz-cream-deep); border: 1px solid rgba(232,90,43,0.14);">
              <summary style="font-weight: 800; color: var(--fg-inverse); cursor: pointer; font-size: 16px;">{f.q}</summary>
              <p style="margin: 12px 0 0; color: var(--fg-inverse); font-size: 15px; line-height: 1.65;">{f.a}</p>
            </details>
          ))
        }
      </div>
    </section>

    <!-- Abschluss-CTA -->
    <section style="margin-top: 80px; padding: 56px clamp(24px, 4vw, 48px); background: var(--kz-cream-deep); border-radius: 12px;">
      <h2 class="kz-h2" style="margin-top: 0; color: var(--fg-inverse);">Der nächste Schritt ist ein Gespräch</h2>
      <p style="color: var(--fg-inverse);">
        Kein Verkaufsmarathon: Sie wählen einen Rückruf-Termin, wir sprechen 15 Minuten
        über Ihren Betrieb, und Sie entscheiden in Ruhe. Wenn es nicht passt, sagen wir
        das ehrlich.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px;">
        <a href="https://cal.k-aizen.de/ben-kaizen/rueckruf" class="kz-btn" target="_blank" rel="noopener">Rückruf-Termin wählen</a>
        <a href="mailto:kontakt@k-aizen.de?subject=Meisterseite" class="kz-btn kz-btn-ghost">Oder kurz per Mail</a>
      </div>
      <p style="margin-top: 28px; font-size: 14px; color: var(--fg-muted);">
        Die Meisterseite ist der Einstieg. Wer später mehr will — etwa eine KI-Stimme,
        die Anrufe annimmt und direkt Termine vereinbart — findet bei k-AIzen die
        nächsten Stufen. Eins nach dem anderen.
      </p>
    </section>
  </article>
</KaizenLayout>
