---
import KaizenLayout from '../../layouts/KaizenLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Wissens-Suche Workflow",
  "description": "Semantische Suche über alle Firmen-Dokumente, Mails, Tickets. Antwort auf Deutsch mit Quellenangabe. DSGVO-konform, deutsche Cloud.",
  "provider": { "@type": "Organization", "name": "k-AIzen", "url": "https://k-aizen.de" },
  "areaServed": "DE",
  "serviceType": "Enterprise-Knowledge-Search",
  "url": "https://k-aizen.de/workflows/wissens-suche"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Welche Datenquellen werden indexiert?", "acceptedAnswer": { "@type": "Answer", "text": "Mail-Archive (Outlook, Gmail, IMAP), Dokumente (PDF, Word, Markdown, Excel, PowerPoint), Wiki/Notion/Confluence, Ticket-Systeme (Zendesk, Freshdesk, Jira). Optional auch Slack/Teams-Verläufe — auf Wunsch und mit Mitarbeitenden-Einverständnis." } },
    { "@type": "Question", "name": "Wie aktuell ist der Index?", "acceptedAnswer": { "@type": "Answer", "text": "Standardmäßig täglich aktualisiert (nachts). Echtzeit-Sync möglich für Mail (alle 5 Min) und Dokumenten-Ordner (Watch-Mode). Bei Tickets je nach API meist 15-30 Min Lag." } },
    { "@type": "Question", "name": "Halluziniert die AI bei den Antworten?", "acceptedAnswer": { "@type": "Answer", "text": "Wir nutzen Retrieval-Augmented Generation (RAG) — die AI darf nur antworten was tatsächlich in den indexierten Dokumenten steht. Bei jeder Antwort werden klickbare Quellen angegeben. Wenn nichts gefunden wird, sagt die AI das ehrlich anstatt zu erfinden." } },
    { "@type": "Question", "name": "Wo werden die Daten gespeichert?", "acceptedAnswer": { "@type": "Answer", "text": "Standard: deutscher Cloud-Provider (Hetzner Nürnberg). Alternative: lokal bei dir auf einem Server (NAS, On-Premise-Box). Für besonders sensible Branchen empfehlen wir On-Premise — kein Datentransfer raus, alles bleibt im Haus." } },
    { "@type": "Question", "name": "Können Mitarbeitende sehen was Kollegen suchen?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Such-Logs sind privat pro Nutzer. Admin-Reports zeigen nur aggregierte Themen-Statistiken (z.B. 'Suchen zu Compliance haben um 30% zugenommen') — niemals individual-Niveau." } },
    { "@type": "Question", "name": "Was passiert mit alten / vertraulichen Dokumenten?", "acceptedAnswer": { "@type": "Answer", "text": "Du definierst Berechtigungen pro Ordner / Quelle. Der Index respektiert deine Active-Directory- oder Sharepoint-Permissions. Vertrauliche Personalakten z.B. werden nur für HR-Berechtigte durchsucht — nicht für alle." } }
  ]
};
---

<KaizenLayout
  title="Wissens-Suche — Eine Suche, eine Antwort, mit Quellen"
  description="Semantische Suche über alle Firmen-Dokumente, Mails, Tickets. RAG-basiert, keine Halluzinationen, klickbare Quellen. DSGVO-konform, deutsche Cloud oder On-Premise."
  path="/workflows/wissens-suche"
  activeNav="workflows"
  breadcrumbs={[{ name: 'Workflows', href: '/workflows' }, { name: 'Wissens-Suche', href: '/workflows/wissens-suche' }]}
  jsonLd={[serviceSchema, faqSchema]}
>
  <article class="kz-page">
    <p style="margin-bottom: 16px;">
      <a href="/workflows" style="font-size: 14px; color: var(--fg-muted);">← Alle Workflows</a>
    </p>
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" loading="lazy" />
      <span class="kanji">四</span>
      <span>Workflow 4 von 4</span>
    </div>
    <h1 class="kz-h1">Wissens-Suche.<br/><span style="color: var(--kz-ember); font-style: italic;">Eine Suche. Eine Antwort. Mit Quellen.</span></h1>
    <p class="kz-lead">
      Eine zentrale Suche über alles was deine Firma weiß. Mails, PDFs, Verträge, Wiki-Einträge, Ticket-Archive. Du fragst auf Deutsch — kriegst eine Antwort mit Quellenangabe. Keine erfundenen Antworten, keine Halluzinationen.
    </p>

    <section>
      <h2 class="kz-h2">Was reinkommt</h2>
      <ul>
        <li><strong>Mail-Archive</strong> — Outlook, Gmail, IMAP-Server</li>
        <li><strong>Dokumente</strong> — PDF, Word, Excel, PowerPoint, Markdown</li>
        <li><strong>Wiki / Confluence / Notion</strong></li>
        <li><strong>Ticket-Systeme</strong> — Zendesk, Freshdesk, Jira</li>
        <li><strong>Optional</strong> — Slack/Teams-Verläufe (mit Mitarbeitenden-Einverständnis)</li>
      </ul>

      <h2 class="kz-h2">Wie eine Antwort aussieht</h2>
      <p>
        „Zur Frage X ist die Antwort Y. Steht in <strong>Datei Z</strong> (Seite 4) und <strong>Mail vom 12.03.2025</strong>."
      </p>
      <p>
        Mit klickbaren Links direkt zur Quelle. Keine erfundenen Antworten — wenn die AI nichts findet, sagt sie das.
      </p>
      <p class="kz-quote">
        „Mein Steuerberater fragt nach der AVV-Klausel von 2023. Ich tippe die Frage in die Suche, kriege die Antwort plus den Vertrag aus dem Archiv. 90 Sekunden statt 20 Minuten Ordner-Wühlen."
      </p>

      <h2 class="kz-h2">Compliance — der wichtigste Teil</h2>
      <ul>
        <li><strong>Daten verlassen deinen Server nicht</strong> — Index wird lokal oder auf deutscher Cloud (Hetzner, IONOS) gehostet</li>
        <li><strong>RAG-basierte Antworten</strong> — die AI nutzt nur tatsächlich vorhandene Dokumente, generiert nichts dazu</li>
        <li><strong>Berechtigungs-Respekt</strong> — Active-Directory / Sharepoint-Permissions werden eingehalten, vertrauliche Ordner sind nur für Berechtigte durchsuchbar</li>
        <li><strong>Auftragsverarbeitungsvertrag</strong> nach Art. 28 DSGVO inklusive</li>
        <li><strong>Auf Wunsch On-Premise</strong> — kompletter Stack auf deinem Server, kein Cloud-Bestandteil</li>
      </ul>

      <h2 class="kz-h2">Tech-Stack</h2>
      <ul>
        <li><strong>Indexer:</strong> ETL-Pipeline die täglich (oder Echtzeit) deine Quellen abscannt</li>
        <li><strong>Vector-DB:</strong> Qdrant oder Weaviate self-hosted, kein US-SaaS</li>
        <li><strong>Embedding-Modell:</strong> mxbai-embed-large (deutsch optimiert) lokal oder Cohere via deutsche Region</li>
        <li><strong>LLM:</strong> Claude für Antwort-Generierung — alternativ Llama 3 lokal für maximale Datensouveränität</li>
        <li><strong>UI:</strong> Browser-Suche-Interface ODER Plugin in dein bestehendes Intranet</li>
      </ul>
    </section>

    <section style="margin-top: 80px; padding: 48px; background: var(--kz-cream-deep); border-radius: 12px;">
      <h2 class="kz-h2" style="margin-top: 0;">Klingt nach deinem Schmerz?</h2>
      <p style="margin-bottom: 28px;">30-Min-Erstgespräch. Wir hören zu, du erzählst.</p>
      <a href="/erstgespraech" class="kz-btn">Termin vorschlagen</a>
      <a href="/workflows" class="kz-btn kz-btn-ghost" style="margin-left: 12px;">← Alle Workflows</a>
    </section>
  </article>
</KaizenLayout>
