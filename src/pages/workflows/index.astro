---
import KaizenLayout from '../../layouts/KaizenLayout.astro';

const workflowsSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "k-AIzen Standard-Workflows für KMUs",
  "description": "Vier standardisierte AI-Automation-Workflows für mittelständische Unternehmen.",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inbox-Triage", "url": "https://k-aizen.de/workflows/inbox-triage" },
    { "@type": "ListItem", "position": 2, "name": "Angebots-Generator", "url": "https://k-aizen.de/workflows/angebote" },
    { "@type": "ListItem", "position": 3, "name": "Tagesreport", "url": "https://k-aizen.de/workflows/tagesreport" },
    { "@type": "ListItem", "position": 4, "name": "Wissens-Suche", "url": "https://k-aizen.de/workflows/wissens-suche" }
  ]
};

const workflows = [
  { kanji: '一', slug: 'inbox-triage', title: 'Inbox-Triage', tagline: 'AI klassifiziert. Mensch entscheidet.', desc: 'Mails, Form-Submissions, Telefon-Notizen kontinuierlich klassifiziert + priorisiert + mit Antwort-Vorschlägen aufbereitet — keine Auto-Antwort, du behältst die Kontrolle.', time: '1-2 Wochen Live' },
  { kanji: '二', slug: 'angebote', title: 'Angebots-Generator', tagline: 'Aus 3 Stichworten ein fertiges Angebot.', desc: 'Du gibst Kunde + 3-5 Stichworte ein, AI generiert ein vollständiges, individualisiertes Angebot in deinem Branding mit korrekten Konditionen. 5 Min statt 45.', time: '2-3 Wochen Live' },
  { kanji: '三', slug: 'tagesreport', title: 'Tagesreport', tagline: 'Jeden Morgen 7:30 in der Inbox.', desc: 'Verkaufs-Zahlen, Auffälligkeiten gegenüber 30-Tage-Schnitt, offene Mails, Termine, 3-5 priorisierte To-Dos. Zwei Minuten Lese-Zeit, voller Tages-Überblick.', time: '1 Woche Live' },
  { kanji: '四', slug: 'wissens-suche', title: 'Wissens-Suche', tagline: 'Eine Suche. Eine Antwort. Mit Quellen.', desc: 'Mails, PDFs, Wiki, Tickets — alles indexiert. Du fragst auf Deutsch, kriegst die Antwort mit klickbarer Quellenangabe. Compliance-aware, deutsche Cloud.', time: '2-3 Wochen Live' },
];
---

<KaizenLayout
  title="Workflows — Vier AI-Automationen für den Mittelstand"
  description="Inbox-Triage, Angebots-Generator, Tagesreport, Wissens-Suche. Vier standardisierte AI-Workflows für KMUs in Deutschland. Jeder läuft live in 1-2 Wochen."
  path="/workflows"
  activeNav="workflows"
  jsonLd={workflowsSchema}
>
  <article class="kz-page">
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" loading="lazy" />
      <span class="kanji">流</span>
      <span>Workflows</span>
    </div>
    <h1 class="kz-h1">Vier Workflows. Sofort einsatzbereit.</h1>
    <p class="kz-lead">
      Wir bauen für jedes KMU andere Workflows — aber vier Patterns sehen wir immer wieder. Die hier kannst du in 1-2 Wochen live haben. Klick rein, lies die Details, sag was passt.
    </p>

    <section style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin: 64px 0;">
      {workflows.map((w) => (
        <a href={`/workflows/${w.slug}`} style="display: block; padding: 36px 32px; background: var(--kz-card); border: 1px solid var(--kz-border); border-radius: 12px; text-decoration: none !important; color: var(--fg); transition: all 280ms var(--ease-out); position: relative;">
          <div style="display: flex; align-items: baseline; gap: 14px; margin-bottom: 16px;">
            <span style="font-family: var(--font-jp); font-size: 36px; color: var(--kz-ember); line-height: 1;">{w.kanji}</span>
            <h2 class="kz-h2" style="margin: 0; font-size: clamp(22px, 2.4vw, 28px);">{w.title}</h2>
          </div>
          <p style="font-style: italic; color: var(--fg-muted); margin: 0 0 16px;">{w.tagline}</p>
          <p style="margin: 0 0 24px; font-size: 16px; line-height: 1.6;">{w.desc}</p>
          <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 16px; border-top: 1px solid var(--kz-border);">
            <span style="font-family: var(--font-brush); font-size: 19px; color: var(--kz-ember);">{w.time}</span>
            <span style="font-size: 14px; font-weight: 600; color: var(--fg);">Details lesen →</span>
          </div>
        </a>
      ))}
    </section>

    <section style="margin-top: 96px; padding: 56px clamp(24px, 4vw, 48px); background: var(--kz-cream-deep); border-radius: 12px;">
      <h2 class="kz-h2" style="margin-top: 0;">Welcher Workflow passt zu dir?</h2>
      <p>Drei Wege das herauszufinden:</p>
      <ul>
        <li><strong>Erstgespräch (30 Min, kostenlos)</strong> — du erzählst, wir hören zu, am Ende wissen wir beide ob's passt</li>
        <li><strong>Schreiben</strong> per Mail an <a href="mailto:hallo@k-aizen.de">hallo@k-aizen.de</a> mit ein paar Stichworten</li>
        <li><strong>Selbst lesen</strong> — die <a href="/tutorials">Tutorials</a> zeigen wie wir bauen, ohne dass du mit uns sprechen musst</li>
      </ul>
      <p style="margin-top: 32px;">
        <a href="/erstgespraech" class="kz-btn">Termin vorschlagen →</a>
      </p>
    </section>
  </article>
</KaizenLayout>
