---
import KaizenLayout from '../../layouts/KaizenLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Tagesreport Workflow",
  "description": "Automatischer täglicher Geschäfts-Report für KMUs. Zahlen, Auffälligkeiten, To-Dos in 2 Min Lesezeit.",
  "provider": { "@type": "Organization", "name": "k-AIzen", "url": "https://k-aizen.de" },
  "areaServed": "DE",
  "serviceType": "Business-Reporting-Automation",
  "url": "https://k-aizen.de/workflows/tagesreport"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Welche Datenquellen werden unterstützt?", "acceptedAnswer": { "@type": "Answer", "text": "Lexware, DATEV, sevDesk, eigene ERP-Systeme, Excel/Google-Sheets, JTL, Shopware, WooCommerce. Alles was eine Schnittstelle hat oder regelmäßig CSV-Exports liefert. Bei rein manuellen Zahlen-Eingaben bauen wir einen schnellen Web-Eingabe-Form." } },
    { "@type": "Question", "name": "Wann genau kommt der Report?", "acceptedAnswer": { "@type": "Answer", "text": "Standardmäßig 7:30 Uhr Local-Time. Du kannst die Zeit frei wählen — manche bevorzugen 6:00 vor dem Pendeln, andere 8:00 mit dem ersten Kaffee. Plus optional Wochenend-Versionen mit anderen Inhalten." } },
    { "@type": "Question", "name": "In welchem Format kommt der Report?", "acceptedAnswer": { "@type": "Answer", "text": "Standardmäßig E-Mail (HTML mit Charts). Optional Push an Slack/Teams/Telegram. PDF-Anhang für Archiv-Dropbox falls gewünscht. Mobile-optimiert — du liest es im Stau." } },
    { "@type": "Question", "name": "Werden Daten an externe AI-Provider geschickt?", "acceptedAnswer": { "@type": "Answer", "text": "Nur die anonymisierte Aggregat-Ebene wird zur AI-Analyse geschickt — keine Kunden-Namen, keine konkreten Beträge. Die AI macht nur das 'Was ist auffällig'-Pattern. Volle Daten bleiben on-premise." } },
    { "@type": "Question", "name": "Was passiert wenn ein Datenquelle ausfällt?", "acceptedAnswer": { "@type": "Answer", "text": "Der Report wird trotzdem zugestellt mit dem Hinweis dass Quelle X nicht erreichbar ist. Du wirst sofort gewarnt — wir warten nicht 24h." } }
  ]
};
---

<KaizenLayout
  title="Tagesreport — Jeden Morgen 7:30 in der Inbox"
  description="Täglicher Geschäfts-Report für KMUs. Zahlen aus Lexware/DATEV, Auffälligkeiten, To-Dos in 2 Min Lesezeit. Nur Lese-Verbindung, keine Schreib-Operation."
  path="/workflows/tagesreport"
  activeNav="workflows"
  breadcrumbs={[{ name: 'Workflows', href: '/workflows' }, { name: 'Tagesreport', href: '/workflows/tagesreport' }]}
  jsonLd={[serviceSchema, faqSchema]}
>
  <article class="kz-page">
    <p style="margin-bottom: 16px;">
      <a href="/workflows" style="font-size: 14px; color: var(--fg-muted);">← Alle Workflows</a>
    </p>
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" loading="lazy" />
      <span class="kanji">三</span>
      <span>Workflow 3 von 4</span>
    </div>
    <h1 class="kz-h1">Tagesreport.<br/><span style="color: var(--kz-ember); font-style: italic;">Zwei Minuten Lesezeit. Kompletter Tages-Überblick.</span></h1>
    <p class="kz-lead">
      Jeden Morgen um 7:30 landet in deiner Inbox eine Zusammenfassung. Was ist gestern passiert. Welche Zahlen sind auffällig. Was muss heute entschieden werden.
    </p>

    <section>
      <h2 class="kz-h2">Was im Report steht</h2>
      <ul>
        <li><strong>Verkaufs-Zahlen vom Vortag</strong> — Umsatz, Margen, Top 5 Kunden, Top 5 Artikel</li>
        <li><strong>Abweichungen</strong> vom 30-Tage-Durchschnitt (positiv und negativ, mit Erklärung wenn die AI eine Hypothese hat)</li>
        <li><strong>Offene Mails &gt;24h</strong> ohne Antwort — sortiert nach Priorität</li>
        <li><strong>Termine + Reminders</strong> für heute und die nächsten 3 Tage</li>
        <li><strong>3-5 priorisierte To-Dos</strong> basierend auf Kontext (was ist liegengeblieben, was wird kritisch, was ist easy-win)</li>
        <li><strong>Cash-Position</strong> (optional, wenn gewünscht): Bank-Saldo, fällige Rechnungen, offene Forderungen</li>
      </ul>

      <h2 class="kz-h2">Wo die Daten herkommen</h2>
      <p>
        Aus dem System das du schon hast — Lexware, DATEV, sevDesk, eigenes ERP, Excel-Sheets, Google-Tabellen, eCommerce-Plattformen. Wir bauen nur eine <strong>Lese-Verbindung</strong>. Schreibend ändern wir nichts.
      </p>
      <p class="kz-quote">
        Der Report soll dir Zeit sparen, nicht neue Risiken schaffen.
      </p>

      <h2 class="kz-h2">Format</h2>
      <ul>
        <li><strong>E-Mail</strong> (Default) — HTML mit kleinen Charts, mobile-optimiert</li>
        <li><strong>Slack / Teams / Telegram</strong> — Push wenn dein Team-Setup das verträgt</li>
        <li><strong>PDF im Archiv-Folder</strong> für spätere Audits / Steuerberater-Übergaben</li>
      </ul>

      <h2 class="kz-h2">Compliance</h2>
      <p>
        Daten bleiben in deinem Kontext: Berechnungen passieren auf einem deutschen Server (Hetzner, IONOS oder lokal bei dir). Nur anonymisierte Aggregate werden zur AI-Analyse geschickt — keine Kunden-Namen, keine konkreten Beträge. Auftragsverarbeitungsvertrag inklusive.
      </p>
    </section>

    <section style="margin-top: 80px; padding: 48px; background: var(--kz-cream-deep); border-radius: 12px;">
      <h2 class="kz-h2" style="margin-top: 0;">Klingt nach deinem Schmerz?</h2>
      <p style="margin-bottom: 28px;">30-Min-Erstgespräch. Wir hören zu, du erzählst.</p>
      <a href="/erstgespraech" class="kz-btn">Termin vorschlagen</a>
      <a href="/workflows/wissens-suche" class="kz-btn kz-btn-ghost" style="margin-left: 12px;">Nächster Workflow: Wissens-Suche →</a>
    </section>
  </article>
</KaizenLayout>
