---
import KaizenLayout from '../../layouts/KaizenLayout.astro';
import SlideLayout from '../../components/pitch/SlideLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const variantsDir = path.join(process.cwd(), 'src/pages/pitch/_variants');
  const files = fs.readdirSync(variantsDir).filter(f => f.endsWith('.json'));
  return files.map(f => ({
    params: { variant: path.basename(f, '.json') }
  }));
}

const { variant } = Astro.params;
const variantsDir = path.join(process.cwd(), 'src/pages/pitch/_variants');
const raw = fs.readFileSync(path.join(variantsDir, `${variant}.json`), 'utf-8');
const data = JSON.parse(raw);

const imageFolder = data.character.image_folder;
const imageUrl = (slideImage: string) => `${imageFolder}/${slideImage}`;
---

<KaizenLayout
  title={data.title}
  description={data.description}
  path={`/pitch/${variant}`}
  noindex={true}
  hideChrome={true}
  activeNav="home"
>
  <main class="pitch-deck" id="pitch-deck" data-total={data.slides.length}>
    {data.slides.map((slide: any, idx: number) => (
      <div class="pitch-slide-wrapper" data-slide-index={idx} id={`slide-${idx}`}>
        <SlideLayout
          type={slide.type}
          time={slide.time}
          scene_label={slide.scene_label}
          imageUrl={imageUrl(slide.image)}
          imageAlt={`${data.character.story_name} · ${slide.scene_label || slide.headline}`}
          headline={slide.headline}
          subheadline={slide.subheadline}
          body={slide.body}
          discord={slide.discord}
          cta_label={slide.cta_label}
          cta_href={slide.cta_href}
        />
      </div>
    ))}
  </main>

  <div class="pitch-progress-bar" aria-hidden="true">
    <div class="pitch-progress-fill" id="pitch-progress-fill"></div>
  </div>

  <nav class="pitch-nav" aria-label="Slide-Navigation">
    <button id="pitch-prev" aria-label="Vorherige Slide" class="pitch-nav-btn">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="pitch-nav-dots" id="pitch-nav-dots">
      {data.slides.map((_: any, idx: number) => (
        <button class="pitch-nav-dot" data-dot-index={idx} aria-label={`Slide ${idx + 1}`}></button>
      ))}
    </div>
    <span id="pitch-progress" class="pitch-progress">1 / {data.slides.length}</span>
    <button id="pitch-next" aria-label="Nächste Slide" class="pitch-nav-btn">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </nav>
</KaizenLayout>

<style is:global>
  html, body {
    overflow: hidden;
    height: 100%;
  }
  body {
    background: #F5F0E8;
  }
</style>

<style>
  .pitch-deck {
    scroll-snap-type: y mandatory;
    overflow-y: scroll;
    overflow-x: hidden;
    height: 100vh;
    scroll-behavior: smooth;
    background: #F5F0E8;
    -webkit-overflow-scrolling: touch;
  }

  .pitch-slide-wrapper {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    position: relative;
  }

  /* === Top Progress Bar === */
  .pitch-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(26, 26, 26, 0.06);
    z-index: 200;
    pointer-events: none;
  }

  .pitch-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #FF5500, #FF8833);
    width: 0%;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 0 14px rgba(255, 85, 0, 0.45);
  }

  /* === Glassmorphism Nav (bottom) === */
  .pitch-nav {
    position: fixed;
    bottom: 28px;
    left: 50%;
    background: rgba(26, 26, 26, 0.65);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    z-index: 150;
    box-shadow:
      0 20px 50px -20px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(0, 0, 0, 0.05);
    opacity: 0;
    transform: translateX(-50%) translateY(12px);
    animation: pitch-nav-enter 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  @keyframes pitch-nav-enter {
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  .pitch-nav-btn {
    background: transparent;
    border: none;
    color: rgba(245, 240, 232, 0.85);
    cursor: pointer;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s cubic-bezier(0.22, 0.61, 0.36, 1), color 0.3s, transform 0.3s;
  }

  .pitch-nav-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
    transform: scale(1.08);
  }

  .pitch-nav-btn:active {
    transform: scale(0.96);
  }

  .pitch-nav-dots {
    display: flex;
    gap: 6px;
    padding: 0 4px;
  }

  .pitch-nav-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(245, 240, 232, 0.3);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pitch-nav-dot:hover {
    background: rgba(245, 240, 232, 0.6);
    transform: scale(1.3);
  }

  .pitch-nav-dot.is-active {
    background: #FF5500;
    width: 24px;
    border-radius: 3px;
    box-shadow: 0 0 12px rgba(255, 85, 0, 0.55);
  }

  .pitch-progress {
    color: rgba(245, 240, 232, 0.75);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    min-width: 44px;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 640px) {
    .pitch-nav-dots {
      display: none;
    }
    .pitch-nav {
      bottom: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pitch-deck { scroll-behavior: auto; }
    .pitch-nav,
    .pitch-progress-fill,
    .pitch-nav-dot,
    .pitch-nav-btn {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  const deck = document.getElementById('pitch-deck');
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.pitch-slide-wrapper'));
  const prevBtn = document.getElementById('pitch-prev');
  const nextBtn = document.getElementById('pitch-next');
  const progressLabel = document.getElementById('pitch-progress');
  const progressFill = document.getElementById('pitch-progress-fill');
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.pitch-nav-dot'));
  const totalSlides = slides.length;

  let currentIndex = 0;
  let isProgrammaticScroll = false;
  let scrollEndTimer: number | null = null;

  function updateProgress() {
    if (progressLabel) progressLabel.textContent = `${currentIndex + 1} / ${totalSlides}`;
    if (progressFill) progressFill.style.width = `${((currentIndex + 1) / totalSlides) * 100}%`;
    dots.forEach((d, i) => d.classList.toggle('is-active', i === currentIndex));
  }

  function goToSlide(idx: number) {
    if (idx < 0 || idx >= totalSlides) return;
    currentIndex = idx;
    isProgrammaticScroll = true;
    slides[idx].scrollIntoView({ behavior: 'smooth', block: 'start' });
    updateProgress();
    if (scrollEndTimer) window.clearTimeout(scrollEndTimer);
    scrollEndTimer = window.setTimeout(() => { isProgrammaticScroll = false; }, 950);
  }

  prevBtn?.addEventListener('click', () => goToSlide(currentIndex - 1));
  nextBtn?.addEventListener('click', () => goToSlide(currentIndex + 1));
  dots.forEach((d, i) => d.addEventListener('click', () => goToSlide(i)));

  document.addEventListener('keydown', (e) => {
    if (['ArrowRight', 'ArrowDown', 'PageDown', ' '].includes(e.key)) {
      e.preventDefault();
      goToSlide(currentIndex + 1);
    } else if (['ArrowLeft', 'ArrowUp', 'PageUp'].includes(e.key)) {
      e.preventDefault();
      goToSlide(currentIndex - 1);
    } else if (e.key === 'Home') {
      e.preventDefault();
      goToSlide(0);
    } else if (e.key === 'End') {
      e.preventDefault();
      goToSlide(totalSlides - 1);
    }
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const slide = entry.target as HTMLElement;
      const inner = slide.querySelector<HTMLElement>('.pitch-slide');
      if (entry.isIntersecting && entry.intersectionRatio > 0.55) {
        inner?.classList.add('is-visible');
        if (!isProgrammaticScroll) {
          const idx = parseInt(slide.dataset.slideIndex || '0');
          if (idx !== currentIndex) {
            currentIndex = idx;
            updateProgress();
          }
        }
      } else if (entry.intersectionRatio < 0.15) {
        inner?.classList.remove('is-visible');
      }
    });
  }, { threshold: [0, 0.15, 0.55, 1] });

  slides.forEach(s => observer.observe(s));

  updateProgress();
  requestAnimationFrame(() => {
    slides[0]?.querySelector('.pitch-slide')?.classList.add('is-visible');
  });
</script>
