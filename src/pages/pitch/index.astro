---
import KaizenLayout from '../../layouts/KaizenLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const variantsDir = path.join(process.cwd(), 'src/pages/pitch/_variants');
const files = fs.readdirSync(variantsDir).filter(f => f.endsWith('.json'));

const variants = files.map(f => {
  const data = JSON.parse(fs.readFileSync(path.join(variantsDir, f), 'utf-8'));
  return {
    slug: path.basename(f, '.json'),
    title: data.title,
    description: data.description,
    branche: data.character.branche_label,
    storyName: data.character.story_name,
    slideCount: data.slides.length,
  };
});
---

<KaizenLayout
  title="Pitch-Deck · Varianten"
  description="Internes Tool: Pitch-Deck-Varianten für KI-PA-Erstgespräche"
  path="/pitch"
  noindex={true}
  activeNav="home"
>
  <article class="kz-page" style="max-width: 1100px; padding: 80px 24px;">
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" />
      <span>Pitch-Deck · Operator-Tool</span>
    </div>

    <h1 class="kz-h1">Wähle deine Variante.</h1>
    <p class="kz-lead">
      Diese Pitch-Decks sind nicht in Suchmaschinen indexiert. Du kannst die Links direkt an Leads schicken — die Story erzählt sich selbst.
    </p>

    <div class="pitch-index-grid">
      {variants.map(v => (
        <a href={`/pitch/${v.slug}`} class="pitch-index-card">
          <div class="pitch-index-branche">{v.branche}</div>
          <h2 class="pitch-index-title">{v.title}</h2>
          <p class="pitch-index-desc">{v.description}</p>
          <div class="pitch-index-meta">
            <span class="pitch-index-character">{v.storyName}</span>
            <span class="pitch-index-slides">{v.slideCount} Slides</span>
          </div>
          <span class="pitch-index-link">
            /pitch/{v.slug}
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 10h12m0 0l-5-5m5 5l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      ))}
    </div>
  </article>
</KaizenLayout>

<style>
  .pitch-index-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    margin-top: 56px;
  }

  .pitch-index-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.5s;
  }

  .pitch-index-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 85, 0, 0) 0%, rgba(255, 85, 0, 0.04) 100%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }

  .pitch-index-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 24px 48px -16px rgba(26, 26, 26, 0.16),
      0 0 0 1px rgba(255, 85, 0, 0.2);
    border-color: rgba(255, 85, 0, 0.3);
  }

  .pitch-index-card:hover::before {
    opacity: 1;
  }

  .pitch-index-branche {
    color: #FF5500;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .pitch-index-title {
    font-size: 1.4rem;
    margin: 0 0 12px 0;
    line-height: 1.2;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }

  .pitch-index-desc {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0 0 20px 0;
    flex-grow: 1;
  }

  .pitch-index-meta {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
    font-size: 13px;
    color: #777;
  }

  .pitch-index-character::before {
    content: '👤 ';
  }

  .pitch-index-slides::before {
    content: '📑 ';
  }

  .pitch-index-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #FF5500;
    font-weight: 600;
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
    transition: gap 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pitch-index-card:hover .pitch-index-link {
    gap: 10px;
  }

  @media (prefers-reduced-motion: reduce) {
    .pitch-index-card,
    .pitch-index-card::before,
    .pitch-index-link {
      transition: none !important;
    }
  }
</style>
