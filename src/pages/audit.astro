---
import KaizenLayout from '../layouts/KaizenLayout.astro';

const checkMail = `mailto:kontakt@k-aizen.de?subject=${encodeURIComponent("Kostenloser KI-Check")}&body=${encodeURIComponent(`Hi Ben,

ich möchte den kostenlosen KI-Check machen.

Mein Unternehmen:
- Name:
- Branche:
- Teamgröße:

Worum es grob geht:
- 

Welche Systeme nutzen wir?
- z. B. Microsoft 365, Teams, Slack, Notion, CRM, Excel

Viele Grüße`)}`;

const whatsappLink = `https://wa.me/4915901031928?text=${encodeURIComponent('Hi Ben, ich interessiere mich für den kostenlosen KI-Check. Können wir remote kurz sprechen?')}`;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "k-AIzen KI-Check",
  "description": "Kostenloser Remote-KI-Check für KMU. Per Zoom, Google Meet oder ähnlichem Videotool klären wir Engpässe, Systeme, Datenquellen und den sinnvollsten nächsten Schritt.",
  "provider": { "@type": "Organization", "name": "k-AIzen", "url": "https://k-aizen.de" },
  "areaServed": ["DE", "AT", "CH"],
  "serviceType": "KI-Potenzialcheck und Erstberatung",
  "url": "https://k-aizen.de/audit",
  "offers": {
    "@type": "Offer",
    "name": "Kostenloser Remote-KI-Check",
    "price": "0",
    "priceCurrency": "EUR"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Kostet der KI-Check etwas?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Der KI-Check ist kostenlos." } },
    { "@type": "Question", "name": "Findet der KI-Check vor Ort statt?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Der KI-Check findet aktuell remote per Zoom, Google Meet oder einem ähnlichen Videotool statt." } },
    { "@type": "Question", "name": "Was kommt nach dem KI-Check?", "acceptedAnswer": { "@type": "Answer", "text": "Danach ist klarer, ob KI-PA, ein kleiner Pilot, ein konkretes Setup oder vorerst kein Projekt sinnvoll ist." } },
    { "@type": "Question", "name": "Muss ich danach etwas buchen?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Der KI-Check dient der Orientierung und erzeugt keine Kaufpflicht." } }
  ]
};
---

<KaizenLayout
  title="KI-Check — kostenlos und remote"
  description="Kostenloser KI-Check für KMU. Wir klären per Zoom, Google Meet oder ähnlichem Gespräch, ob KI-PA, Pilot oder vorerst kein Projekt sinnvoll ist."
  path="/audit"
  activeNav="pricing"
  breadcrumbs={[{ name: 'Preise', href: '/pricing' }, { name: 'KI-Check', href: '/audit' }]}
  jsonLd={[serviceSchema, faqSchema]}
>
  <article class="kz-page">
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" loading="lazy" />
      <img src="/icons/icon-sakura-branch.png" alt="" class="kz-eyebrow-leaf" loading="lazy" />
      <span>Kostenloser KI-Check</span>
    </div>

    <h1 class="kz-h1">KI-Check ohne Preisschild.</h1>
    <p class="kz-lead">
      Wir schauen gemeinsam auf Ihren Alltag und klären, wo KI wirklich helfen kann.
      Der Check kostet nichts und findet remote statt: per Zoom, Google Meet oder einem ähnlichen Gespräch.
    </p>

    <section style="margin-top: 56px; padding: 32px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
      <h2 class="kz-h2" style="margin-top: 0; color: var(--fg-inverse);">Was im KI-Check passiert</h2>
      <ul>
        <li><strong>Engpass verstehen</strong> — wo gerade Zeit, Überblick oder Nachhalten verloren geht.</li>
        <li><strong>Systeme sortieren</strong> — Mail, Kalender, Aufgaben, CRM, Notion, Microsoft 365, Slack oder andere Quellen.</li>
        <li><strong>Grenzen benennen</strong> — was die KI sehen dürfte, was tabu bleibt und wo ein Mensch freigeben muss.</li>
        <li><strong>Nächsten Schritt klären</strong> — KI-PA, kleiner Pilot, konkretes Angebot oder bewusst kein Projekt.</li>
      </ul>
    </section>

    <section style="margin-top: 56px;">
      <h2 class="kz-h2">Kein Inhouse-Paket</h2>
      <p>
        Den KI-Check biete ich aktuell nicht als Vor-Ort- oder Inhouse-Termin an.
        Wir machen das bewusst online: mit Gespräch, Bildschirmteilung und den Unterlagen,
        die Sie freigeben möchten.
      </p>
      <p>
        Falls danach ein konkretes Setup sinnvoll ist, sprechen wir über Umfang, Kosten und Vorgehen separat.
        Der Check selbst bleibt kostenlos.
      </p>
    </section>

    <section style="margin-top: 56px;">
      <h2 class="kz-h2">Was Sie danach wissen</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; margin-top: 24px;">
        <article style="padding: 22px; border-radius: 12px; background: var(--kz-cream-deep); color: var(--fg-inverse);">
          <h3 style="margin: 0 0 8px; font-size: 18px;">Ob es passt</h3>
          <p style="margin: 0; color: var(--fg-inverse); font-size: 15px; line-height: 1.6;">Wenn KI gerade nicht der richtige Hebel ist, sage ich das klar.</p>
        </article>
        <article style="padding: 22px; border-radius: 12px; background: var(--kz-cream-deep); color: var(--fg-inverse);">
          <h3 style="margin: 0 0 8px; font-size: 18px;">Wo man starten könnte</h3>
          <p style="margin: 0; color: var(--fg-inverse); font-size: 15px; line-height: 1.6;">Meistens ist ein kleiner Bereich besser als ein großes Alles-auf-einmal-Projekt.</p>
        </article>
        <article style="padding: 22px; border-radius: 12px; background: var(--kz-cream-deep); color: var(--fg-inverse);">
          <h3 style="margin: 0 0 8px; font-size: 18px;">Welche Quellen nötig wären</h3>
          <p style="margin: 0; color: var(--fg-inverse); font-size: 15px; line-height: 1.6;">Wir sprechen darüber, welche Daten und Freigaben ein sinnvoller Einstieg brauchen würde.</p>
        </article>
      </div>
    </section>

    <section style="margin-top: 64px;">
      <h2 class="kz-h2">FAQ</h2>

      <details style="border-top: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Kostet der KI-Check etwas?</summary>
        <p style="margin-top: 16px;">Nein. Der KI-Check ist kostenlos.</p>
      </details>

      <details style="border-top: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Kommt k-AIzen dafür zu uns?</summary>
        <p style="margin-top: 16px;">Nein. Aktuell biete ich dafür kein Inhouse- oder Vor-Ort-Paket an. Der KI-Check läuft remote.</p>
      </details>

      <details style="border-top: 1px solid var(--kz-border); border-bottom: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Müssen wir danach etwas kaufen?</summary>
        <p style="margin-top: 16px;">Nein. Wenn ein Pilot oder Setup sinnvoll ist, bekommen Sie danach ein separates Angebot. Wenn nicht, bleibt es bei der Einschätzung.</p>
      </details>
    </section>

    <section style="margin-top: 80px; padding: 56px clamp(24px, 4vw, 48px); background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
      <h2 class="kz-h2" style="margin-top: 0;">KI-Check starten</h2>
      <p style="margin-bottom: 28px;">Schicken Sie drei Stichpunkte oder buchen Sie direkt einen Termin. Beides reicht für den Einstieg.</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="/termin" class="kz-btn">Termin wählen</a>
        <a href={checkMail} class="kz-btn kz-btn-ghost">3 Stichpunkte schicken</a>
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="kz-btn kz-btn-ghost">WhatsApp an Ben</a>
      </div>
    </section>
  </article>
</KaizenLayout>
