// Bezahl-Modelle (Modell A vs B)
const paymentModels = [
  { id: 'pa',         name: 'PA',         setupA: '10.299 €', retainerA: '1.029 €/Mo', retainerBYear1: '1.899 €/Mo', retainerBYear2: '1.029 €/Mo' },
  { id: 'social',     name: 'Social',     setupA: '8.999 €',  retainerA: '999 €/Mo',   retainerBYear1: '1.749 €/Mo', retainerBYear2: '999 €/Mo' },
  { id: 'finanzer',   name: 'Finanzer',   setupA: '10.999 €', retainerA: '1.199 €/Mo', retainerBYear1: '2.099 €/Mo', retainerBYear2: '1.199 €/Mo' },
  { id: 'personaler', name: 'Personaler', setupA: '19.999 €', retainerA: '2.199 €/Mo', retainerBYear1: '3.899 €/Mo', retainerBYear2: '2.199 €/Mo' },
  { id: 'ultimate',   name: 'Ultimate',   setupA: '57.999 €', retainerA: '6.999 €/Mo', retainerBYear1: '11.999 €/Mo', retainerBYear2: '6.999 €/Mo' },
