const auditTiers = [
  { name: 'Remote Kompakt', desc: '2h Call + 1-seitige Empfehlung.', price: '1.190 €' },
  { name: 'Remote Standard', desc: '4h Call + 4-seitiger Audit-Report + Modul-Empfehlung + ROI-Schätzung.', price: '1.490 €', featured: true },
  { name: 'Vor Ort', desc: 'Tag vor Ort. Alle Beteiligten interviewen. Vollständiger Audit-Report.', price: '1.990 €' },
];

const combos = [
  { name: 'PA + Finanzer', cells: ['Solo/Klein-KMU', '20.999 €', '2.199 €/Mo', 'Summe Bundles'] },
  { name: 'PA + Social', cells: ['Content-Marketing-First', '18.999 €', '1.999 €/Mo', 'Summe Bundles'] },
  { name: 'Drei Mitarbeiter', cells: ['Mittelgroße KMU', '29.999 €', '3.199 €/Mo', 'Summe Bundles'] },
  { name: 'Alle vier', cells: ['Full-Setup, ganze Mannschaft', '44.999 €', '4.999 €/Mo', '−10 % Extra-Bündel'] },
  { name: 'Ultimate · Die ganze KI-Mannschaft', cells: ['Wer alles will — inkl. Voice', '57.999 €', '6.999 €/Mo', '−15 % Ultimate-Rabatt'], featured: true },
