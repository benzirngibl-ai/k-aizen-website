// Voice-Add-On (Cross-Cut)
const voiceLayer = {
  foundation: { name: 'Voice-Foundation', setup: '4.990 €', retainer: '299 €/Mo', desc: 'Phone-Number + STT/TTS + Conversation-Engine. Allein nicht nutzbar — braucht mindestens einen Use-Case-Pack.' },
  packs: [
    { code: 'M-V1', name: 'Voice-Pack PA', setup: '1.490 €', retainer: '149 €/Mo', desc: 'Anrufe entgegen nehmen, Termine vereinbaren, FAQ beantworten, Pre-Call-Briefing in Discord.' },
    { code: 'M-V2', name: 'Voice-Pack Personaler', setup: '1.490 €', retainer: '149 €/Mo', desc: 'Personal anrufen für Schicht-Aushelfe, Krankmeldungen per Telefon annehmen, Bewerber-Vor-Screening.' },
    { code: 'M-V3', name: 'Voice-Pack Finanzer', setup: '1.490 €', retainer: '149 €/Mo', desc: 'Höfliche Mahn-Anrufe Tier 2 nach E-Mail-Mahnung, Steuerberater-Call-Briefing.' },
  ],
