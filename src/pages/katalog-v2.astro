      { code: 'M-C2', name: 'Schicht-Genie', desc: 'Schichtplanung, Konflikt-Detection, Tausch-Vorschläge, Multi-Standort.', cls: 'L', price: '8.990 €', status: 'plan' },
      { code: 'M-B6', name: 'Bewerber-Triage', desc: 'Eingehende Bewerbungen vorqualifizieren mit Score + Zusammenfassung.', cls: 'M', price: '1.890 €', status: 'plan' },
      { code: 'M-A1', name: 'Audio→Protokoll', desc: 'Interne Meetings und 1-on-1-Gespräche als Transkript.', cls: 'S', price: '2.490 €', status: 'build' },
