  <!-- Script: progress dots + smooth scroll -->
  <script is:inline>
    (function() {
      const dots = document.querySelectorAll('.kz-progress-dot');
      const sections = Array.from(dots).map((d) => document.getElementById(d.dataset.target)).filter(Boolean);
      const scrollHint = document.getElementById('kz-scroll-hint');

      // Click dot → scroll to section
      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const target = document.getElementById(dot.dataset.target);
          if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
      });

      // Update active dot on scroll
      let ticking = false;
      function updateActive() {
        const mid = window.scrollY + window.innerHeight / 2;
        let activeIdx = 0;
        sections.forEach((s, i) => {
          if (s.offsetTop <= mid) activeIdx = i;
        });
        dots.forEach((d, i) => d.setAttribute('aria-current', i === activeIdx ? 'true' : 'false'));

        // Hide hint after scroll-start
        if (window.scrollY > 100) {
          scrollHint?.classList.add('kz-scroll-hint--hidden');
        } else {
          scrollHint?.classList.remove('kz-scroll-hint--hidden');
        }
        ticking = false;
      }
      document.body.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(updateActive);
          ticking = true;
        }
      });
      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(updateActive);
          ticking = true;
        }
      });

      // Keyboard nav: ArrowDown / Space = next section
      window.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown' || e.key === 'PageDown') {
          e.preventDefault();
          const mid = (document.scrollingElement || document.documentElement).scrollTop + window.innerHeight / 2;
          let next = sections.find((s) => s.offsetTop > mid + 10);
          if (next) next.scrollIntoView({ behavior: 'smooth' });
        } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
          e.preventDefault();
          const top = (document.scrollingElement || document.documentElement).scrollTop;
          let prev = [...sections].reverse().find((s) => s.offsetTop < top - 10);
          if (prev) prev.scrollIntoView({ behavior: 'smooth' });
        }
      });

      // ── Scroll-Reveal: pattern from homepage useReveal() ─────────────
      // Auto-mark content elements as reveal-targets, then observe.
      // Selectors chosen so most editorial content fades up on intersect.
      const revealSelectors = [
        '.kz-eyebrow',
        '.kz-display',
        '.kz-lead',
        '.kz-body',
        '.kz-overview-card',
        '.kz-usecase-item',
        '.kz-module',
        '.kz-pricing-bundle',
        '.kz-pricing-retainer-item',
        '.kz-pricing-note',
        '.kz-combo-cell--name',
        '.kz-voice-foundation',
        '.kz-voice-pack',
        '.kz-voice-footnote',
        '.kz-ultimate-card',
        '.kz-payment-card',
        '.kz-payment-table-head',
        '.kz-payment-table-row',
        '.kz-payment-footnote',
        '.kz-audit-tier',
        '.kz-emp-name',
        '.kz-emp-hook',
        '.kz-emp-status-pill',
        '.kz-emp-meta-left',
        '.kz-manifest-quote',
        '.kz-manifest-attr',
        '.kz-cover-meta-block',
        '.kz-btn',
      ];
      const revealEls = document.querySelectorAll(revealSelectors.join(','));
      revealEls.forEach((el) => {
        el.setAttribute('data-reveal', '');
      });

      // Word-by-word reveal for major display headlines on Cover, Manifest, CTA
      // Wraps text-nodes only (preserves inline <span>/<br> structure).
      function wrapWordsForReveal(headline) {
        const walker = document.createTreeWalker(headline, NodeFilter.SHOW_TEXT, null);
        const textNodes = [];
        let n;
        while ((n = walker.nextNode())) textNodes.push(n);
        let wordIndex = 0;
        textNodes.forEach((textNode) => {
          const words = textNode.textContent.split(/(\s+)/);
          const frag = document.createDocumentFragment();
          words.forEach((w) => {
            if (/^\s+$/.test(w) || w === '') {
              frag.appendChild(document.createTextNode(w));
              return;
            }
            const mask = document.createElement('span');
            mask.className = 'kz-word-mask';
            mask.style.transitionDelay = `${wordIndex * 60}ms`;
            const inner = document.createElement('span');
            inner.className = 'kz-word-inner';
            inner.style.transitionDelay = `${wordIndex * 60}ms`;
            inner.textContent = w;
            // Copy parent emphasis (italic + ember) onto inner so word-roll preserves styling
            if (textNode.parentElement && textNode.parentElement.classList.contains('kz-italic')) {
              inner.style.fontStyle = 'italic';
              inner.style.color = 'var(--kz-ember)';
            }
            if (textNode.parentElement && textNode.parentElement.classList.contains('kz-italic-soft')) {
              inner.style.fontStyle = 'italic';
              inner.style.color = 'var(--kz-charcoal-soft)';
            }
            mask.appendChild(inner);
            frag.appendChild(mask);
            wordIndex++;
          });
          textNode.parentNode.replaceChild(frag, textNode);
        });
      }

      // Apply word-reveal to hero-level headlines (kz-display--xxl, --xl)
      // Skip smaller --l/--m to keep performance + avoid over-staging
      document.querySelectorAll('.kz-display--xxl, .kz-display--xl, .kz-emp-name, .kz-manifest-quote').forEach((h) => {
        try { wrapWordsForReveal(h); } catch (e) {}
      });

      // IntersectionObserver — toggles is-visible class on intersect
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          } else {
            // Re-trigger on re-entry: remove is-visible when scrolled out of view
            entry.target.classList.remove('is-visible');
          }
        });
      }, {
        threshold: 0.18,
        rootMargin: '0px 0px -10% 0px',
      });

      // Observe reveal targets + word-masks
      document.querySelectorAll('[data-reveal]').forEach((el) => revealObserver.observe(el));
      document.querySelectorAll('.kz-word-mask').forEach((el) => revealObserver.observe(el));
    })();
  </script>
</body>
</html>
