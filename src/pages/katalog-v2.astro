---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>k-AIzen — Produkt-Katalog 2026</title>
  <meta name="description" content="Vier KI-Mitarbeiter für dein KMU. KI-PA, Social, Finanzer, Personaler. Persönlich betreut, in Deutschland gehostet." />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#F5F0E8" />
  <link rel="icon" type="image/png" href="/animations/claude-design/logo-mark.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter+Tight:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Top Chrome -->
  <header class="kz-topbar">
    <a href="/" class="kz-brand">k-<span class="kz-brand-ai">AI</span>zen · Katalog</a>
    <div class="kz-topbar-meta">
      <span>MMXXVI</span>
      <a href="/" class="kz-close">Schließen</a>
    </div>
  </header>

  <!-- Section Progress Dots -->
  <nav class="kz-progress" aria-label="Sektionen">
    {sections.map((s, i) => (
      <button class="kz-progress-dot" data-target={s.id} aria-current={i === 0 ? 'true' : 'false'}>
        <span class="kz-progress-dot-label">{s.label}</span>
        <span class="kz-progress-dot-mark"></span>
      </button>
    ))}
  </nav>

  <!-- Scroll Hint -->
  <div class="kz-scroll-hint" id="kz-scroll-hint">
    <span class="kz-scroll-hint-line"></span>
    <span>Scroll</span>
    <span class="kz-scroll-hint-line"></span>
  </div>

  <!-- ── SECTION 1: COVER ────────────────────────────────────────────── -->
  <section class="kz-section kz-cover" id="cover">
    <span class="kz-cover-kanji">改</span>
    <div class="kz-cover-content" style="margin-top: auto;">
      <div class="kz-eyebrow" style="margin-bottom: 32px;">Produkt-Katalog · MMXXVI · für KMU</div>
      <h1 class="kz-display kz-display--xxl">
        Vier&nbsp;<span class="kz-italic">KI-Mitarbeiter.</span>
      </h1>
      <p class="kz-lead" style="margin-top: clamp(20px, 3vh, 32px); max-width: 48ch;">
        Persönlich betreut. In Deutschland gehostet. Ohne Lock-in.
      </p>
    </div>
    <div class="kz-cover-meta">
      <div class="kz-cover-meta-block">
        <span class="kz-mono">Benjamin Zirngibl · k-aizen.de</span>
        <span class="kz-mono">Bayern, Deutschland</span>
      </div>
      <div class="kz-cover-meta-block" style="text-align: right; align-items: flex-end;">
        <span class="kz-mono">Vol. III · Mai 2026</span>
        <span class="kz-mono">{sections.length.toString().padStart(2, '0')} Sektionen</span>
      </div>
    </div>
  </section>

  <!-- ── SECTION 2: MANIFEST ─────────────────────────────────────────── -->
  <section class="kz-section kz-manifest" id="manifest">
    <div class="kz-manifest-grid">
      <div class="kz-manifest-portrait">
        <img src="/images/ben-portrait.png" alt="Benjamin Zirngibl" />
        <div class="kz-manifest-portrait-caption">
          <span class="kz-mono" style="color: rgba(245,240,232,0.5);">Benjamin Zirngibl</span>
          <span class="kz-mono" style="color: rgba(245,240,232,0.5);">Gründer · k-AIzen</span>
        </div>
      </div>
      <div class="kz-manifest-body">
        <div class="kz-eyebrow" style="margin-bottom: 32px;">Manifest · Eins</div>
        <h2 class="kz-manifest-quote">
          „Ich bin nicht<br />euer SaaS-Vendor.<br /><span class="kz-italic">Ich bin euer KI-Guy.</span>"
        </h2>
        <span class="kz-manifest-attr">Wie ein Versicherungsmakler — nur für KI</span>
        <p class="kz-lead" style="margin-top: clamp(24px, 4vh, 40px); max-width: 56ch; color: rgba(245,240,232,0.75);">
          Andere setzen ein System auf und verschwinden. Ich bleibe dein Ansprechpartner. Halte dein Setup auf dem neuesten Stand. Tausche Modelle, wenn ein besseres kommt. Bin am Telefon, wenn du Fragen hast.
        </p>
      </div>
    </div>
  </section>

  <!-- ── SECTION 3: OVERVIEW ─────────────────────────────────────────── -->
  <section class="kz-section kz-overview" id="overview">
    <div style="display: flex; flex-direction: column; gap: 18px;">
      <span class="kz-eyebrow">Sortiment</span>
      <h2 class="kz-display kz-display--l">Die&nbsp;<span class="kz-italic">vier&nbsp;Mitarbeiter</span>.</h2>
      <p class="kz-lead">Jeder als komplettes Paket. Einzeln buchbar. Auch in Kombination — Multi-Mitarbeiter-Rabatte siehe später.</p>
    </div>

    <div class="kz-overview-grid">
      {employees.map((e) => (
        <a href={`#${e.id}-hero`} class="kz-overview-card">
          <span class="kz-overview-card-num">№ {e.num}</span>
          <h3 class="kz-overview-card-name">{e.name.replace(e.nameEmphasis, '')}<em>{e.nameEmphasis}</em></h3>
          <p class="kz-overview-card-role">{e.role}</p>
          <p class="kz-overview-card-desc">{e.mission}</p>
          <div class="kz-overview-card-foot">
            <span class="kz-overview-card-price">{e.bundlePrice}</span>
            <span class="kz-overview-card-status">
              {e.statusLabel}{e.statusPct ? ` · ${e.statusPct}` : ''}
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── PER-EMPLOYEE SECTIONS ───────────────────────────────────────── -->
  {employees.map((e) => (
    <div data-emp={e.id}>
      <!-- HERO -->
      <section class={`kz-section kz-emp-hero`} id={`${e.id}-hero`}>
        <div class="kz-emp-meta">
          <div class="kz-emp-meta-left">
            <span class="kz-eyebrow">Mitarbeiter № {e.num} von 04</span>
            <span class="kz-mono">ICP · {e.icp}</span>
          </div>
          <span class="kz-emp-status-pill">
            <span class={`kz-emp-status-dot kz-emp-status-dot--${e.status}`}></span>
            {e.statusLabel}{e.statusPct ? ` · ${e.statusPct}` : ''}
          </span>
        </div>
        <div class="kz-emp-hero-body">
          <h2 class="kz-emp-name">
            {e.name.split(e.nameEmphasis)[0]}<em>{e.nameEmphasis}</em>{e.name.split(e.nameEmphasis)[1]}
          </h2>
          <p class="kz-emp-hook">„{e.hook}"</p>
