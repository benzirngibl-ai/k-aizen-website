// Editorial-Pacing nach Research-Findings (Fraunces + Inter Tight + JetBrains Mono).
// Unverlinkt, noindex. Direktlink für Sales-Calls / Zoom-Onboarding.

import '../components/katalog-v2/katalog-v2.css';

// ── Data ────────────────────────────────────────────────────────────────

