// Section-Index für progress-dots
const sections = [
  { id: 'cover',     label: 'Cover' },
  { id: 'manifest',  label: 'Manifest' },
  { id: 'overview',  label: 'Mitarbeiter' },
  ...employees.flatMap((e) => [
    { id: `${e.id}-hero`,     label: e.name },
    { id: `${e.id}-mission`,  label: `${e.name} · Mission` },
    { id: `${e.id}-cases`,    label: `${e.name} · Alltag` },
    { id: `${e.id}-modules`,  label: `${e.name} · Module` },
    { id: `${e.id}-pricing`,  label: `${e.name} · Preis` },
  ]),
  { id: 'combos',    label: 'Kombinationen' },
  { id: 'voice',     label: 'Voice-Layer' },
  { id: 'ultimate',  label: 'Ultimate' },
