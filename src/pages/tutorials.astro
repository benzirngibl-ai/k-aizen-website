---
import KaizenLayout from '../layouts/KaizenLayout.astro';
import { getCollection } from 'astro:content';

const tutorials = (await getCollection('tutorials'))
  .filter((t) => !t.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<KaizenLayout
  title="Ressourcen — KI für KMU, Schritt für Schritt"
  description="Kurze, praktische Ressourcen für KMU: KI verstehen, erste Abläufe ordnen und konkrete Schritte testen."
  path="/tutorials"
  activeNav="tutorials"
>
  <article class="kz-page">
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" />
      <span>Ressourcen</span>
    </div>
    <h1 class="kz-h1">Ressourcen für den ersten KI-Schritt.</h1>
    <p class="kz-lead">
      Kurz, klar, ohne IT-Studium. Praktische Anleitungen für Unternehmen, die KI
      verstehen und die ersten Abläufe sauberer machen wollen.
    </p>

    {tutorials.length === 0 ? (
      <section class="kz-empty-block">
        <p class="kz-empty">Neue Tutorials laufen gerade durch die Pipeline. Bald hier.</p>
        <p>
          In der Zwischenzeit: <a href="/blog">Blog-Posts</a> oder direkt
          <a href="/erstgespraech">ein Erstgespräch</a> buchen.
        </p>
      </section>
    ) : (
      <section class="kz-tutorial-list">
        {tutorials.map((tut) => {
          const slug = tut.data.slug || tut.id;
          return (
            <div class="kz-tutorial-card">
              <div class="kz-tutorial-card-header">
                <div class="kz-tutorial-card-meta">
                  <time datetime={tut.data.pubDate.toISOString()}>
                    {tut.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                </div>
                <h2 class="kz-tutorial-card-title">{tut.data.title}</h2>
                <p class="kz-tutorial-card-desc">{tut.data.description}</p>
              </div>

              <div class="kz-tutorial-card-footer">
                <a href={`/tutorials/${slug}`} class="kz-tutorial-card-link">
                  Online lesen →
                </a>
              </div>
            </div>
          );
        })}
      </section>
    )}

    <section class="kz-tutorial-info">
      <h2 class="kz-h2">Was Sie hier bekommen</h2>
      <ul>
        <li><strong>Kurze Praxisnotizen</strong> mit Schritt-für-Schritt-Denken — kurz, klar, sofort lesbar</li>
        <li><strong>Konkrete Links</strong> zu relevanten Tools und Quellen, keine generischen Tipps</li>
        <li><strong>5.-Klässler-Test</strong> — jeder Begriff wird in einem Satz erklärt, kein IT-Jargon</li>
        <li><strong>Praxis statt Tool-Hype</strong> — Fokus auf Abläufe, Freigaben und sinnvolle erste Schritte</li>
        <li><strong>Kein künstliches Gating</strong> — lesen, prüfen, bei Bedarf ein Gespräch buchen</li>
      </ul>
    </section>
  </article>

  <style>
    .kz-empty-block {
      padding: 48px;
      background: var(--kz-cream-deep, #ede5d4);
      color: var(--fg-inverse);
      border-radius: 12px;
      margin-top: 32px;
    }
    .kz-empty { font-size: 17px; color: rgba(31,41,51,0.7); margin: 0 0 16px; }

    .kz-tutorial-list {
      display: grid;
      gap: 32px;
      margin: 32px 0 64px;
    }
    .kz-tutorial-card {
      padding: 32px;
      background: var(--kz-cream-deep, #ede5d4);
      color: var(--fg-inverse);
      border-radius: 12px;
      border: 1px solid var(--kz-border);
      display: grid;
      gap: 20px;
    }
    .kz-tutorial-card-meta {
      font-family: var(--font-sans);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--fg-muted);
      margin-bottom: 8px;
    }
    .kz-tutorial-card-title {
      font-family: var(--font-display);
      font-size: clamp(22px, 2.4vw, 28px);
      line-height: 1.2;
      margin: 0 0 8px;
    }
    .kz-tutorial-card-desc {
      font-family: var(--font-sans);
      font-size: 16px;
      line-height: 1.55;
      color: var(--fg-muted);
      margin: 0;
    }

    .kz-tutorial-card-footer {
      display: flex;
      justify-content: flex-end;
    }
    .kz-tutorial-card-link {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
    }
    .kz-tutorial-card-link:hover { text-decoration: underline; }

    .kz-tutorial-info {
      margin-top: 64px;
      padding: 32px;
      background: var(--kz-cream-deep, #ede5d4);
      color: var(--fg-inverse);
      border-radius: 12px;
    }
    .kz-tutorial-info ul { margin-top: 20px; }
  </style>
</KaizenLayout>
