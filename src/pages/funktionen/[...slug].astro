---
import { getCollection, render } from 'astro:content';
import KaizenLayout from '../../layouts/KaizenLayout.astro';

export async function getStaticPaths() {
  const funktionen = await getCollection('funktionen', ({ data }) => !data.draft);
  return funktionen.map((f) => ({ params: { slug: f.id }, props: { funktion: f } }));
}

const { funktion } = Astro.props;
const { Content } = await render(funktion);
const d = funktion.data;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${d.title} — Lena-Funktion · k-AIzen`,
  description: d.description,
  isPartOf: { '@id': 'https://k-aizen.de/#website' },
  about: { '@id': 'https://k-aizen.de/ki-pa#service' },
};
---

<KaizenLayout
  title={`${d.title} — was Lena übernimmt`}
  description={d.description}
  path={`/funktionen/${funktion.id}`}
  jsonLd={jsonLd}
  breadcrumbs={[
    { name: 'Funktionen', href: '/funktionen' },
    { name: d.title, href: `/funktionen/${funktion.id}` },
  ]}
>
  <article class="kz-page">
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" />
      <span>Lena-Funktion</span>
    </div>
    <h1 class="kz-h1">{d.title}</h1>
    <p class="kz-lead kz-fn-kicker">{d.schmerzKicker}</p>

    <div class="kz-fn-hero">
      <img src={d.heroImage} alt={d.heroAlt} loading="eager" />
    </div>

    {d.beats.length > 0 && (
      <section class="kz-fn-beats">
        {d.beats.map((b) => (
          <div class="kz-fn-beat">
            <span class="kz-fn-beat-label">{b.label}</span>
            <p>{b.text}</p>
          </div>
        ))}
      </section>
    )}

    <section class="kz-fn-contrast">
      <div class="kz-fn-col kz-fn-col--ohne">
        <h2>Ohne Lena</h2>
        {d.ohneFrage && <p class="kz-fn-frage kz-fn-frage--leere">„{d.ohneFrage}“</p>}
        {d.phoneMock && (
          <div class="kz-fn-phone">
            <div class="kz-fn-phone-head">{d.phoneMock.title}</div>
            {d.phoneMock.lines.map((line) => <div class="kz-fn-phone-line">{line}</div>)}
          </div>
        )}
        {d.ohneText && <p>{d.ohneText}</p>}
      </div>
      <div class="kz-fn-col kz-fn-col--mit">
        <h2>Mit Lena</h2>
        {d.mitChat ? (
          <div class="kz-fn-chat">
            <div class="kz-fn-chat-frage">{d.mitChat.frage}</div>
            <div class="kz-fn-chat-antwort">
              <span class="kz-fn-chat-name">Lena</span>
              <div set:html={d.mitChat.antwort.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>')} />
            </div>
          </div>
        ) : d.discord && (
          <div class="kz-fn-discord">
            <div class={`kz-fn-discord-head${d.discord.alert ? ' alert' : ''}`}>
              <span class="ch">{d.discord.channel}</span><span> · {d.discord.time}</span>
            </div>
            <div class="kz-fn-discord-body" set:html={d.discord.body.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>')} />
          </div>
        )}
        {d.mitText && <p>{d.mitText}</p>}
      </div>
    </section>

    <div class="kz-fn-prose">
      <Content />
    </div>

    {(d.sources.length > 0 || d.flow.length > 0) && (
      <section class="kz-fn-mechanik">
        <h2>So funktioniert's</h2>
        {d.sources.length > 0 && (
          <div class="kz-fn-row">
            <span class="kz-fn-label">Quellen</span>
            <div class="kz-fn-chips">{d.sources.map((s) => <span>{s}</span>)}</div>
          </div>
        )}
        {d.flow.length > 0 && (
          <div class="kz-fn-flow">
            {d.flow.map((step, i) => (
              <div class="kz-fn-step"><span class="kz-fn-num">{i + 1}</span><span>{step}</span></div>
            ))}
          </div>
        )}
      </section>
    )}

    <section class="kz-fn-cta">
      <h2>Klingt nach Ihrem Betrieb?</h2>
      <p>30 Minuten, kostenlos, unverbindlich: Wir schauen gemeinsam, ob und wo das bei Ihnen trägt. Wenn nicht, ist auch das eine klare Antwort.</p>
      <div class="kz-fn-cta-row">
        <a href="/erstgespraech" class="kz-btn">Erstgespräch vereinbaren</a>
        <a href="/funktionen" class="kz-btn kz-btn-ghost">← Alle Funktionen</a>
      </div>
    </section>
  </article>

  <style>
    .kz-fn-kicker { font-style: italic; }
    .kz-fn-hero { margin: 40px 0 48px; border-radius: 12px; overflow: hidden; }
    .kz-fn-hero img { width: 100%; height: auto; display: block; }

    /* Story-Beats: große Zeitstempel, wenig Text — der Pain als Sequenz */
    .kz-fn-beats { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin: 0 0 56px; }
    .kz-fn-beat { padding: 24px; background: var(--kz-cream-deep, #ede5d4); color: var(--fg-inverse); border-radius: 12px; border: 1px solid rgba(232,90,43,0.14); }
    .kz-fn-beat-label { display: block; font-family: var(--font-display); font-size: clamp(24px, 3vw, 32px); font-weight: 700; color: var(--accent, #e85a2b); margin-bottom: 10px; }
    .kz-fn-beat p { margin: 0; font-size: 15px; line-height: 1.55; }

    /* Der Kontrast: Handy-Leere vs. Discord-Übergabe */
    .kz-fn-contrast { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin: 0 0 56px; }
    .kz-fn-col { padding: 28px; border-radius: 12px; }
    .kz-fn-col h2 { font-family: var(--font-display); font-size: clamp(20px, 2.2vw, 26px); margin: 0 0 18px; }
    .kz-fn-col p { margin: 18px 0 0; font-size: 15px; line-height: 1.6; }
    .kz-fn-col--ohne { background: rgba(31,41,51,0.04); border: 1px dashed rgba(31,41,51,0.25); }
    .kz-fn-col--ohne h2 { color: var(--fg-muted); }
    .kz-fn-col--mit { background: var(--kz-cream-deep, #ede5d4); color: var(--fg-inverse); border: 1px solid rgba(232,90,43,0.2); }
    .kz-fn-col--mit h2 { color: var(--accent, #e85a2b); }

    /* Dieselbe Frage, zweimal gestellt */
    .kz-fn-frage { font-family: var(--font-display); font-style: italic; font-size: 17px; margin: 0 0 14px; }
    .kz-fn-frage--leere { color: var(--fg-muted); }
    .kz-fn-chat { display: grid; gap: 10px; max-width: 420px; }
    .kz-fn-chat-frage { justify-self: end; background: var(--accent, #e85a2b); color: #fff; padding: 10px 16px; border-radius: 16px 16px 4px 16px; font-size: 15px; max-width: 85%; }
    .kz-fn-chat-antwort { justify-self: start; background: rgba(255,255,255,0.75); border: 1px solid rgba(232,90,43,0.18); padding: 12px 16px; border-radius: 16px 16px 16px 4px; font-size: 14px; line-height: 1.55; max-width: 92%; box-shadow: 0 4px 14px rgba(31,41,51,0.06); }
    .kz-fn-chat-name { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent, #e85a2b); font-weight: 700; margin-bottom: 6px; }

    /* Handy-Mock: die Leere IST der Pain */
    .kz-fn-phone { border-radius: 14px; background: #101418; color: #e8eaed; max-width: 340px; overflow: hidden; box-shadow: 0 8px 24px rgba(0,0,0,0.18); }
    .kz-fn-phone-head { padding: 10px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; color: #9aa0a6; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .kz-fn-phone-line { padding: 12px 16px; font-size: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .kz-fn-phone-line:first-of-type { color: #ff6b5e; font-weight: 600; }

    .kz-fn-discord { border-radius: 10px; background: #2b2d31; color: #dbdee1; font-size: 14px; overflow: hidden; max-width: 420px; box-shadow: 0 8px 24px rgba(0,0,0,0.15); }
    .kz-fn-discord-head { padding: 10px 16px; background: #1e1f22; font-size: 12px; color: #949ba4; }
    .kz-fn-discord-head.alert { color: #f0b132; }
    .kz-fn-discord-head .ch { font-weight: 600; }
    .kz-fn-discord-body { padding: 14px 16px; line-height: 1.55; }

    .kz-fn-prose { font-family: var(--font-sans); font-size: 18px; line-height: 1.7; max-width: 720px; }
    .kz-fn-prose :global(h2) { font-family: var(--font-display); font-size: clamp(26px, 3vw, 34px); margin: 56px 0 16px; line-height: 1.2; }
    .kz-fn-prose :global(p) { margin: 0 0 20px; }

    .kz-fn-mechanik { margin-top: 16px; padding: 28px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px; }
    .kz-fn-mechanik h2 { font-family: var(--font-display); font-size: clamp(20px, 2.2vw, 26px); margin: 0 0 18px; }
    .kz-fn-row { display: flex; align-items: baseline; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
    .kz-fn-label { font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(31,41,51,0.6); }
    .kz-fn-chips { display: flex; gap: 8px; flex-wrap: wrap; }
    .kz-fn-chips span { padding: 4px 12px; border-radius: 999px; background: rgba(255,255,255,0.6); border: 1px solid rgba(232,90,43,0.18); font-size: 13px; }
    .kz-fn-flow { display: grid; gap: 10px; margin: 16px 0 0; }
    .kz-fn-step { display: flex; gap: 12px; align-items: baseline; font-size: 15px; }
    .kz-fn-num { width: 22px; height: 22px; border-radius: 50%; background: var(--accent, #e85a2b); color: #fff; font-size: 12px; display: inline-flex; align-items: center; justify-content: center; flex: none; }

    .kz-fn-cta { margin-top: 56px; padding: 48px clamp(24px, 4vw, 40px); background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px; }
    .kz-fn-cta h2 { font-family: var(--font-display); margin: 0 0 12px; }
    .kz-fn-cta p { max-width: 560px; margin: 0 0 24px; }
    .kz-fn-cta-row { display: flex; gap: 12px; flex-wrap: wrap; }
  </style>
</KaizenLayout>
