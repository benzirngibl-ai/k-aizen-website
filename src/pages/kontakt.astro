---
import KaizenLayout from '../layouts/KaizenLayout.astro';

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Kontakt — k-AIzen",
  "url": "https://k-aizen.de/kontakt",
  "mainEntity": {
    "@type": "Organization",
    "name": "k-AIzen",
    "email": "kontakt@k-aizen.de",
    "url": "https://k-aizen.de",
    "areaServed": "DE",
    "founder": { "@type": "Person", "name": "Benjamin Zirngibl" }
  }
};

const asyncMail = `mailto:kontakt@k-aizen.de?subject=${encodeURIComponent("KI-PA Kurzcheck")}&body=${encodeURIComponent(`Hi Ben,

ich möchte kurz prüfen, ob k-AIzen für uns passt.

1. Branche / Teamgröße:
2. Wo verlieren wir gerade Zeit?
3. Welche Systeme nutzen wir?

Beste Grüße`)}`;
---

<KaizenLayout
  title="Kontakt — Erstgespräch oder direkte Nachricht"
  description="Kontakt zu k-AIzen: kostenloses Erstgespräch buchen oder direkt an Benjamin Zirngibl schreiben. Für KI-PA, KI-Check und Automatisierung im Unternehmen."
  path="/kontakt"
  activeNav="kontakt"
  jsonLd={contactSchema}
>
  <style is:global>
    .kz-contact-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
      margin: 42px 0 72px;
    }
    .kz-contact-card {
      padding: 28px;
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: var(--card);
      box-shadow: var(--shadow-sm);
    }
    .kz-contact-card h3 {
      margin: 0 0 12px;
      font-size: 1.2rem;
    }
    @media (max-width: 820px) {
      .kz-contact-grid { grid-template-columns: 1fr; }
    }
  </style>

  <article class="kz-page kz-page--wide">
    <div class="kz-page-eyebrow"><span>Kontakt</span></div>
    <h1 class="kz-h1">Der einfachste Einstieg ist ein kurzes Gespräch.</h1>
    <p class="kz-lead">
      Sie müssen noch nicht wissen, welches System Sie brauchen. Es reicht, wenn Sie
      wissen, wo gerade Zeit, Überblick oder Energie verloren geht.
    </p>

    <section class="kz-contact-grid">
      <article class="kz-contact-card">
        <h3>Erstgespräch</h3>
        <p>30 Minuten, kostenlos, ohne Verkaufsdruck. Wir prüfen, ob KI-PA, KI-Check oder ein Pilot sinnvoll ist.</p>
        <p><a href="/erstgespraech" class="kz-btn">Termin buchen <span class="kz-btn__arrow">→</span></a></p>
      </article>
      <article class="kz-contact-card">
        <h3>Direkt schreiben</h3>
        <p>Kurze Mail reicht: Branche, Teamgröße, ein konkreter Schmerzpunkt und die wichtigsten Systeme. Ich antworte persönlich.</p>
        <p><a href={asyncMail} class="kz-btn kz-btn-ghost">3-Fragen-Mail öffnen</a></p>
      </article>
      <article class="kz-contact-card">
        <h3>Mitlesen</h3>
        <p>Auf LinkedIn schreibe ich über Aufbau, Tests und echte Lernkurven rund um k-AIzen.</p>
        <p><a href="https://www.linkedin.com/in/benjamin-zirngibl-0963753ab" rel="noopener noreferrer" target="_blank" class="kz-btn kz-btn-ghost">LinkedIn ansehen</a></p>
      </article>
    </section>

    <section>
      <h2 class="kz-h2">Was für die erste Nachricht hilft</h2>
      <ul>
        <li><strong>Branche und Teamgröße</strong> — damit ich den Kontext einordnen kann.</li>
        <li><strong>Der konkrete Engpass</strong> — Mailflut, Terminchaos, Dateiablage, Belege, Kundenkontext, interne Rückfragen.</li>
        <li><strong>Bestehende Systeme</strong> — Microsoft 365, Teams, Slack, Notion, CRM, SharePoint, Excel-Listen oder etwas Eigenes.</li>
        <li><strong>Was schon probiert wurde</strong> — falls es bereits Tool-Tests, Automationen oder KI-Versuche gab.</li>
      </ul>
    </section>

    <section style="margin-top: 96px; padding: 48px clamp(24px, 4vw, 48px); background: var(--kz-charcoal); color: var(--kz-cream); border-radius: 16px;">
      <h2 class="kz-h2" style="color: var(--kz-cream); margin-top: 0;">Postanschrift</h2>
      <p style="color: rgba(255,255,255,0.78);">
        Benjamin Zirngibl — k-AIzen<br/>
        Zum Schwarzachtal 5 · 90592 Schwarzenbruck · Deutschland
      </p>
      <p style="color: rgba(255,255,255,0.62); font-size: 14px;">
        Die vollständigen rechtlichen Angaben stehen im <a href="/impressum" style="color: var(--kz-cream); text-decoration: underline;">Impressum</a>.
      </p>
    </section>
  </article>
</KaizenLayout>
