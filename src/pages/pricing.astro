---
import KaizenLayout from '../layouts/KaizenLayout.astro';

const buyerPaths = [
  {
    k: "Sie sind unsicher",
    title: "Erstgespräch oder Async-Check",
    text: "Wenn noch nicht klar ist, wo KI helfen soll, reicht zunächst eine kostenfreie Einschätzung. Danach kann ein kostenloser KI-Check per Zoom oder Google Meet sinnvoll sein.",
    cta: "Erstgespräch",
    href: "/erstgespraech",
  },
  {
    k: "Es gibt mehrere Baustellen",
    title: "Kostenloser KI-Check",
    text: "Wenn Mail, Belege, Telefon, Wissen und Prozesse gleichzeitig ziehen, priorisieren wir zuerst remote. Das verhindert ein Setup am falschen Punkt.",
    cta: "KI-Check ansehen",
    href: "#audit",
  },
  {
    k: "Der erste Bereich ist klar",
    title: "KI-PA Pilot oder Setup",
    text: "Wenn Mail, Kalender, Aufgaben oder ein anderer Bereich offensichtlich ist, starten wir begrenzt und messen an echten Arbeitsartefakten.",
    cta: "KI-PA verstehen",
    href: "/ki-pa",
  },
];

const offerCatalogSchema = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "k-AIzen Preise",
  "description": "Öffentliche Orientierung für den Einstieg in k-AIzen: kostenloses Erstgespräch, kostenloser Remote-KI-Check, KI-PA-Vollsetup als Ausbaurahmen und Add-on-Module. Preise sichtbar, kein Lock-in.",
  "itemListElement": [
    {
      "@type": "Offer",
      "name": "KI-PA Autonom (Tier 1) — Setup-First",
      "description": "Ihr persönlicher KI-Assistent. Mail-Triage, Termine, Briefings, Belege, Audio→Protokoll. Arbeitskanal, getrennte Umgebung und Memory-System inklusive.",
      "price": "10299",
      "priceCurrency": "EUR",
      "areaServed": "DE"
    },
    {
      "@type": "Offer",
      "name": "KI-PA + Concierge (Tier 2) — Setup-First",
      "description": "Alles aus Tier 1, plus: menschlicher Backstop für Aufgaben, die KI nicht sauber lösen kann — Anrufe, Behörden, Reklamationen, Verhandlungen, Reise-Logistik. Mo-Fr 9-16 für menschliche Tasks.",
      "price": "12999",
      "priceCurrency": "EUR",
      "areaServed": "DE"
    },
    {
      "@type": "Offer",
      "name": "Voice-Empfangsdame (Add-on)",
      "description": "Eigene Firmen-Telefonnummer, KI nimmt Anrufe entgegen, beantwortet FAQs, vereinbart Termine. Premium-Modul.",
      "price": "9999",
      "priceCurrency": "EUR",
      "areaServed": "DE"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Was ist der Unterschied zwischen Tier 1 und Tier 2?", "acceptedAnswer": { "@type": "Answer", "text": "Tier 1 = KI-PA Autonom. Zuverlässig lösbare Aufgaben wie Mails, Termine, Briefings, Recherche, Belege und Audio-Protokolle werden durch den Assistenten vorbereitet oder ausgeführt. Grenzfälle werden markiert. Tier 2 = KI-PA + Concierge. Alles aus Tier 1, plus menschlicher Backstop für Grenzfälle wie Anrufe, Behörden, Reklamationen, Verhandlungen oder komplexe Reise-Logistik." } },
    { "@type": "Question", "name": "Modell A oder Modell B — was passt für mich?", "acceptedAnswer": { "@type": "Answer", "text": "Beide kosten über 24 Monate ungefähr gleich. Modell A (Setup-First): einmaliger Setup-Block, dann niedrigere Monatsraten. Modell B (SaaS-Style): kein Setup-Block, höhere Y1-Monatsrate, automatische Reduktion ab Y2. Welche Variante sinnvoll ist, klären wir nach Erstgespräch, KI-Check oder Pilot." } },
    { "@type": "Question", "name": "Kann ich Tier 1 später auf Tier 2 upgraden?", "acceptedAnswer": { "@type": "Answer", "text": "Ja, jederzeit. Ihr KI-PA bleibt und kennt den Kontext dann bereits. Aufpreis: Differenz zwischen Tier 1 und Tier 2 ab Upgrade-Datum. Kein komplett neuer Setup-Prozess." } },
    { "@type": "Question", "name": "Kann ich Add-on-Module später dazubuchen?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. Voice-Empfangsdame, Content-Maschine, Beleg-Modul, Lead-Pipeline, News-Cockpit — alles modular ergänzbar. Pro Add-on Setup-Pauschale + monatlicher Aufschlag. Vorgehen wie beim Tier-Upgrade." } },
    { "@type": "Question", "name": "Kostet der KI-Check etwas?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Der KI-Check ist ein kostenloser Remote-Termin zur Orientierung. Er findet per Zoom, Google Meet oder einem ähnlichen Videotool statt." } },
    { "@type": "Question", "name": "Was passiert bei Kündigung? Gibt es einen Lock-in?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Infrastruktur, Zugänge, Workflows und Daten werden sauber dokumentiert übergeben. Ziel ist kein Lock-in, sondern ein System, das Ihr Unternehmen versteht und trotzdem übergabefähig bleibt. Mindestlaufzeit 12 Monate (24 Monate bei Modell B SaaS-Style ohne Setup-Block)." } },
    { "@type": "Question", "name": "Gibt es Förderungen?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. In Deutschland go-digital bis 17.000 € (50% förderfähig). In Österreich KMU.Digital bis 8.000 € und aws AI-Start bis 15.000 €. k-AIzen ist aktuell noch nicht akkreditierter Berater — wir können aber helfen, passende Stellen zu finden." } },
    { "@type": "Question", "name": "Was ist mit Datenschutz und EU-Hosting?", "acceptedAnswer": { "@type": "Answer", "text": "Je nach Setup arbeiten wir mit einer getrennten Umgebung, klaren Freigaben und Auftragsverarbeitungsvertrag. Kundendaten und Memory liegen nachvollziehbar ab, mit Zugriff für Ihr Unternehmen." } }
    ,
    { "@type": "Question", "name": "Welcher Einstieg ist der richtige?", "acceptedAnswer": { "@type": "Answer", "text": "Wenn der Bedarf unklar ist, zuerst Erstgespräch oder Async-Check. Wenn mehrere Baustellen gleichzeitig sichtbar sind, kostenloser Remote-KI-Check. Wenn ein erster Bereich klar ist, ein begrenzter KI-PA-Pilot oder Setup." } }
  ]
};
---

<KaizenLayout
  title="Preise — Einstieg, KI-PA und Ausbau. Alles offen."
  description="Öffentliche Preisorientierung: kostenloses Erstgespräch, kostenloser Remote-KI-Check, KI-PA-Vollsetup als Ausbaurahmen, Add-ons modular. Kein Lock-in."
  path="/pricing"
  activeNav="pricing"
  jsonLd={[offerCatalogSchema, faqSchema]}
>
  <article class="kz-page">
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" loading="lazy" />
      <img src="/icons/icon-ginkgo.png" alt="" class="kz-eyebrow-leaf" loading="lazy" />
      <span>Preise</span>
    </div>
    <h1 class="kz-h1">Preise offen. Einstieg klar strukturiert.</h1>
    <p class="kz-lead">
      Preise stehen sichtbar — auf der Website, im Angebot, am Telefon. Gleichzeitig startet
      nicht jeder Kunde mit dem vollständigen KI-PA-Setup. Der sinnvolle Weg ist:
      kostenloses Erstgespräch, dann kostenloser KI-Check oder Pilot, danach Ausbau.
    </p>

    <section style="margin-top: 40px; padding: 28px 32px; background: rgba(255,85,0,0.07); border: 1px solid rgba(255,85,0,0.16); border-radius: 12px;">
      <h2 class="kz-h2" style="margin-top: 0; font-size: 24px;">Empfohlener Einstieg</h2>
      <p style="margin: 0 0 18px 0;">
        Damit der erste Schritt nicht zu groß wird, führen wir Kunden über einen klaren
        Ablauf: erst verstehen, dann testen, dann ausbauen.
      </p>
      <ol style="margin: 0; padding-left: 20px; line-height: 1.85;">
        <li><strong>Erstgespräch</strong> — 30 Minuten kostenlos, Fit prüfen.</li>
        <li><strong>KI-Check</strong> — kostenlos per Zoom, Google Meet oder ähnlichem Tool; konkrete Prioritäten statt Bauchgefühl.</li>
        <li><strong>Pilot oder KI-PA-Basis</strong> — ein begrenzter Use Case, z.B. Mail, Termine oder Belege.</li>
        <li><strong>Ausbau</strong> — Vollsetup, Add-ons oder Kaizen OS, wenn der Nutzen belegt ist.</li>
      </ol>
    </section>

    <section style="margin-top: 48px;">
      <h2 class="kz-h2">Welche Route passt zu Ihnen?</h2>
      <p>
        Nicht jeder sollte direkt ein Setup kaufen. Der beste Einstieg hängt davon ab,
        wie klar der erste sinnvolle Anwendungsfall schon ist.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 16px; margin-top: 24px;">
        {buyerPaths.map((path) => (
          <article style="display: flex; flex-direction: column; min-height: 270px; padding: 24px; border-radius: 12px; background: var(--kz-cream-deep); color: var(--fg-inverse); border: 1px solid rgba(232,90,43,0.14);">
            <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--kz-ember-text);">{path.k}</div>
            <h3 class="kz-h3" style="margin: 12px 0 10px; font-size: 20px;">{path.title}</h3>
            <p style="margin: 0; font-size: 15px; line-height: 1.62; color: var(--fg-inverse);">{path.text}</p>
            <a href={path.href} class="kz-btn kz-btn--small" style="margin-top: auto; align-self: flex-start;">{path.cta} →</a>
          </article>
        ))}
      </div>
    </section>

    <!-- ─────────── KI-PA Preview Block ─────────── -->
    <section style="margin-top: 48px; padding: 32px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 16px; display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: center;">
      <div>
        <h3 class="kz-h3" style="margin-top: 0;">Wie sieht ein Tag mit dem KI-PA aus?</h3>
        <p style="margin: 8px 0 0 0; font-size: 15px;">
          Die KI-PA-Seite zeigt den Einstieg praktisch: welche Informationen die KI nutzt,
          wo Freigaben passieren und warum Kontext wichtiger ist als ein weiteres Tool.
        </p>
      </div>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <a href="/ki-pa" class="kz-btn kz-btn--small" style="white-space: nowrap;">KI-PA verstehen →</a>
        <a href="/#ein-tag" class="kz-btn kz-btn--small kz-btn--ghost" style="white-space: nowrap;">Tagesbeispiel →</a>
      </div>
    </section>

    <!-- ═══════════════ 1. KI-CHECK ═══════════════ -->
    <section id="audit" style="margin-top: 80px;">
      <h2 class="kz-h2">1. KI-Check — der kostenlose Einstieg</h2>
      <p>
        Bevor ein Angebot entsteht, prüfen wir remote, wo KI in Ihrem Betrieb wirklich tragen kann.
        Der KI-Check kostet nichts und findet per Zoom, Google Meet oder einem ähnlichen Videotool statt.
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 16px; margin: 32px 0;">
        <div style="padding: 32px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
          <img src="/icons/icon-camellia.png" alt="" class="kz-section-leaf" loading="lazy" />
          <h3 class="kz-h3" style="margin-top: 0;">Remote-Gespräch</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">0 €</div>
          <div style="font-size: 13px; color: var(--fg-muted); margin-bottom: 16px;">kostenlos</div>
          <p style="margin: 0; font-size: 15px;">Wir sprechen über Engpässe, Systeme, Datenquellen und erste realistische Einsatzbereiche. Alles online, ohne Anfahrt.</p>
        </div>

        <div style="padding: 32px 24px; background: var(--kz-charcoal); color: var(--kz-cream); border-radius: 12px; position: relative; box-shadow: 0 24px 48px -16px rgba(31,41,51,0.32);">
          <div style="position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--kz-ember-deep); color: var(--kz-cream); padding: 4px 14px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.18em; border-radius: 999px;">Empfohlen</div>
          <img src="/icons/icon-plum-blossom.png" alt="" class="kz-section-leaf" loading="lazy" />
          <h3 class="kz-h3" style="margin-top: 0; color: var(--kz-cream);">Prioritäten klären</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">Remote</div>
          <div style="font-size: 13px; color: rgba(245,240,232,0.6); margin-bottom: 16px;">Zoom, Google Meet oder ähnlich</div>
          <p style="margin: 0; font-size: 15px;">Am Ende soll klarer sein, ob KI-PA, Pilot, konkretes Setup oder vorerst kein Projekt der richtige nächste Schritt ist.</p>
        </div>

        <div style="padding: 32px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
          <img src="/icons/icon-pine.png" alt="" class="kz-section-leaf" loading="lazy" />
          <h3 class="kz-h3" style="margin-top: 0;">Kein Inhouse-Paket</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">Online</div>
          <div style="font-size: 13px; color: var(--fg-muted); margin-bottom: 16px;">kein Vor-Ort-Angebot</div>
          <p style="margin: 0; font-size: 15px;">Der KI-Check wird aktuell nicht als Inhouse-Termin angeboten. Wir prüfen alles im Gespräch und über geteilte Unterlagen.</p>
        </div>
      </div>

      <div style="padding: 24px 28px; background: rgba(255,85,0,0.08); border-left: 4px solid var(--kz-ember); border-radius: 4px; margin-top: 32px;">
        <strong>Klarer Rahmen:</strong> Der KI-Check ist Orientierung, kein verstecktes Beratungsprodukt. Bezahlt wird erst ein Pilot, Setup oder Modul, wenn daraus ein konkretes Angebot entsteht.
      </div>
    </section>

    <!-- ═══════════════ 2. KI-PA TIERS ═══════════════ -->
    <section style="margin-top: 80px;">
      <h2 class="kz-h2">2. KI-PA — der Hauptservice</h2>
      <p>
        Ihr persönlicher KI-Assistent. Mail-Triage, Termine, Briefings, Recherche, Belege,
        Audio→Protokoll und Lern-Memory. Angedockt an Ihre bestehende Arbeitsumgebung
        oder an ein eigenes Kaizen OS. <strong>Zwei Tiers</strong> — der Unterschied ist nicht
        der Funktionsumfang der KI, sondern ob ein menschlicher Backstop durch k-AIzen dazukommt.
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin: 32px 0;">
        <!-- TIER 1 -->
        <div style="padding: 36px 28px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 16px;">
          <div style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.18em; color: var(--kz-ember-text); margin-bottom: 8px;">Tier 1 · Autonom</div>
          <h3 class="kz-h3" style="margin-top: 0;">KI-PA Autonom</h3>
          <p style="margin: 4px 0 24px 0; font-size: 15px; color: rgba(31, 41, 51, 0.75);">Ihr KI-Assistent ohne menschlichen Backstop. Zuverlässig lösbare Aufgaben werden vorbereitet oder ausgeführt; Grenzfälle werden sichtbar markiert.</p>

          <div style="margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid rgba(0,0,0,0.08);">
            <div style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(31, 41, 51, 0.65); margin-bottom: 6px;">Modell A — Setup-First</div>
            <div style="font-family: var(--font-display); font-size: 32px; line-height: 1;">10.299 € <span style="font-size: 14px; color: rgba(31, 41, 51, 0.65); font-family: inherit;">einmalig</span></div>
            <div style="font-size: 15px; margin-top: 4px;">+ <strong>1.029 €/Mo</strong> Retainer · 12 Mo Mindestlaufzeit</div>
          </div>

          <div style="margin-bottom: 24px;">
            <div style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(31, 41, 51, 0.65); margin-bottom: 6px;">Modell B — SaaS-Style</div>
            <div style="font-family: var(--font-display); font-size: 32px; line-height: 1;">0 € <span style="font-size: 14px; color: rgba(31, 41, 51, 0.65); font-family: inherit;">Setup</span></div>
            <div style="font-size: 15px; margin-top: 4px;">+ <strong>1.899 €/Mo</strong> Y1 → <strong>1.029 €/Mo</strong> ab Y2 · 12 Mo</div>
          </div>

          <ul style="list-style: none; padding: 0; margin: 0; font-size: 14px; line-height: 1.7;">
            <li>✓ Mail-Triage + Antwort-Drafts in Ihrem Tonfall</li>
            <li>✓ Calendly-Bookings + Pre-Call-Briefings</li>
            <li>✓ Daily Morning Briefing + Evening Wrap</li>
            <li>✓ Audio → Protokoll mit Action-Items</li>
            <li>✓ Beleg-Sortierung (Basis)</li>
            <li>✓ Web-Recherche + Personen-Background</li>
            <li>✓ Customer-Memory (lernt Stammkunden + Mandanten)</li>
            <li>✓ Link-First-Empfehlungen (Restaurants, Hotels, Bestellungen)</li>
            <li>✓ <strong>News-Cockpit</strong> — tägliche Branchen-News kuratiert</li>
            <li>✓ Arbeitskanal, getrennte Umgebung, DSGVO-Setup mit AVV</li>
          </ul>
        </div>

        <!-- TIER 2 (HIGHLIGHTED) -->
        <div style="padding: 36px 28px; background: var(--kz-charcoal); color: var(--kz-cream); border-radius: 16px; position: relative; box-shadow: 0 24px 48px -16px rgba(31,41,51,0.32);">
          <div style="position: absolute; top: -12px; right: 28px; background: var(--kz-ember-deep); color: var(--kz-cream); padding: 4px 14px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.18em; border-radius: 999px;">Empfehlung</div>
          <div style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.18em; color: var(--kz-ember); margin-bottom: 8px;">Tier 2 · Concierge</div>
          <h3 class="kz-h3" style="margin-top: 0; color: var(--kz-cream);">KI-PA + Concierge</h3>
          <p style="margin: 4px 0 24px 0; font-size: 15px; color: rgba(245,240,232,0.75);">Ihr KI-Assistent plus menschlicher Backstop. Was die KI nicht sauber lösen kann, wird durch k-AIzen übernommen oder entscheidungsreif vorbereitet.</p>

          <div style="margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid rgba(245,240,232,0.12);">
            <div style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(245,240,232,0.78); margin-bottom: 6px;">Modell A — Setup-First</div>
            <div style="font-family: var(--font-display); font-size: 32px; line-height: 1;">12.999 € <span style="font-size: 14px; color: rgba(245,240,232,0.78); font-family: inherit;">einmalig</span></div>
            <div style="font-size: 15px; margin-top: 4px;">+ <strong>1.529 €/Mo</strong> Retainer · 12 Mo Mindestlaufzeit</div>
          </div>

          <div style="margin-bottom: 24px;">
            <div style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(245,240,232,0.78); margin-bottom: 6px;">Modell B — SaaS-Style</div>
            <div style="font-family: var(--font-display); font-size: 32px; line-height: 1;">0 € <span style="font-size: 14px; color: rgba(245,240,232,0.78); font-family: inherit;">Setup</span></div>
            <div style="font-size: 15px; margin-top: 4px;">+ <strong>2.599 €/Mo</strong> Y1 → <strong>1.529 €/Mo</strong> ab Y2 · 12 Mo</div>
          </div>

          <ul style="list-style: none; padding: 0; margin: 0; font-size: 14px; line-height: 1.7;">
            <li>✓ <strong>Alles aus Tier 1</strong>, plus:</li>
            <li>✓ Anrufe in Ihrem Namen (Behörden, Versicherungen, Service)</li>
            <li>✓ Bürokratie & Behörden-Krams (Anträge, Steuer-Zuarbeit)</li>
            <li>✓ Reklamationen & Eskalationen (Bank, Airline, Lieferanten)</li>
            <li>✓ Verhandlungen und Klärungen mit Dienstleistern</li>
            <li>✓ Komplexe Reise-Logistik (Multi-Stop, Visa, Mietwagen)</li>
            <li>✓ Vollmacht + AVV + Vault-Setup für sichere Daten-Übergabe</li>
            <li>✓ Service-Level Mo-Fr 9-16 Uhr für menschliche Tasks</li>
            <li>✓ Aktive Memory-Pflege pro Kunde (Tuning durch Ben)</li>
          </ul>
        </div>
      </div>

      <p style="margin-top: 32px; font-size: 14px; color: var(--fg-muted); text-align: center;">
        Beide Modelle ergeben über 24 Monate ungefähr vergleichbare Gesamtkosten. Modell B (SaaS) ist liquiditätsschonender, Modell A (Setup-First) hat planbare Monatsraten.
      </p>
    </section>

    <!-- ═══════════════ 3. ADD-ON-MODULE ═══════════════ -->
    <section style="margin-top: 80px;">
      <h2 class="kz-h2">3. Add-on-Module — modular zubuchbar</h2>
      <p>
        Zu beiden Tiers ergänzbar. Alle Module integrieren sich in Ihre bestehende Umgebung:
        ein Arbeitskanal, ein KI-PA, mehr Fähigkeiten.
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px; margin: 32px 0;">

        <!-- Voice-Empfangsdame (Premium) -->
        <div style="padding: 28px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px; position: relative;">
          <div style="position: absolute; top: -10px; right: 20px; background: var(--kz-ember); color: var(--kz-cream); padding: 3px 10px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; border-radius: 999px;">Premium</div>
          <div style="font-size: 28px; margin-bottom: 8px;">🎙️</div>
          <h3 class="kz-h3" style="margin-top: 0; font-size: 19px;">Voice-Empfangsdame</h3>
          <p style="margin: 4px 0 12px 0; font-size: 14px; color: rgba(31, 41, 51, 0.75);">Eigene Firmen-Telefonnummer. KI nimmt Anrufe entgegen, beantwortet FAQs, vereinbart Termine, leitet Wichtiges in den Arbeitskanal.</p>
          <div style="font-family: var(--font-display); font-size: 22px; line-height: 1;">9.999 €<span style="font-size: 14px; color: rgba(31, 41, 51, 0.65); font-family: inherit;"> Setup</span></div>
          <div style="font-size: 14px; margin-top: 2px;">+ <strong>799 €/Mo</strong></div>
        </div>

        <!-- Content-Maschine -->
        <div style="padding: 28px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
          <div style="font-size: 28px; margin-bottom: 8px;">📢</div>
