---
import KaizenLayout from '../layouts/KaizenLayout.astro';

const offerCatalogSchema = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "k-AIzen Preise",
  "description": "Discovery-Audit ab 1.190 €, KI-PA in 2 Tiers (Autonom ab 10.299 € Setup oder 1.899 €/Mo · Concierge ab 12.999 € oder 2.399 €/Mo), Add-on-Module ab 999 €. Preise öffentlich, kein Lock-in.",
  "itemListElement": [
    {
      "@type": "Offer",
      "name": "Discovery-Audit Standard",
      "description": "1 Tag remote, Report binnen 5 Werktagen, 1h Follow-up. 50% bei Buchung innerhalb 30 Tagen aufs Setup angerechnet.",
      "price": "1490",
      "priceCurrency": "EUR",
      "areaServed": "DE"
    },
    {
      "@type": "Offer",
      "name": "KI-PA Autonom (Tier 1) — Setup-First",
      "description": "Dein persönlicher KI-Assistent. Mail-Triage, Termine, Briefings, Belege, Audio→Protokoll. Discord-Cockpit, eigener Server in Deutschland. Memory-System inklusive.",
      "price": "10299",
      "priceCurrency": "EUR",
      "areaServed": "DE"
    },
    {
      "@type": "Offer",
      "name": "KI-PA + Concierge (Tier 2) — Setup-First",
      "description": "Alles aus Tier 1, plus: ich übernehme als Mensch alles was die KI nicht kann — Anrufe, Behörden, Reklamationen, Verhandlungen, Reise-Logistik. Mo-Fr 9-16 für menschliche Tasks.",
      "price": "12999",
      "priceCurrency": "EUR",
      "areaServed": "DE"
    },
    {
      "@type": "Offer",
      "name": "Voice-Empfangsdame (Add-on)",
      "description": "Eigene Firmen-Telefonnummer, KI nimmt Anrufe entgegen, beantwortet FAQs, vereinbart Termine. Premium-Modul.",
      "price": "9999",
      "priceCurrency": "EUR",
      "areaServed": "DE"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Was ist der Unterschied zwischen Tier 1 und Tier 2?", "acceptedAnswer": { "@type": "Answer", "text": "Tier 1 = KI-PA Autonom. Alles was eine KI heute zuverlässig kann (Mails, Termine, Briefings, Recherche, Belege, Audio-Protokolle) macht sie selbst. Was sie nicht kann, sagt sie ehrlich. Tier 2 = KI-PA + Concierge. Alles aus Tier 1, plus: was die KI nicht kann (Anrufe in deinem Namen, Behörden, Reklamationen, Verhandlungen, komplexe Reise-Logistik), mache ich im Hintergrund. Du bekommst das Ergebnis im Channel — als hätte die KI's gemacht." } },
    { "@type": "Question", "name": "Modell A oder Modell B — was passt für mich?", "acceptedAnswer": { "@type": "Answer", "text": "Beide kosten über 24 Monate ungefähr gleich. Modell A (Setup-First): einmaliger Setup-Block, dann niedrige Monatsraten. Gut wenn Cash da ist und du Investitions-Logik magst. Modell B (SaaS-Style): kein Setup-Block, höhere Y1-Monatsrate, automatische Reduktion ab Y2. Gut wenn Cashflow wichtiger ist als Total-Cost." } },
    { "@type": "Question", "name": "Kann ich Tier 1 später auf Tier 2 upgraden?", "acceptedAnswer": { "@type": "Answer", "text": "Ja, jederzeit. Dein KI-PA bleibt — er kennt dich dann schon. Aufpreis: Differenz zwischen Tier 1 und Tier 2 (Setup + monatlich) ab Upgrade-Datum. Kein neuer Setup." } },
    { "@type": "Question", "name": "Kann ich Add-on-Module später dazubuchen?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. Voice-Empfangsdame, Content-Maschine, Beleg-Modul, Lead-Pipeline, News-Cockpit — alles modular ergänzbar. Pro Add-on Setup-Pauschale + monatlicher Aufschlag. Vorgehen wie beim Tier-Upgrade." } },
    { "@type": "Question", "name": "Warum bezahltes Audit statt kostenloser Beratung?", "acceptedAnswer": { "@type": "Answer", "text": "Wer ein Audit bezahlt, will wirklich Klarheit. Wer kostenlose Beratung will, will oft eine Visitenkarten-Sammlung. Bei Buchung eines Setups innerhalb 30 Tagen werden 50% des Audit-Preises aufs Setup angerechnet." } },
    { "@type": "Question", "name": "Was passiert bei Kündigung? Bin ich gelocked-in?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Drei-Klick-Übergabe: Hetzner-Account auf dich transferieren, Tailscale-Zugang dir geben, DNS umstellen. Innerhalb 5 Werktagen bist du komplett unabhängig. Code, Workflows, Daten — alles deins. Mindestlaufzeit 12 Monate (24 Monate bei Modell B SaaS-Style ohne Setup-Block)." } },
    { "@type": "Question", "name": "Gibt es Förderungen?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. In Deutschland go-digital bis 17.000 € (50% förderfähig). In Österreich KMU.Digital bis 8.000 € und aws AI-Start bis 15.000 €. k-AIzen ist aktuell noch nicht akkreditierter Berater — wir können dir aber helfen, einen zu finden." } },
    { "@type": "Question", "name": "Was ist mit Datenschutz und EU-Hosting?", "acceptedAnswer": { "@type": "Answer", "text": "Pro Kunde ein dedizierter Hetzner-Server in Nürnberg oder Helsinki. Kein Multi-Tenant. DSGVO-konform ab Tag 1, Auftragsverarbeitungsvertrag inklusive. Memory-System (Gäste/Mandanten-Gedächtnis) liegt als Markdown-Files auf deinem Server — du hast 100% Read-Access." } }
  ]
};
---

<KaizenLayout
  title="Preise — KI-PA in 2 Tiers, Add-ons, Audit. Alles offen."
  description="KI-PA Autonom (Tier 1) ab 10.299 € Setup oder 1.899 €/Mo. KI-PA + Concierge (Tier 2) ab 12.999 € oder 2.399 €/Mo. Add-ons ab 999 €. Discovery-Audit ab 1.190 €. Kein Lock-in. Preise öffentlich."
  path="/pricing"
  activeNav="pricing"
  jsonLd={[offerCatalogSchema, faqSchema]}
>
  <article class="kz-page">
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" loading="lazy" />
      <img src="/icons/icon-ginkgo.png" alt="" class="kz-eyebrow-leaf" loading="lazy" />
      <span>Preise</span>
    </div>
    <h1 class="kz-h1">Preise offen.<br/><span style="color: var(--kz-ember-text); font-style: italic;">Kein „auf Anfrage". Kein Versteckspiel.</span></h1>
    <p class="kz-lead">
      Eines unserer drei Manifest-Prinzipien: Preise stehen sichtbar — auf der Website, im Angebot, am Telefon. Du sollst wissen woran du bist, bevor du auf einen Termin-Knopf drückst. <strong>Schneller Überblick:</strong> Tier 1 ab 10.299 € (oder 1.899 €/Mo ohne Setup), Tier 2 ab 12.999 €. Add-ons modular zubuchbar. Audit-Einstieg ab 1.190 €.
    </p>

    <!-- ─────────── Pitch-Preview-Block ─────────── -->
    <section style="margin-top: 48px; padding: 32px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 16px; display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: center;">
      <div>
        <h3 class="kz-h3" style="margin-top: 0;">Wie sieht dein Tag mit dem KI-PA aus?</h3>
        <p style="margin: 8px 0 0 0; font-size: 15px;">
          Schau dir eine vollständige Tages-Story durch — Morgens bis Abend, mit konkreten Discord-Posts. 11 Slides, ~3 Min Klick-Through.
        </p>
      </div>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <a href="/pitch/markus" class="kz-btn kz-btn--small" style="white-space: nowrap;">Markus (GF) →</a>
        <a href="/pitch/lena" class="kz-btn kz-btn--small kz-btn--ghost" style="white-space: nowrap;">Lena (Gastro) →</a>
      </div>
    </section>

    <!-- ═══════════════ 1. AUDIT ═══════════════ -->
    <section style="margin-top: 80px;">
      <h2 class="kz-h2">1. Discovery-Audit — der Einstieg</h2>
      <p>
        Ein Tag in deinem Betrieb, dokumentierter Report mit Roadmap, Festpreis. Drei Varianten je nach Setting. <strong>Der Standard-Audit ist die Empfehlung für die meisten KMU.</strong>
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 16px; margin: 32px 0;">
        <div style="padding: 32px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
          <img src="/icons/icon-camellia.png" alt="" class="kz-section-leaf" loading="lazy" />
          <h3 class="kz-h3" style="margin-top: 0;">Remote Kompakt</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">1.190 €</div>
          <div style="font-size: 13px; color: var(--fg-muted); margin-bottom: 16px;">netto, einmalig</div>
          <p style="margin: 0; font-size: 15px;">Halber Tag remote, Report binnen 5 Werktagen. Für kleinere Betriebe (10–15 MA) oder als niedrigschwelliger Einstieg.</p>
        </div>

        <div style="padding: 32px 24px; background: var(--kz-charcoal); color: var(--kz-cream); border-radius: 12px; position: relative; box-shadow: 0 24px 48px -16px rgba(31,41,51,0.32);">
          <div style="position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--kz-ember-deep); color: var(--kz-cream); padding: 4px 14px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.18em; border-radius: 999px;">Standard</div>
          <img src="/icons/icon-plum-blossom.png" alt="" class="kz-section-leaf" loading="lazy" />
          <h3 class="kz-h3" style="margin-top: 0; color: var(--kz-cream);">Remote Standard</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">1.490 €</div>
          <div style="font-size: 13px; color: rgba(245,240,232,0.6); margin-bottom: 16px;">netto, einmalig</div>
          <p style="margin: 0; font-size: 15px;">Voller Tag remote, 3 Mitarbeiter-Interviews à 20 Min, Report binnen 5 Werktagen, 1h Follow-up-Call. Default für die meisten Audits.</p>
        </div>

        <div style="padding: 32px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
          <img src="/icons/icon-pine.png" alt="" class="kz-section-leaf" loading="lazy" />
          <h3 class="kz-h3" style="margin-top: 0;">Vor Ort</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">1.990 €</div>
          <div style="font-size: 13px; color: var(--fg-muted); margin-bottom: 16px;">netto, einmalig · zzgl. Reisekosten</div>
          <p style="margin: 0; font-size: 15px;">Zwei Tage vor Ort, persönliche Begleitung der Mitarbeiter im Workflow. Für komplexere Betriebe (20+ MA) oder wenn Remote nicht passt.</p>
        </div>
      </div>

      <div style="padding: 24px 28px; background: rgba(255,85,0,0.08); border-left: 4px solid var(--kz-ember); border-radius: 4px; margin-top: 32px;">
        <strong>Stage-Gate-Mechanik:</strong> Bei Buchung eines Setups innerhalb 30 Tagen werden <strong>50% des Audit-Preises aufs Setup angerechnet</strong>. Ein Standard-Audit für 1.490 € reduziert dein Setup also um 745 €. Wer nur den Audit will, zahlt voll. Wer weitermacht, kriegt einen rationalen Anreiz.
      </div>
    </section>

    <!-- ═══════════════ 2. KI-PA TIERS ═══════════════ -->
    <section style="margin-top: 80px;">
      <h2 class="kz-h2">2. KI-PA — der Hauptservice</h2>
      <p>
        Dein persönlicher KI-Assistent. Mail-Triage, Termine, Briefings, Recherche, Belege, Audio→Protokoll, Lern-Memory. Discord-Cockpit auf eigenem Server in Deutschland. <strong>Zwei Tiers</strong> — der Unterschied ist nicht der Funktionsumfang der KI, sondern ob ich als Mensch im Hintergrund einspringe.
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin: 32px 0;">
        <!-- TIER 1 -->
        <div style="padding: 36px 28px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 16px;">
          <div style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.18em; color: var(--kz-ember-text); margin-bottom: 8px;">Tier 1 · Autonom</div>
          <h3 class="kz-h3" style="margin-top: 0;">KI-PA Autonom</h3>
          <p style="margin: 4px 0 24px 0; font-size: 15px; color: var(--fg-muted);">Dein KI-Assistent ohne menschlichen Backstop. Was er kann, macht er. Was er nicht kann, sagt er ehrlich.</p>

          <div style="margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid rgba(0,0,0,0.08);">
            <div style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--fg-muted); margin-bottom: 6px;">Modell A — Setup-First</div>
            <div style="font-family: var(--font-display); font-size: 32px; line-height: 1;">10.299 € <span style="font-size: 14px; color: var(--fg-muted); font-family: inherit;">einmalig</span></div>
            <div style="font-size: 15px; margin-top: 4px;">+ <strong>1.029 €/Mo</strong> Retainer · 12 Mo Mindestlaufzeit</div>
          </div>

          <div style="margin-bottom: 24px;">
            <div style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--fg-muted); margin-bottom: 6px;">Modell B — SaaS-Style</div>
            <div style="font-family: var(--font-display); font-size: 32px; line-height: 1;">0 € <span style="font-size: 14px; color: var(--fg-muted); font-family: inherit;">Setup</span></div>
            <div style="font-size: 15px; margin-top: 4px;">+ <strong>1.899 €/Mo</strong> Y1 → <strong>1.029 €/Mo</strong> ab Y2 · 12 Mo</div>
          </div>

          <ul style="list-style: none; padding: 0; margin: 0; font-size: 14px; line-height: 1.7;">
            <li>✓ Mail-Triage + Antwort-Drafts in deinem Tonfall</li>
            <li>✓ Calendly-Bookings + Pre-Call-Briefings</li>
            <li>✓ Daily Morning Briefing + Evening Wrap</li>
            <li>✓ Audio → Protokoll mit Action-Items</li>
            <li>✓ Beleg-Sortierung (Basis)</li>
            <li>✓ Web-Recherche + Personen-Background</li>
            <li>✓ Customer-Memory (lernt Stammkunden + Mandanten)</li>
            <li>✓ Link-First-Empfehlungen (Restaurants, Hotels, Bestellungen)</li>
            <li>✓ Discord-Cockpit, eigener Hetzner-Server, DSGVO-konform</li>
          </ul>
        </div>

        <!-- TIER 2 (HIGHLIGHTED) -->
        <div style="padding: 36px 28px; background: var(--kz-charcoal); color: var(--kz-cream); border-radius: 16px; position: relative; box-shadow: 0 24px 48px -16px rgba(31,41,51,0.32);">
          <div style="position: absolute; top: -12px; right: 28px; background: var(--kz-ember-deep); color: var(--kz-cream); padding: 4px 14px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.18em; border-radius: 999px;">Empfehlung</div>
          <div style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.18em; color: var(--kz-ember); margin-bottom: 8px;">Tier 2 · Concierge</div>
          <h3 class="kz-h3" style="margin-top: 0; color: var(--kz-cream);">KI-PA + Concierge</h3>
          <p style="margin: 4px 0 24px 0; font-size: 15px; color: rgba(245,240,232,0.75);">Dein KI-Assistent UND ich als persönlicher Backstop. Was die KI nicht kann, mache ich. Du musst nichts mehr machen.</p>

          <div style="margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid rgba(245,240,232,0.12);">
            <div style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(245,240,232,0.55); margin-bottom: 6px;">Modell A — Setup-First</div>
            <div style="font-family: var(--font-display); font-size: 32px; line-height: 1;">12.999 € <span style="font-size: 14px; color: rgba(245,240,232,0.6); font-family: inherit;">einmalig</span></div>
            <div style="font-size: 15px; margin-top: 4px;">+ <strong>1.299 €/Mo</strong> Retainer · 12 Mo Mindestlaufzeit</div>
          </div>

          <div style="margin-bottom: 24px;">
            <div style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(245,240,232,0.55); margin-bottom: 6px;">Modell B — SaaS-Style</div>
            <div style="font-family: var(--font-display); font-size: 32px; line-height: 1;">0 € <span style="font-size: 14px; color: rgba(245,240,232,0.6); font-family: inherit;">Setup</span></div>
            <div style="font-size: 15px; margin-top: 4px;">+ <strong>2.399 €/Mo</strong> Y1 → <strong>1.299 €/Mo</strong> ab Y2 · 12 Mo</div>
          </div>

          <ul style="list-style: none; padding: 0; margin: 0; font-size: 14px; line-height: 1.7;">
            <li>✓ <strong>Alles aus Tier 1</strong>, plus:</li>
            <li>✓ Anrufe in deinem Namen (Behörden, Versicherungen, Service)</li>
            <li>✓ Bürokratie & Behörden-Krams (Anträge, Steuer-Zuarbeit)</li>
            <li>✓ Reklamationen & Eskalationen (Bank, Airline, Lieferanten)</li>
            <li>✓ Verhandlungen (Versicherung kündigen, Preise drücken)</li>
            <li>✓ Komplexe Reise-Logistik (Multi-Stop, Visa, Mietwagen)</li>
            <li>✓ Vollmacht + AVV + Vault-Setup für sichere Daten-Übergabe</li>
            <li>✓ Service-Level Mo-Fr 9-16 Uhr für menschliche Tasks</li>
            <li>✓ Aktive Memory-Pflege pro Kunde (Tuning durch Ben)</li>
          </ul>
        </div>
      </div>

      <p style="margin-top: 32px; font-size: 14px; color: var(--fg-muted); text-align: center;">
        Beide Modelle ergeben über 24 Monate ungefähr den gleichen Total-Cost. Modell B (SaaS) ist Cashflow-freundlicher, Modell A (Setup-First) hat planbare Monatsraten.
      </p>
    </section>

    <!-- ═══════════════ 3. ADD-ON-MODULE ═══════════════ -->
    <section style="margin-top: 80px;">
      <h2 class="kz-h2">3. Add-on-Module — modular zubuchbar</h2>
      <p>
        Zu beiden Tiers ergänzbar. Alle Module integrieren sich in deinen existierenden Discord-Server — ein Cockpit, ein KI-PA, mehr Fähigkeiten.
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px; margin: 32px 0;">

        <!-- Voice-Empfangsdame (Premium) -->
        <div style="padding: 28px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px; position: relative;">
          <div style="position: absolute; top: -10px; right: 20px; background: var(--kz-ember); color: var(--kz-cream); padding: 3px 10px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; border-radius: 999px;">Premium</div>
          <div style="font-size: 28px; margin-bottom: 8px;">🎙️</div>
          <h3 class="kz-h3" style="margin-top: 0; font-size: 19px;">Voice-Empfangsdame</h3>
          <p style="margin: 4px 0 12px 0; font-size: 14px; color: var(--fg-muted);">Eigene Firmen-Telefonnummer. KI nimmt Anrufe entgegen, beantwortet FAQs, vereinbart Termine, leitet Wichtiges an Discord.</p>
          <div style="font-family: var(--font-display); font-size: 22px; line-height: 1;">9.999 €<span style="font-size: 14px; color: var(--fg-muted); font-family: inherit;"> Setup</span></div>
          <div style="font-size: 14px; margin-top: 2px;">+ <strong>799 €/Mo</strong></div>
        </div>

        <!-- Content-Maschine -->
        <div style="padding: 28px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
          <div style="font-size: 28px; margin-bottom: 8px;">📢</div>
          <h3 class="kz-h3" style="margin-top: 0; font-size: 19px;">Content-Maschine</h3>
          <p style="margin: 4px 0 12px 0; font-size: 14px; color: var(--fg-muted);">Social-Media-Posts in deinem Tonfall, Image-Gen, 12+ Posts/Monat. Approval-Flow im Discord.</p>
          <div style="font-family: var(--font-display); font-size: 22px; line-height: 1;">4.499 €<span style="font-size: 14px; color: var(--fg-muted); font-family: inherit;"> Setup</span></div>
          <div style="font-size: 14px; margin-top: 2px;">+ <strong>499 €/Mo</strong></div>
        </div>

        <!-- Beleg- & Steuer-Modul -->
        <div style="padding: 28px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
          <div style="font-size: 28px; margin-bottom: 8px;">💰</div>
          <h3 class="kz-h3" style="margin-top: 0; font-size: 19px;">Beleg- & Steuer-Modul</h3>
          <p style="margin: 4px 0 12px 0; font-size: 14px; color: var(--fg-muted);">Erweiterte Beleg-Sortierung + monatlicher Steuerberater-Export (GoBD-konform).</p>
          <div style="font-family: var(--font-display); font-size: 22px; line-height: 1;">3.499 €<span style="font-size: 14px; color: var(--fg-muted); font-family: inherit;"> Setup</span></div>
          <div style="font-size: 14px; margin-top: 2px;">+ <strong>399 €/Mo</strong></div>
        </div>

        <!-- Lead-Pipeline -->
        <div style="padding: 28px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
          <div style="font-size: 28px; margin-bottom: 8px;">🎯</div>
          <h3 class="kz-h3" style="margin-top: 0; font-size: 19px;">Lead-Pipeline</h3>
          <p style="margin: 4px 0 12px 0; font-size: 14px; color: var(--fg-muted);">Lead-Recherche mit ICP-Filter, Outreach-Mail-Drafts in deinem Tonfall, Follow-up-Tracking.</p>
          <div style="font-family: var(--font-display); font-size: 22px; line-height: 1;">2.999 €<span style="font-size: 14px; color: var(--fg-muted); font-family: inherit;"> Setup</span></div>
          <div style="font-size: 14px; margin-top: 2px;">+ <strong>299 €/Mo</strong></div>
        </div>

        <!-- News-Cockpit -->
        <div style="padding: 28px 24px; background: var(--kz-cream-deep); color: var(--fg-inverse); border-radius: 12px;">
          <div style="font-size: 28px; margin-bottom: 8px;">📰</div>
          <h3 class="kz-h3" style="margin-top: 0; font-size: 19px;">News-Cockpit</h3>
          <p style="margin: 4px 0 12px 0; font-size: 14px; color: var(--fg-muted);">Tägliche Branchen-News kuratiert + im Daily Briefing integriert. Keine Info-Überflutung.</p>
          <div style="font-family: var(--font-display); font-size: 22px; line-height: 1;">999 €<span style="font-size: 14px; color: var(--fg-muted); font-family: inherit;"> Setup</span></div>
          <div style="font-size: 14px; margin-top: 2px;">+ <strong>99 €/Mo</strong></div>
        </div>

      </div>
    </section>

    <!-- ═══════════════ 4. BEISPIEL-BUNDLES ═══════════════ -->
    <section style="margin-top: 80px;">
