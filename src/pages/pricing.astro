---
import KaizenLayout from '../layouts/KaizenLayout.astro';

const offerCatalogSchema = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "k-AIzen Preise",
  "description": "Discovery-Audit, Modul-Festpreise, Komplett-PA-Bundle und Retainer für KMU. Preise öffentlich, kein Lock-in.",
  "itemListElement": [
    {
      "@type": "Offer",
      "name": "Discovery-Audit Standard",
      "description": "1 Tag remote, 3 Mitarbeiter-Interviews, kundenspezifischer Report binnen 5 Werktagen, 1h Follow-up.",
      "price": "1490",
      "priceCurrency": "EUR",
      "areaServed": "DE"
    },
    {
      "@type": "Offer",
      "name": "Komplett-PA-Bundle",
      "description": "Ein S-, ein M- und ein L-Modul gebündelt — der KI-PA für deinen Betrieb.",
      "price": "14999",
      "priceCurrency": "EUR",
      "areaServed": "DE"
    },
    {
      "@type": "Offer",
      "name": "Retainer Wachstum",
      "description": "2 Module im Betrieb, 8h Anpassung pro Monat, Reaktion < 24h Werktags.",
      "price": "799",
      "priceCurrency": "EUR",
      "priceSpecification": { "@type": "UnitPriceSpecification", "price": "799", "priceCurrency": "EUR", "unitText": "pro Monat" },
      "areaServed": "DE"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Warum bezahltes Audit statt kostenloser Beratung?", "acceptedAnswer": { "@type": "Answer", "text": "Wer ein Audit bezahlt, will wirklich Klarheit. Wer kostenlose Beratung will, will oft eine Visitenkarten-Sammlung. Die 1.490 € sind der Preis für einen Tag Beobachtung plus Roadmap. Bei Buchung eines Setups innerhalb 30 Tagen werden 50% angerechnet." } },
    { "@type": "Question", "name": "Was ist die Stage-Gate-Mechanik?", "acceptedAnswer": { "@type": "Answer", "text": "Wenn du nach dem Audit innerhalb 30 Tagen ein Setup-Paket buchst, ziehen wir 50% des Audit-Preises vom Setup ab. Ein Audit für 1.490 € reduziert das Setup also um 745 €. Wer nur den Audit will, zahlt voll. Wer weitermacht, kriegt einen rationalen Anreiz." } },
    { "@type": "Question", "name": "Was ist im Modul-Festpreis drin?", "acceptedAnswer": { "@type": "Answer", "text": "Setup, Tests, Übergabe-Doku, dein eigener Hetzner-Server, OAuth-Integration in deinen Tool-Stack (M365, Google, ERP, CRM). Vier Wochen Begleit-Betrieb. Kein Stunden-Tracking, keine versteckten Sub-Kosten." } },
    { "@type": "Question", "name": "Was ist im Retainer drin — und was nicht?", "acceptedAnswer": { "@type": "Answer", "text": "Drin: Hosting, Updates, Backups, Monitoring, Anpassungs-Stunden (4/8/16h je Stufe), SLA. Nicht drin: neue Module (= neuer Setup-Preis) und komplette Re-Architekturen. Anpassung heißt Prompt-Tweaks, Voice-Justierung, Bug-Behebung, Ergebnis-Verfeinerung." } },
    { "@type": "Question", "name": "Was passiert bei Kündigung? Bin ich gelocked-in?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Drei-Klick-Übergabe: Hetzner-Account auf dich transferieren, Tailscale-Zugang dir geben, DNS umstellen. Innerhalb 5 Werktagen bist du komplett unabhängig. Code, Workflows, Daten — alles deins. Das ist eines unserer drei Manifest-Prinzipien." } },
    { "@type": "Question", "name": "Gibt es Förderungen?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. In Deutschland go-digital bis 17.000 € (50% förderfähig). In Österreich KMU.Digital bis 8.000 € und aws AI-Start bis 15.000 €. k-AIzen ist aktuell noch nicht akkreditierter Berater — wir können dir aber helfen, einen zu finden, oder begleiten den Antrag. Phase-2-Thema bei uns." } },
    { "@type": "Question", "name": "Stundensatz für Custom-Arbeit?", "acceptedAnswer": { "@type": "Answer", "text": "130 €/h für alles, was über die Retainer-Stunden hinausgeht. Alternativ: Erweiterungs-Modul-Festpreis ab 990 € für klar abgegrenzte Mini-Use-Cases (neue Mail-Kategorie, neuer Workflow-Trigger). Du wählst." } },
    { "@type": "Question", "name": "Was ist mit Datenschutz und EU-Hosting?", "acceptedAnswer": { "@type": "Answer", "text": "Pro Kunde ein dedizierter Hetzner-Server in Nürnberg oder Helsinki. Kein Multi-Tenant. DSGVO-konform ab Tag 1, Auftragsverarbeitungsvertrag inklusive. Wer mehr Souveränität will: On-Premise mit lokalem Llama/Mistral-Modell statt Claude API." } }
  ]
};
---

<KaizenLayout
  title="Preise — Audit, Module, Retainer. Alles offen."
  description="Discovery-Audit ab 1.190 €, Module ab 2.490 €, Komplett-PA-Bundle 14.999 €, Retainer ab 499 €/Monat. Förderungen prominent. Kein Lock-in. Preise öffentlich."
  path="/pricing"
  activeNav="pricing"
  jsonLd={[offerCatalogSchema, faqSchema]}
>
  <article class="kz-page">
    <div class="kz-page-eyebrow">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-mark" loading="lazy" />
      <span class="kanji">価</span>
      <span>Preise</span>
    </div>
    <h1 class="kz-h1">Preise offen.<br/><span style="color: var(--kz-ember); font-style: italic;">Kein „auf Anfrage". Kein Versteckspiel.</span></h1>
    <p class="kz-lead">
      Eines unserer drei Manifest-Prinzipien: Preise stehen sichtbar auf der Website, im Angebot, am Telefon. Du sollst wissen woran du bist, bevor du auf einen Termin-Knopf drückst. Hier sind alle Zahlen.
    </p>

    <!-- AUDIT -->
    <section style="margin-top: 64px;">
      <h2 class="kz-h2">1. Discovery-Audit — der Einstieg</h2>
      <p>
        Ein Tag in deinem Betrieb, dokumentierter Report mit Roadmap, Festpreis. Drei Varianten je nach Setting. <strong>Der Standard-Audit ist die Empfehlung für die meisten KMU.</strong>
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 16px; margin: 32px 0;">
        <div style="padding: 32px 24px; background: var(--kz-cream-deep); border-radius: 12px;">
          <div style="font-family: var(--font-jp); font-size: 28px; color: var(--kz-ember); margin-bottom: 12px;">小</div>
          <h3 class="kz-h3" style="margin-top: 0;">Remote Kompakt</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">1.190 €</div>
          <div style="font-size: 13px; color: var(--fg-muted); margin-bottom: 16px;">netto, einmalig</div>
          <p style="margin: 0; font-size: 15px;">Halber Tag remote, Report binnen 5 Werktagen. Für kleinere Betriebe (10–15 MA) oder als niedrigschwelliger Einstieg.</p>
        </div>

        <div style="padding: 32px 24px; background: var(--kz-charcoal); color: var(--kz-cream); border-radius: 12px; position: relative; box-shadow: 0 24px 48px -16px rgba(31,41,51,0.32);">
          <div style="position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--kz-ember); color: var(--kz-cream); padding: 4px 14px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.18em; border-radius: 999px;">Standard</div>
          <div style="font-family: var(--font-jp); font-size: 28px; color: var(--kz-ember); margin-bottom: 12px;">中</div>
          <h3 class="kz-h3" style="margin-top: 0; color: var(--kz-cream);">Remote Standard</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">1.490 €</div>
          <div style="font-size: 13px; color: rgba(245,240,232,0.6); margin-bottom: 16px;">netto, einmalig</div>
          <p style="margin: 0; font-size: 15px;">Voller Tag remote, 3 Mitarbeiter-Interviews à 20 Min, Report binnen 5 Werktagen, 1h Follow-up-Call. Default für die meisten Audits.</p>
        </div>

        <div style="padding: 32px 24px; background: var(--kz-cream-deep); border-radius: 12px;">
          <div style="font-family: var(--font-jp); font-size: 28px; color: var(--kz-ember); margin-bottom: 12px;">大</div>
          <h3 class="kz-h3" style="margin-top: 0;">Vor Ort</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">1.990 €</div>
          <div style="font-size: 13px; color: var(--fg-muted); margin-bottom: 16px;">netto, einmalig + Anreise</div>
          <p style="margin: 0; font-size: 15px;">Wie Standard plus Werks-/Büro-Tour. Für Hersteller oder Betriebe wo Maschinen, Produktion, physische Räume Teil des Bilds sind.</p>
        </div>
      </div>

      <div style="padding: 24px 28px; background: var(--kz-cream); border: 1px solid var(--kz-border); border-radius: 8px;">
        <strong>Stage-Gate-Mechanik:</strong> Bei Buchung eines Setup-Pakets innerhalb <strong>30 Tagen</strong> nach Audit-Lieferung werden <strong>50% des Audit-Preises auf das Setup angerechnet</strong>. Ein Standard-Audit (1.490 €) reduziert dein erstes Setup also um 745 €.
      </div>

      <p style="margin-top: 24px;">
        <a href="/audit" class="kz-btn">Audit buchen →</a>
      </p>
    </section>

    <!-- MODULE -->
    <section style="margin-top: 96px;">
      <h2 class="kz-h2">2. Modul-Festpreise — der Aufbau</h2>
      <p>
        Aus dem Audit kommt eine Roadmap. Die Roadmap besteht aus Modulen — abgegrenzten Bausteinen mit klarem Setup-Festpreis. Drei Größen-Klassen, je nach Aufwand.
      </p>

      <div style="overflow-x: auto; margin: 32px 0;">
        <table style="width: 100%; border-collapse: collapse; font-size: 15px;">
          <thead>
            <tr style="border-bottom: 2px solid var(--kz-charcoal);">
              <th style="text-align: left; padding: 12px 8px;">Modul</th>
              <th style="text-align: center; padding: 12px 8px;">Klasse</th>
              <th style="text-align: right; padding: 12px 8px;">Setup einmalig</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--kz-border);"><td style="padding: 14px 8px;"><strong>Audio → Protokoll</strong> · Meeting/Anruf-Mitschrift, automatische Zusammenfassung</td><td style="text-align: center;">S</td><td style="text-align: right; font-family: var(--font-display); font-size: 18px;">2.490 €</td></tr>
            <tr style="border-bottom: 1px solid var(--kz-border);"><td style="padding: 14px 8px;"><strong>FAQ-Chatbot Basis</strong> · Antworten aus deiner Doku, klickbare Quellen</td><td style="text-align: center;">S</td><td style="text-align: right; font-family: var(--font-display); font-size: 18px;">2.490 €</td></tr>
            <tr style="border-bottom: 1px solid var(--kz-border);"><td style="padding: 14px 8px;"><strong>News &amp; Knowledge Cockpit</strong> · Tages-Digest, RAG-Suche, Themen-Tracking</td><td style="text-align: center;">M</td><td style="text-align: right; font-family: var(--font-display); font-size: 18px;">3.990 €</td></tr>
            <tr style="border-bottom: 1px solid var(--kz-border);"><td style="padding: 14px 8px;"><strong>Beleg-/Dokument-Sortierung</strong> · Mail-Anhänge → kategorisieren → ablegen → DATEV/Buchhaltung</td><td style="text-align: center;">M</td><td style="text-align: right; font-family: var(--font-display); font-size: 18px;">3.990 €</td></tr>
            <tr style="border-bottom: 1px solid var(--kz-border);"><td style="padding: 14px 8px;"><strong>Email-Befreiung</strong> · Vorsortierung, Standard-Antworten, Eskalations-Routing</td><td style="text-align: center;">M</td><td style="text-align: right; font-family: var(--font-display); font-size: 18px;">4.490 €</td></tr>
            <tr style="border-bottom: 1px solid var(--kz-border);"><td style="padding: 14px 8px;"><strong>Sales-Chat mit Frontend</strong> · Anfragen-Triage, Offert-Vorbereitung, eigenes Dashboard</td><td style="text-align: center;">L</td><td style="text-align: right; font-family: var(--font-display); font-size: 18px;">6.990 €</td></tr>
            <tr style="border-bottom: 1px solid var(--kz-border);"><td style="padding: 14px 8px;"><strong>Schicht-Genie</strong> · Personalplanung, Stundenberechnung, Kalender, Mail-Push</td><td style="text-align: center;">L</td><td style="text-align: right; font-family: var(--font-display); font-size: 18px;">8.990 €</td></tr>
            <tr><td style="padding: 14px 8px;"><strong>Voice-Agent</strong> · telefonische Auskunft, Termine, Erst-Triage <span style="color: var(--fg-muted); font-size: 13px;">(ab Q3 2026)</span></td><td style="text-align: center;">L</td><td style="text-align: right; font-family: var(--font-display); font-size: 18px;">9.990 €</td></tr>
          </tbody>
        </table>
      </div>

      <div style="padding: 32px; background: var(--kz-charcoal); color: var(--kz-cream); border-radius: 12px; margin: 32px 0;">
        <h3 class="kz-h3" style="margin-top: 0; color: var(--kz-cream);">Komplett-PA-Bundle</h3>
        <p style="margin: 8px 0 16px; color: rgba(245,240,232,0.85);">
          Ein S-Modul + ein M-Modul + ein L-Modul deiner Wahl. Der ganze KI-PA in einem Paket.
        </p>
        <div style="font-family: var(--font-display); font-size: 48px; line-height: 1; color: var(--kz-cream);">14.999 €</div>
        <div style="font-size: 14px; color: rgba(245,240,232,0.6); margin-top: 4px;">netto, statt rechnerisch ~17.470 € einzeln</div>
      </div>
    </section>

    <!-- RETAINER -->
    <section style="margin-top: 96px;">
      <h2 class="kz-h2">3. Retainer — der laufende Betrieb</h2>
      <p>
        Module sind nicht „bauen und tschüss". Sie laufen, brauchen Hosting, kleine Anpassungen, Monitoring. Der Retainer hält sie am Leben — drei Stufen je nach Modul-Anzahl.
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 16px; margin: 32px 0;">
        <div style="padding: 32px 24px; background: var(--kz-cream-deep); border-radius: 12px;">
          <h3 class="kz-h3" style="margin-top: 0;">Start</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">499 €</div>
          <div style="font-size: 13px; color: var(--fg-muted); margin-bottom: 20px;">pro Monat, netto</div>
          <ul style="font-size: 14px; padding-left: 18px;">
            <li>1 Modul im Betrieb</li>
            <li>Eigener Hetzner-Server</li>
            <li>Updates, Backups, Monitoring</li>
            <li>4h Anpassung pro Monat</li>
            <li>SLA: Reaktion &lt; 24h Werktags</li>
          </ul>
        </div>

        <div style="padding: 32px 24px; background: var(--kz-cream-deep); border-radius: 12px; border: 2px solid var(--kz-ember);">
          <h3 class="kz-h3" style="margin-top: 0;">Wachstum</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">799 €</div>
          <div style="font-size: 13px; color: var(--fg-muted); margin-bottom: 20px;">pro Monat, netto</div>
          <ul style="font-size: 14px; padding-left: 18px;">
            <li>2 Module im Betrieb</li>
            <li>8h Anpassung pro Monat</li>
            <li>Priority-Support</li>
            <li>SLA: Reaktion &lt; 24h Werktags</li>
            <li>Quartals-Review-Call</li>
          </ul>
        </div>

        <div style="padding: 32px 24px; background: var(--kz-cream-deep); border-radius: 12px;">
          <h3 class="kz-h3" style="margin-top: 0;">Voll</h3>
          <div style="font-family: var(--font-display); font-size: 36px; line-height: 1; margin: 12px 0 4px;">1.299 €</div>
          <div style="font-size: 13px; color: var(--fg-muted); margin-bottom: 20px;">pro Monat, netto</div>
          <ul style="font-size: 14px; padding-left: 18px;">
            <li>3+ Module im Betrieb</li>
            <li>16h Anpassung pro Monat</li>
            <li>SLA: Reaktion &lt; 12h Werktags</li>
            <li>Roadmap-Reviews</li>
            <li>Direkter Zugang per Telegram</li>
          </ul>
        </div>
      </div>

      <p style="font-size: 15px; color: var(--fg-muted);">
        <strong>Anpassung im Retainer</strong> = Prompt-Tweaks, Voice-Justierung, Bug-Behebung, Ergebnis-Verfeinerung. <strong>Nicht im Retainer:</strong> neue Module (= Setup-Preis) oder komplette Re-Architektur.
      </p>
    </section>

    <!-- CUSTOM -->
    <section style="margin-top: 64px;">
      <h2 class="kz-h2">Custom über Retainer-Stunden hinaus</h2>
      <ul>
        <li><strong>Stundensatz:</strong> 130 €/h, transparent abgerechnet</li>
        <li><strong>Erweiterungs-Modul-Festpreis:</strong> ab 990 € für klar abgegrenzte Mini-Use-Cases (neue Mail-Kategorie, neuer Workflow-Trigger, neue Datenquelle anbinden)</li>
      </ul>
      <p>Du wählst den Modus, der für deinen Fall passt — Festpreis-Sicherheit oder Stunden-Flexibilität.</p>
    </section>

    <!-- FÖRDERUNGEN -->
    <section style="margin-top: 64px; padding: 40px clamp(24px, 4vw, 48px); background: var(--kz-cream-deep); border-radius: 12px;">
      <h2 class="kz-h2" style="margin-top: 0;">Förderungen — bis zu 50% Zuschuss</h2>
      <p>Für KMU in DACH gibt es konkrete Programme, die einen Großteil des Setup-Preises übernehmen:</p>
      <ul>
        <li><strong>Deutschland — go-digital:</strong> bis 17.000 € förderfähig, 50% Zuschuss vom Bundesministerium für Wirtschaft</li>
        <li><strong>Österreich — KMU.Digital:</strong> bis 8.000 € (50% Zuschuss). Plus aws AI-Start bis 15.000 €</li>
      </ul>
      <p style="margin-top: 16px;">
        <strong>Ehrlich gesagt:</strong> k-AIzen ist aktuell <em>noch nicht</em> akkreditierter Berater unter diesen Programmen — das ist ein Phase-2-Thema (BAFA-Akkreditierung dauert 12–18 Monate). Was wir heute schon machen: dir helfen, einen akkreditierten Berater für die Antragsbegleitung zu finden, oder die technische Lieferung in Kombination mit einem Beratungs-Partner abwickeln.
      </p>
    </section>

    <!-- FAQ -->
    <section style="margin-top: 96px;">
      <h2 class="kz-h2">FAQ</h2>

      <details style="border-top: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Warum bezahltes Audit statt kostenloser Beratung?</summary>
        <p style="margin-top: 16px;">
          Wer ein Audit bezahlt, will wirklich Klarheit. Wer kostenlose Beratung will, will oft eine Visitenkarten-Sammlung. Die 1.490 € sind der Preis für einen Tag Beobachtung plus Roadmap. Bei Buchung eines Setups innerhalb 30 Tagen werden 50% angerechnet — du verlierst nichts wenn du weitermachst.
        </p>
      </details>

      <details style="border-top: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Was ist die Stage-Gate-Mechanik?</summary>
        <p style="margin-top: 16px;">
          Wenn du nach dem Audit innerhalb 30 Tagen ein Setup-Paket buchst, ziehen wir 50% des Audit-Preises vom Setup ab. Ein Audit für 1.490 € reduziert das Setup also um 745 €. Wer nur den Audit will, zahlt voll. Wer weitermacht, kriegt einen rationalen Anreiz.
        </p>
      </details>

      <details style="border-top: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Was ist im Modul-Festpreis drin?</summary>
        <p style="margin-top: 16px;">
          Setup, Tests, Übergabe-Doku, dein eigener Hetzner-Server, OAuth-Integration in deinen Tool-Stack (M365, Google, ERP, CRM). Vier Wochen Begleit-Betrieb. Kein Stunden-Tracking, keine versteckten Sub-Kosten.
        </p>
      </details>

      <details style="border-top: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Was ist im Retainer drin — und was nicht?</summary>
        <p style="margin-top: 16px;">
          <strong>Drin:</strong> Hosting, Updates, Backups, Monitoring, Anpassungs-Stunden (4/8/16h je Stufe), SLA. <strong>Nicht drin:</strong> neue Module (= neuer Setup-Preis) und komplette Re-Architekturen. Anpassung heißt Prompt-Tweaks, Voice-Justierung, Bug-Behebung, Ergebnis-Verfeinerung — nicht „neuer Workflow von null".
        </p>
      </details>

      <details style="border-top: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Was passiert bei Kündigung? Bin ich gelocked-in?</summary>
        <p style="margin-top: 16px;">
          Nein. Drei-Klick-Übergabe: Hetzner-Account auf dich transferieren, Tailscale-Zugang dir geben, DNS umstellen. Innerhalb 5 Werktagen bist du komplett unabhängig. Code, Workflows, Daten — alles deins. „Kein Lock-in" ist eines unserer drei Manifest-Prinzipien — nicht nur Marketing.
        </p>
      </details>

      <details style="border-top: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Gibt es Förderungen?</summary>
        <p style="margin-top: 16px;">
          Ja. In Deutschland <strong>go-digital</strong> bis 17.000 € (50% Zuschuss). In Österreich <strong>KMU.Digital</strong> bis 8.000 € und <strong>aws AI-Start</strong> bis 15.000 €. k-AIzen ist aktuell noch nicht akkreditierter Berater — wir können dir aber helfen, einen zu finden, oder begleiten den Antrag in Kombination mit einem Partner. Phase-2-Thema bei uns.
        </p>
      </details>

      <details style="border-top: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Stundensatz für Custom-Arbeit?</summary>
        <p style="margin-top: 16px;">
          130 €/h für alles, was über die Retainer-Stunden hinausgeht. Alternativ: <strong>Erweiterungs-Modul-Festpreis ab 990 €</strong> für klar abgegrenzte Mini-Use-Cases (neue Mail-Kategorie, neuer Workflow-Trigger, neue Datenquelle anbinden). Du wählst.
        </p>
      </details>

      <details style="border-top: 1px solid var(--kz-border); border-bottom: 1px solid var(--kz-border); padding: 24px 0;">
        <summary style="cursor: pointer; font-family: var(--font-display); font-size: 22px; font-weight: 400;">Was ist mit Datenschutz und EU-Hosting?</summary>
        <p style="margin-top: 16px;">
          Pro Kunde ein <strong>dedizierter Hetzner-Server</strong> in Nürnberg oder Helsinki — kein Multi-Tenant, keine geteilten Datenbanken. DSGVO-konform ab Tag 1, Auftragsverarbeitungsvertrag inklusive. Wer mehr Souveränität will: <strong>On-Premise</strong> mit lokalem Llama- oder Mistral-Modell statt Claude API. Daten verlassen deinen Server nie.
        </p>
      </details>
