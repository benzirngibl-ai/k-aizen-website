const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "k-AIzen",
  "url": SITE_URL,
  "description": DESCRIPTION,
  "inLanguage": "de-DE",
  "publisher": {
    "@type": "Organization",
    "name": "k-AIzen / Pulscraft Digital",
    "url": SITE_URL
  }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "k-AIzen — AI-Workflow-Automation",
  "url": SITE_URL,
  "image": OG_IMAGE,
  "telephone": "",
  "priceRange": "€€",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "DE",
    "addressRegion": "Bayern"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Deutschland"
  },
  "serviceType": "KI-Workflow-Automation für KMU",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "k-AIzen Angebot",
    "itemListElement": [
      { "@type": "Offer", "name": "Discovery-Audit Standard", "price": "1490", "priceCurrency": "EUR", "itemOffered": { "@type": "Service", "name": "Discovery-Audit", "description": "1 Tag remote, 3 Mitarbeiter-Interviews, kundenspezifischer PDF-Report binnen 5 Werktagen, 1h Follow-up." } },
      { "@type": "Offer", "name": "Modul S — Audio→Protokoll", "price": "2490", "priceCurrency": "EUR" },
      { "@type": "Offer", "name": "Modul M — Email-Befreiung", "price": "4490", "priceCurrency": "EUR" },
      { "@type": "Offer", "name": "Modul L — Schicht-Genie", "price": "8990", "priceCurrency": "EUR" },
      { "@type": "Offer", "name": "Komplett-PA-Bundle", "price": "14999", "priceCurrency": "EUR", "itemOffered": { "@type": "Service", "name": "KI-PA Bundle", "description": "Ein S-, ein M- und ein L-Modul gebündelt — der KI-PA für deinen Betrieb." } },
      { "@type": "Offer", "name": "Retainer Wachstum", "price": "799", "priceCurrency": "EUR", "priceSpecification": { "@type": "UnitPriceSpecification", "price": "799", "priceCurrency": "EUR", "unitText": "pro Monat" } }
