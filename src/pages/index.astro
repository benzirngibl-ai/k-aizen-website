  "@type": "ProfessionalService",
  "name": "k-AIzen — AI-Workflow-Automation",
  "url": SITE_URL,
  "image": OG_IMAGE,
  "telephone": "+49-1590-1031928",
  "priceRange": "€€",
  "address": {
