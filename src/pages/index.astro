---

<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <!-- SEO -->
  <title>{TITLE}</title>
  <meta name="description" content={DESCRIPTION} />
  <link rel="canonical" href={SITE_URL} />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="author" content="Benjamin Zirngibl · k-AIzen" />
  <meta name="keywords" content="AI Workflow Automation, KMU AI, Mittelstand Automation, Inbox-Triage, Angebots-Generator, n8n, Workflow-Engineering, DSGVO AI, Bayern AI Agency, k-AIzen, Benjamin Zirngibl" />
  <meta name="theme-color" content="#F5F0E8" />

  <!-- OpenGraph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={TITLE} />
  <meta property="og:description" content={DESCRIPTION} />
  <meta property="og:url" content={SITE_URL} />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:image:alt" content="k-AIzen Logo" />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:site_name" content="k-AIzen" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={TITLE} />
  <meta name="twitter:description" content={DESCRIPTION} />
  <meta name="twitter:image" content={OG_IMAGE} />

  <!-- AI Crawlers — explizit erlaubt -->
  <meta name="GPTBot" content="index, follow" />
  <meta name="ClaudeBot" content="index, follow" />
  <meta name="Claude-Web" content="index, follow" />
  <meta name="PerplexityBot" content="index, follow" />
  <meta name="Applebot" content="index, follow" />
  <meta name="Google-Extended" content="index, follow" />

  <!-- Hreflang -->
  <link rel="alternate" hreflang="de" href={SITE_URL} />
  <link rel="alternate" hreflang="x-default" href={SITE_URL} />

  <link rel="icon" type="image/png" href="/animations/claude-design/logo-mark.png" />
  <link rel="apple-touch-icon" href="/animations/claude-design/logo-mark.png" />
  <link rel="manifest" href="/manifest.webmanifest" />

  <!-- Preconnect für Critical-Path-Performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://unpkg.com" crossorigin />

  <!-- Preload Critical-Above-Fold Assets -->
  <link rel="preload" as="image" href="/animations/claude-design/logo-full.png" />
  <link rel="preload" as="image" href="/animations/claude-design/sumi-mountains.png" />

  <link rel="stylesheet" href="/preview/colors_and_type.css?v=20260528-younglena-v3" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--bg);
      overscroll-behavior: none;
    }
    #root { isolation: isolate; }

    @keyframes kz-fade-up {
      from { transform: translateY(14px); }
      to   { transform: translateY(0); }
    }
    @keyframes kz-scroll-line {
      0%   { transform: scaleY(0); transform-origin: top; }
      40%  { transform: scaleY(1); transform-origin: top; }
      60%  { transform: scaleY(1); transform-origin: bottom; }
      100% { transform: scaleY(0); transform-origin: bottom; }
    }

    section { user-select: none; -webkit-user-select: none; }

    /* Server-Side rendered fallback content für Crawlers + initial paint */
    .kz-noscript-fallback {
      max-width: 1180px;
      margin: 0 auto;
      padding: clamp(60px, 10vh, 120px) clamp(24px, 5vw, 48px);
    }
    .kz-noscript-fallback h1 {
      font-family: var(--font-display);
      font-size: clamp(40px, 6vw, 80px);
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin: 0 0 24px;
    }
    .kz-noscript-fallback .accent {
      color: var(--kz-ember);
      font-style: italic;
    }
    .kz-noscript-fallback p {
      font-family: var(--font-sans);
      font-size: 18px;
      line-height: 1.6;
      color: var(--fg-muted);
      max-width: 640px;
    }
    .kz-noscript-fallback ul {
      font-family: var(--font-sans);
      max-width: 640px;
      padding-left: 0;
      list-style: none;
    }
    .kz-noscript-fallback li {
      position: relative;
      padding-left: 22px;
      margin-bottom: 8px;
    }
    .kz-noscript-fallback li::before {
      content: "";
      position: absolute;
      left: 0; top: 12px;
      width: 12px; height: 1px;
      background: var(--kz-ember);
    }
    .kz-noscript-fallback a {
      color: var(--kz-ember-text);
      text-decoration: underline;
    }
    /* Hide fallback when React mounts */
    #root:not(:empty) ~ .kz-noscript-fallback { display: none; }
  </style>
</head>
<body>
  <div id="root"></div>

  <!-- SEO/AI-Crawler Fallback — sichtbar bevor React mountet, hidden danach.
       Stellt sicher dass Suchmaschinen + AI-Tools die Inhalte indexieren können
       auch wenn JavaScript-Rendering fehlschlägt oder langsam ist. -->
  <noscript>
    <article class="kz-noscript-fallback">
      <h1>Jeden Tag 1% besser. <span class="accent">Mit KI.</span></h1>
      <p>
        Ich bin Benjamin Zirngibl, dein persönlicher KI-Bauer für sichtbare Prozess-Automatisierung im Mittelstand.
        Kein Workshop-Zirkus, kein Konzern-Theater. Ein Mensch, der baut. Ein Stack, der dir gehört.
        Eine Lösung, die am Montagmorgen läuft. 7 Jahre Mobility-Praxis bei SKIDATA, eigener Stack auf Hetzner, kein Lock-in.
      </p>

      <h2>Drei Prinzipien</h2>
      <ul>
        <li><strong>Preise offen statt „auf Anfrage"</strong> — jeder Festpreis steht auf dieser Seite</li>
        <li><strong>Übergebbar statt Vertrags-Knebel</strong> — dein Server, deine Workflows, dein Code. Übergabe in 5 Werktagen</li>
        <li><strong>Liefern statt Workshops</strong> — Tools, die nach dem Projekt laufen. Erfolg in gesparten Stunden</li>
      </ul>

      <h2>Drei Stufen, Festpreise</h2>
      <ul>
        <li><a href="/audit">Discovery-Audit</a> — ab 1.190 € · 1 Tag · Lieferung in 5 Werktagen mit Roadmap</li>
        <li><a href="/ki-pa">KI-PA Tier 1 (Autonom)</a> — 10.299 € Setup + 1.029 €/Mo · oder SaaS-Style 1.899 €/Mo Y1</li>
        <li><a href="/ki-pa">KI-PA Tier 2 (+ Concierge)</a> — 12.999 € + 1.529 €/Mo · Mensch übernimmt was KI nicht kann</li>
        <li><a href="/pricing">Add-on-Module</a> — Voice-Empfangsdame, Content-Maschine, Beleg-Modul ab 999 € Setup</li>
      </ul>

      <h2>Methodik — Beobachten statt Beraten</h2>
      <p>
        Während andere KI-Strategien in PowerPoint diskutieren, beobachte ich einen Tag in deinem Büro.
        Ich gucke deiner Buchhalterin über die Schulter, deinem Vertriebsleiter, deinem Chef.
        Dann baue ich genau das Tool, das die Klick-Routine wegnimmt — sichtbares Ergebnis in Wochen.
      </p>

      <h2>Vertrauen</h2>
      <ul>
        <li>EU-Datenhaltung — dedizierter Hetzner-Server in Deutschland</li>
        <li>DSGVO-konform ab Tag 1 — Auftragsverarbeitungsvertrag schriftlich vor Projektstart</li>
        <li>On-Prem-Option — komplette Lösung mit Open-Source-Modellen (Llama, Mistral) auf eigener Infrastruktur</li>
        <li>Transparente Tool-Wahl — keine Provisionen, schriftliche Begründung</li>
      </ul>

      <h2>Mehr</h2>
      <ul>
        <li><a href="/about">Über mich — Hands-On-Bauer statt KI-Theoretiker</a></li>
        <li><a href="/audit">Audit buchen</a></li>
        <li><a href="/pricing">Alle Preise &amp; Module</a></li>
        <li><a href="/kontakt">Kontakt</a> — kontakt@k-aizen.de · WhatsApp · LinkedIn</li>
        <li><a href="/erstgespraech">30-Min-Kennenlern-Call (gratis)</a></li>
      </ul>
    </article>
  </noscript>

  <script is:inline src="https://unpkg.com/react@18.3.1/umd/react.production.min.js"></script>
  <script is:inline src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.production.min.js"></script>
  <script is:inline src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js"></script>

  <script is:inline src="/preview/petal-system.js?v=20260528-younglena-v3"></script>
  <script is:inline type="text/babel" src="/preview/tweaks-panel.jsx?v=20260528-younglena-v3"></script>
  <script is:inline type="text/babel" src="/preview/sections.jsx?v=20260528-younglena-v3"></script>
  <script is:inline type="text/babel" src="/preview/hero.jsx?v=20260528-younglena-v3"></script>

  <!-- Chatbot Widget -->
  <script is:inline>
    window.KAIZEN_BOT_URL = window.KAIZEN_BOT_URL || (
      location.hostname === 'localhost' || location.hostname === '127.0.0.1'
        ? 'http://localhost:4123/chat'
        : 'https://chat.k-aizen.de/chat'
    );
  </script>
  <script is:inline src="/widgets/chatbot.js?v=20260528-younglena-v3" defer></script>
</body>
</html>
