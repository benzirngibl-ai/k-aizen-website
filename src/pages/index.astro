    "DSGVO-konforme KI-Architektur",
    "On-Premise LLM (Llama, Mistral)",
    "Hetzner-Cloud-Infrastruktur",
    "Per-Kunde-Server-Pattern"
  ],
  "sameAs": [
    "https://www.linkedin.com/in/benjamin-zirngibl-0963753ab",
    "https://github.com/benzirngibl-ai"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "kontakt@k-aizen.de",
    "telephone": "+49-1590-1031928",
    "contactType": "customer service",
    "areaServed": "DE",
    "availableLanguage": ["German", "English"]
  }
