      { "@type": "Offer", "name": "Modul Social", "itemOffered": { "@type": "Service", "name": "Social", "description": "Dazubuchbares Modul: Content-Erstellung und Social-Media-Betreuung." } },
      { "@type": "Offer", "name": "Modul Lead-Pipeline", "itemOffered": { "@type": "Service", "name": "Lead-Pipeline", "description": "Dazubuchbares Modul: Lead-Recherche, Qualifizierung und Outreach." } },
      { "@type": "Offer", "name": "Modul Beleg & Steuer", "itemOffered": { "@type": "Service", "name": "Beleg & Steuer", "description": "Dazubuchbares Modul: Beleg-Erfassung und steuerliche Vorbereitung." } },
      { "@type": "Offer", "name": "Modul Recruiting", "itemOffered": { "@type": "Service", "name": "Recruiting", "description": "Dazubuchbares Modul: Bewerber-Sichtung und Recruiting-Workflows." } }
