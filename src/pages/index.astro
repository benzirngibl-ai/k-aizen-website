      { "@type": "Offer", "name": "Voice-Empfangsdame (Add-on)", "price": "9999", "priceCurrency": "EUR", "itemOffered": { "@type": "Service", "name": "Voice-Empfangsdame", "description": "Eigene Firmen-Telefonnummer. KI nimmt Anrufe entgegen, beantwortet FAQs, vereinbart Termine." } },
