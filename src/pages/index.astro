---
// k-AIzen — Cinematic Light Premium (Nordstern-Positionierung).
// Seit 2026-07-03 die Startseite (war zuvor /v2). Vorgänger: old-index.astro.
const benFoto = "/images/ben-portrait.png";
const siteUrl = "https://k-aizen.de";
const homeUrl = `${siteUrl}/`;
const homeTitle = "k-AIzen — Ihr KI-Ansprechpartner im Unternehmen";
const homeDescription = "Ein fester KI-Ansprechpartner für Ihr Unternehmen. Start mit dem KI-Personal-Assistant für Mail, Kalender, Aufgaben und Kontext — danach Schritt für Schritt Automatisierung und System.";
const ogImage = `${siteUrl}/og-image.png`;
const asyncMail = `mailto:kontakt@k-aizen.de?subject=${encodeURIComponent("KI-PA Kurzcheck")}&body=${encodeURIComponent(`Hi Ben,

ich möchte erst einmal async prüfen, ob k-AIzen für uns passt.

1. Branche / Teamgröße:
2. Wo verlieren wir gerade Zeit?
3. Welche Systeme nutzen wir? (z. B. Microsoft 365, Teams, Slack, Notion, CRM, Excel)

Beste Grüße`)}`;

import { getCollection } from 'astro:content';

// Funktionen-Grid (ehem. "Ein Tag mit Lena") — Kacheln kommen aus der funktionen-Collection.
// Neue Funktion sichtbar machen = neue Datei in src/content/funktionen/, kein Code.
const funktionenListe = (await getCollection('funktionen'))
  .filter((f) => !f.data.draft)
  .sort((a, b) => a.data.reihenfolge - b.data.reihenfolge)
  .slice(0, 6);

const ablaufSchritte = [
  {
    k: "01",
    title: "Erstgespräch",
    text: "30 Minuten: Wir schauen, ob KI bei Ihnen gerade wirklich Sinn macht und wo der erste Hebel liegt.",
  },
  {
    k: "02",
    title: "KI-Check",
    text: "Wir prüfen Mails, Kalender, Aufgaben, wiederkehrende Entscheidungen und Datenquellen. Danach ist klar, was zuerst gebaut wird.",
  },
  {
    k: "03",
    title: "KI-PA einrichten",
    text: "Der Assistent bekommt freigegebene Quellen, Regeln, Tonalität und klare Grenzen. Erst Vorschläge, dann Freigabe.",
  },
  {
    k: "04",
    title: "System ausbauen",
    text: "Wenn der Einstieg trägt, automatisieren wir Schritt für Schritt weitere Abläufe: Telefon, Belege, Leads, Wissen, interne Prozesse.",
  },
];

const fitCards = [
  {
    k: "Gut geeignet, wenn",
    title: "Sie KI pragmatisch in Abläufe bringen wollen.",
    items: [
      "Mails, Termine, Aufgaben oder Wissen ziehen im Alltag sichtbar Energie.",
      "Sie wollen klein starten, aber sauber genug für späteren Ausbau.",
      "Sie brauchen jemanden, der Technik, Alltag und Verantwortung zusammenhält.",
    ],
  },
  {
    k: "Eher nicht geeignet, wenn",
    title: "Sie sofort Vollautomatik ohne gemeinsame Grundlagen erwarten.",
    items: [
      "Niemand darf Quellen freigeben, Regeln klären oder Feedback geben.",
      "Es soll nur ein Chatbot auf die Website, aber kein interner Ablauf besser werden.",
      "Einmal eingerichtet und nie wieder betreut ist wichtiger als ein lernendes System.",
    ],
  },
];

const entscheidungsPunkte = [
  {
    k: "Nach 30 Minuten",
    title: "Passend oder nicht passend",
    text: "Sie wissen, ob KI-PA, KI-Check, Pilot oder vorerst kein Projekt der richtige nächste Schritt ist.",
  },
  {
    k: "Nach dem KI-Check",
    title: "Priorisierte Roadmap",
    text: "Quellen, erster Use Case, Risiken, No-Gos und grobe Kosten liegen als Arbeitsgrundlage vor.",
  },
  {
    k: "Nach 14 Tagen Pilot",
    title: "Erste echte Artefakte",
    text: "Briefings, Antwortentwürfe, Freigabeliste oder Ablaufkarte zeigen, ob es im Alltag trägt.",
  },
  {
    k: "Nach 8 Wochen",
    title: "Ausbauentscheidung",
    text: "Dann wird nicht aus Hoffnung erweitert, sondern weil der erste Bereich sichtbar geholfen hat.",
  },
];

const proofPunkte = [
  {
    title: "Echte Quellen",
    text: "Antworten und Briefings entstehen aus freigegebenen Quellen: Mailverlauf, Kalender, Aufgaben, Kundennotizen oder CRM.",
  },
  {
    title: "Freigabe statt Blindflug",
    text: "Sensible Dinge werden vorbereitet, nicht heimlich verschickt. Sie sehen Vorschlag, Kontext und offene Fragen.",
  },
  {
    title: "Greifbare Artefakte",
    text: "Nach kurzer Zeit liegen keine Versprechen vor, sondern Briefings, Antwortentwürfe, Freigabelisten und Ablaufkarten.",
  },
  {
    title: "Saubere Basis",
    text: "Getrennte Kundenumgebungen, dokumentierte Entscheidungen und Datenschutz von Anfang an mitgedacht.",
  },
];

const proofArtefakte = [
  {
    k: "Report",
    title: "KI-Check mit Prioritäten",
    text: "Eine kurze Roadmap: welche Quelle zuerst angebunden wird, welche Aufgabe sich lohnt und was bewusst noch nicht automatisiert wird.",
    bullets: ["Ist-Zustand", "erste 3 Hebel", "Risiken + No-Gos"],
  },
  {
    k: "Arbeitskanal",
    title: "Ein Ort für Vorschläge",
    text: "Briefings, Rückfragen und Freigaben landen nicht irgendwo, sondern in einem klaren Kanal mit Status und Kontext.",
    bullets: ["#posteingang", "#freigaben", "#wissen"],
  },
  {
    k: "Regeln",
    title: "Freigabe-Matrix",
    text: "Schwarz auf weiß: Was darf die KI vorbereiten, was braucht Prüfung, was bleibt grundsätzlich beim Menschen.",
    bullets: ["darf vorbereiten", "muss fragen", "darf nie senden"],
  },
  {
    k: "Doku",
    title: "Übergabefähiges System",
    text: "Quellen, Abläufe, Jobs und Entscheidungen werden dokumentiert, damit das Setup nicht nur in meinem Kopf existiert.",
    bullets: ["Quellenliste", "Ablaufkarte", "Betriebsnotizen"],
  },
];

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#organization`,
      "name": "k-AIzen",
      "url": homeUrl,
      "logo": `${siteUrl}/icons/kaizen-favicon.png`,
      "image": ogImage,
      "email": "kontakt@k-aizen.de",
      "founder": { "@id": `${siteUrl}/#benjamin-zirngibl` },
      "areaServed": ["DE", "AT", "CH"],
      "description": "k-AIzen ist der externe KI-Ansprechpartner für kleine und mittelständische Unternehmen. Einstieg ist der KI-Personal-Assistant für Mail, Kalender, Aufgaben, Kontext und Freigaben.",
      "knowsAbout": [
        "KI Beratung KMU",
        "KI Assistent Unternehmen",
        "KI Automatisierung Mittelstand",
        "Microsoft 365 KI Integration",
        "KI Mail Assistent Firma",
        "Kaizen OS"
      ]
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#benjamin-zirngibl`,
      "name": "Benjamin Zirngibl",
      "url": `${siteUrl}/about`,
      "image": `${siteUrl}${benFoto}`,
      "jobTitle": "Gründer und KI-Ansprechpartner",
      "worksFor": { "@id": `${siteUrl}/#organization` },
      "sameAs": ["https://www.linkedin.com/in/benjamin-zirngibl-0963753ab"]
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": homeUrl,
      "name": "k-AIzen",
      "inLanguage": "de-DE",
      "publisher": { "@id": `${siteUrl}/#organization` },
      "about": { "@id": `${siteUrl}/#ki-pa-service` }
    },
    {
      "@type": "Service",
      "@id": `${siteUrl}/#ki-pa-service`,
      "name": "KI-Personal-Assistant (KI-PA) für Unternehmen",
      "serviceType": "KI-Assistent und KI-Automatisierung für KMU",
      "provider": { "@id": `${siteUrl}/#organization` },
      "areaServed": ["DE", "AT", "CH"],
      "description": "Betreuter KI-Assistent für Mail, Kalender, Aufgaben, Kundennotizen, Kontext, Freigaben und schrittweisen Ausbau zu einem internen KI-System.",
      "audience": {
        "@type": "BusinessAudience",
        "audienceType": "kleine und mittelständische Unternehmen"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "k-AIzen Einstieg",
        "itemListElement": [
          { "@type": "Offer", "name": "Kostenloses Erstgespräch", "url": `${siteUrl}/erstgespraech` },
          { "@type": "Offer", "name": "Kostenloser KI-Check", "url": `${siteUrl}/audit` },
          { "@type": "Offer", "name": "KI-PA Setup", "url": `${siteUrl}/pricing` }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "@id": `${siteUrl}/#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Woher weiß der KI-Personal-Assistant, was beim Kunden wichtig ist?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Der KI-PA arbeitet nur mit freigegebenen Quellen wie Mailverlauf, Kalender, Aufgabenlisten, CRM, Kundennotizen oder Microsoft 365. Fehlender oder unsicherer Kontext wird sichtbar gemacht."
          }
        },
        {
          "@type": "Question",
          "name": "Startet k-AIzen sofort mit Vollautomatisierung?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nein. Der Einstieg ist bewusst klein: Erstgespräch, kostenloser KI-Check oder begrenzter KI-PA-Pilot. Erst wenn der Nutzen sichtbar ist, werden weitere Abläufe angeschlossen."
          }
        },
        {
          "@type": "Question",
          "name": "Kann k-AIzen mit bestehenden Systemen arbeiten?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja. k-AIzen kann an Microsoft 365, Teams, SharePoint, Slack, Notion, CRM, Excel-Listen oder eigene Systeme andocken und bei Bedarf ein eigenes Kaizen OS darum bauen."
          }
        },
        {
          "@type": "Question",
          "name": "Wann passt k-AIzen nicht?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "k-AIzen passt weniger, wenn sofort Vollautomatik ohne Freigaben, Quellenklärung oder Feedback erwartet wird. Der Ansatz beginnt bewusst mit einem begrenzten Bereich und menschlicher Kontrolle."
          }
        }
      ]
    }
  ]
};
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{homeTitle}</title>
  <meta name="description" content={homeDescription} />
  <link rel="canonical" href={homeUrl} />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="author" content="Benjamin Zirngibl · k-AIzen" />
  <meta name="theme-color" content="#FCFCFD" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={homeTitle} />
  <meta property="og:description" content={homeDescription} />
  <meta property="og:url" content={homeUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:site_name" content="k-AIzen" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={homeTitle} />
  <meta name="twitter:description" content={homeDescription} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="GPTBot" content="index, follow" />
  <meta name="ClaudeBot" content="index, follow" />
  <meta name="Claude-Web" content="index, follow" />
  <meta name="PerplexityBot" content="index, follow" />
  <meta name="Applebot" content="index, follow" />
  <link rel="icon" type="image/png" href="/icons/kaizen-favicon.png" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="apple-touch-icon" href="/icons/kaizen-favicon.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt" />
  <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLMs Full" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/v2/kz-v2.css?v=7" />
  <link rel="stylesheet" href="/v2/kz-v2-polish.css?v=7" />
  <script type="application/ld+json" set:html={JSON.stringify(homeSchema)} />
</head>
<body>

  <!-- Scroll-Progress -->
  <div class="kz-progress"></div>

  <!-- NAV -->
  <nav class="kz-nav">
    <div class="kz-nav__brand">
      <img src="/animations/claude-design/logo-mark.png" alt="" class="kz-logo-mark" />
      <span class="kz-logo">k&#8209;<span class="kz-logo__ai">AI</span>zen</span>
    </div>
    <div class="kz-nav__links">
      <a href="#angebot">Angebot</a>
      <a href="#ablauf">Ablauf</a>
      <a href="#ein-tag">Funktionen</a>
      <a href="#proof">Proof</a>
      <a href="#kontakt">Kontakt</a>
    </div>
    <a href="/erstgespraech" class="kz-btn kz-btn--primary" style="padding:11px 22px;font-size:14px;">Erstgespräch</a>
  </nav>

  <!-- HERO -->
  <header class="kz-hero">
    <div class="kz-hero__grid"></div>
    <div class="kz-wrap">
      <div class="kz-hero__eyebrow kz-reveal"><span class="dot"></span> Ihr KI-Ansprechpartner im Unternehmen</div>
      <h1 class="kz-h1 kz-kinetic">Ein fester Ansprechpartner für KI — <span class="accent">startend mit Ihrem KI-Personal-Assistant.</span></h1>
      <p class="kz-hero__sub kz-reveal" data-delay="2">
        So wie größere Firmen klare Verantwortliche für Datenschutz haben, bekommt Ihr Betrieb einen Ansprechpartner für KI. Der Einstieg ist der KI-Personal-Assistant, kurz KI-PA: für Mail, Termine, Aufgaben, Freigaben und Kontext. Danach wird Schritt für Schritt erweitert, wenn der erste Bereich sichtbar trägt.
      </p>
      <div class="kz-hero__cta kz-reveal" data-delay="3">
        <a href="/erstgespraech" class="kz-btn kz-btn--primary">Kostenloses Erstgespräch buchen <span class="kz-btn__arrow">→</span></a>
        <a href={asyncMail} class="kz-btn kz-btn--ghost">3-Fragen-Check per Mail</a>
        <a href="#angebot" class="kz-btn kz-btn--ghost">Angebot ansehen</a>
      </div>
    </div>
    <div class="kz-scrollcue">
      <span>Scroll</span>
      <span class="kz-scrollcue__line"></span>
    </div>
  </header>

  <!-- 2 — DAS PROBLEM (Spiegel) -->
  <section class="kz-section">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Das Dilemma</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">
        „KI wird wichtig. Aber wer soll das bei uns eigentlich verantworten?"
      </h2>
      <p class="kz-lead kz-reveal" data-delay="2">
        Tools testen reicht nicht. Irgendjemand muss verstehen, wo Zeit verloren geht, welche Daten ran dürfen, welche Antworten freigegeben werden müssen und wie daraus ein funktionierendes System entsteht. Genau diese Verantwortung bleibt in vielen Betrieben liegen.
      </p>
    </div>
  </section>

  <!-- 3 — REFRAME: all in vs all in -->
  <section class="kz-section" style="background:var(--paper-2);">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Auf Augenhöhe</span>
      <div class="kz-duo-grid">
        <div class="kz-reveal" data-delay="1">
          <div class="kz-split-card" data-tilt>
            <div class="kz-split-num">01</div>
            <h3 style="font-size:1.5rem;font-weight:700;margin-bottom:8px;">Ihr Betrieb</h3>
            <p style="color:var(--slate);">Sie kennen Ihr Handwerk. Ihr Lebenswerk. Niemand kennt Ihren Betrieb so wie Sie.</p>
          </div>
        </div>
        <div class="kz-reveal" data-delay="2">
          <div class="kz-split-card kz-split-card--accent" data-tilt>
            <div class="kz-split-num">02</div>
            <h3 style="font-size:1.5rem;font-weight:700;margin-bottom:8px;">k-AIzen</h3>
            <p style="color:rgba(255,255,255,0.85);">k-AIzen übernimmt die KI-Rolle: sinnvolle Einsatzfelder prüfen, den ersten Assistenten bauen und daraus Schritt für Schritt bessere Abläufe entwickeln.</p>
          </div>
        </div>
      </div>
      <p class="kz-lead kz-reveal" data-delay="3" style="margin-top:48px;text-align:center;margin-inline:auto;">
        Der Einstieg ist bewusst klein genug, um ihn zu verstehen — aber so gebaut, dass er später wachsen kann.
      </p>
    </div>
  </section>

  <!-- 3.5 — ZAHLEN-BAND (Rhythmus + Greifbarkeit) -->
  <section class="kz-section" style="padding-block:0;">
    <div class="kz-wrap">
      <div class="kz-stats kz-reveal">
        <div class="kz-stat">
          <div class="kz-stat__num" data-count="1" data-suffix="">0</div>
          <div class="kz-stat__label">fester KI-Ansprechpartner, der Ihren Betrieb kennt</div>
        </div>
        <div class="kz-stat">
          <div class="kz-stat__num" data-count="30" data-suffix=" Min">0</div>
          <div class="kz-stat__label">kostenloses Erstgespräch als sauberer Einstieg</div>
        </div>
        <div class="kz-stat">
          <div class="kz-stat__num" data-count="4" data-suffix="">0</div>
          <div class="kz-stat__label">Startbereiche: Mail, Kalender, Aufgaben, Wissen</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3.6 — ANGEBOT -->
  <section class="kz-section" id="angebot">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Das Angebot</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">Der erste Schritt ist nicht „die ganze Firma automatisieren".</h2>
      <p class="kz-lead kz-reveal" data-delay="2">
        Der erste Schritt ist ein persönlicher KI-Assistent, der an echten Stellen hilft: Mail, Kalender, Aufgaben, Freigaben und Kontext. So bekommt Ihr Betrieb einen greifbaren Einstieg in KI, ohne dass Sie selbst zum Tool-Manager werden.
      </p>

      <div class="kz-offer kz-reveal" data-delay="3">
        <div class="kz-offer__main">
          <div class="kz-offer__label">Einstieg</div>
          <h3>KI-PA + persönlicher KI-Ansprechpartner</h3>
          <p>
            Der Assistent wird mit Ihnen eingerichtet, nutzt nur freigegebene Quellen und liefert Vorschläge mit nachvollziehbarem Kontext.
          </p>
          <ul class="kz-checklist">
            <li>Mailverlauf, Kalender, Aufgaben und Kundennotizen als freigegebene Quellen.</li>
            <li>Tagesbriefing, Antwortentwürfe, Freigaben und Erinnerungen für den Alltag.</li>
            <li>Regeln, Tonalität und Grenzen, damit nichts unkontrolliert nach außen geht.</li>
            <li>Laufende Weiterentwicklung, wenn der erste Assistent im Alltag trägt.</li>
          </ul>
        </div>
        <aside class="kz-offer__side">
          <div class="kz-offer__side-k">Nächster Schritt</div>
          <h3>30 Minuten Erstgespräch</h3>
          <p>Wir nehmen Ihren Alltag durch. Am Ende steht keine Pflicht zum Kauf, sondern eine klare Empfehlung: nicht passend, KI-Check, Pilot oder KI-PA.</p>
          <a href="/erstgespraech" class="kz-btn kz-btn--primary">Erstgespräch buchen <span class="kz-btn__arrow">→</span></a>
          <a href={asyncMail} class="kz-offer__link">Lieber 3 Fragen per Mail schicken</a>
          <a href="/ki-pa" class="kz-offer__link">Mehr zum KI-PA verstehen</a>
        </aside>
      </div>
    </div>
  </section>

  <!-- 3.65 — FIT FILTER -->
  <section class="kz-section kz-fit-section">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Schneller Fit-Check</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">Nicht jeder Betrieb braucht jetzt ein KI-Projekt. Genau deshalb starten wir klein.</h2>
      <p class="kz-lead kz-reveal" data-delay="2">
        Ein guter Einstieg soll nicht nur überzeugen, sondern auch aussortieren. Wenn einer dieser Punkte nicht passt, klären wir das früh, bevor Aufwand und Budget in die falsche Richtung laufen.
      </p>
      <div class="kz-fit-grid">
        {fitCards.map((card, index) => (
          <article class={`kz-fit-card${index === 1 ? ' kz-fit-card--quiet' : ''} kz-reveal`} data-delay={index + 1}>
            <div class="kz-fit-card__k">{card.k}</div>
            <h3>{card.title}</h3>
            <ul>
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 3.7 — ABLAUF -->
  <section class="kz-section" id="ablauf" style="background:var(--paper-2);">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Ablauf</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">Vom ersten Gespräch zum ersten System im Betrieb.</h2>
      <p class="kz-lead kz-reveal" data-delay="2">
        Es geht nicht darum, sofort alles zu automatisieren. Es geht darum, den richtigen Einstieg zu finden, sauber aufzubauen und dann mit jedem Schritt mehr Ordnung ins Unternehmen zu bringen.
      </p>
      <div class="kz-process">
        {ablaufSchritte.map((step, index) => (
          <div class="kz-process__step kz-reveal" data-delay={(index % 4) + 1}>
            <div class="kz-process__k">{step.k}</div>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3.8 — ENTSCHEIDUNGSHILFE -->
  <section class="kz-section">
    <div class="kz-wrap">
      <span class="kz-eyebrow kz-reveal">Was Sie bekommen</span>
      <h2 class="kz-h2 kz-reveal" data-delay="1">Der Einstieg endet nicht mit einem Call. Er endet mit einer Entscheidung, die Sie begründen können.</h2>
      <p class="kz-lead kz-reveal" data-delay="2">
        Gerade bei B2B-Entscheidungen reicht Begeisterung nicht. Sie brauchen etwas, das Sie intern zeigen, vergleichen und kritisch prüfen können.
      </p>
      <div class="kz-decision-grid">
