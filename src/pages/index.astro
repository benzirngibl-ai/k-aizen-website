    "itemListElement": [
      { "@type": "Offer", "name": "Discovery-Audit Standard", "price": "1490", "priceCurrency": "EUR", "itemOffered": { "@type": "Service", "name": "Discovery-Audit", "description": "1 Tag remote, kundenspezifischer Report binnen 5 Werktagen, 1h Follow-up. 50% bei Setup-Buchung innerhalb 30 Tagen aufs Setup angerechnet." } },
