---
// k-AIzen Homepage — Claude Design Version (React + Babel-standalone)
// Lädt Static-Assets aus /preview/ (CSS/JS/JSX) und /animations/claude-design/ (Bilder).
// Vorgängerversion liegt unter old-index.astro als Backup.

const SITE_URL = 'https://k-aizen.de';
const TITLE = 'k-AIzen — Jeden Tag 1% besser. Mit KI.';
