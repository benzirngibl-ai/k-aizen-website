  "alternateName": "k-AIzen by Pulscraft Digital",
  "url": SITE_URL,
  "logo": `${SITE_URL}/animations/claude-design/logo-full.png`,
  "description": DESCRIPTION,
  "founder": {
    "@type": "Person",
    "name": "Benjamin Zirngibl",
    "url": "https://www.linkedin.com/in/benjamin-zirngibl-0963753ab"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Deutschland"
  },
  "knowsAbout": [
    "KI-Workflow-Automation für KMU",
    "Observation-driven Process Automation",
    "Discovery-Audit für KMU",
    "Personalplanung mit KI",
