    "name": "Deutschland"
  },
  "serviceType": "KI-Workflow-Automation für KMU",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "k-AIzen Angebot",
    "itemListElement": [
      { "@type": "Offer", "name": "KI-PA", "price": "1490", "priceCurrency": "EUR", "priceSpecification": { "@type": "UnitPriceSpecification", "price": "1490", "priceCurrency": "EUR", "unitText": "pro Monat" }, "itemOffered": { "@type": "Service", "name": "KI-PA", "description": "Persönlicher KI-Assistent, remote eingerichtet. Mail-Triage, Termine, Customer-Memory, Briefings, Beleg-Erfassung, Audio→Protokoll, Recherche, News. Eigener Server in Deutschland, DSGVO-konform, kein Lock-in." } },
