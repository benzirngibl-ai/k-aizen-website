---
import '../styles/global.css';
---

<html lang="de">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>k-AIzen — KI-Automation für KMUs</title>
		<meta name="description" content="Individuelle KI-Workflows für KMUs mit 10–50 Mitarbeitern. Lokal. Persönlich. Ohne Enterprise-Overhead." />
	</head>
	<body class="min-h-screen bg-neutral-950 text-neutral-100 antialiased">
		<header class="mx-auto flex max-w-5xl items-center justify-between px-6 py-6">
			<a href="/" class="text-sm font-semibold tracking-wide">k-AIzen</a>
			<nav class="flex gap-6 text-sm text-neutral-400">
				<a href="/firmen-scan" class="transition hover:text-neutral-100">Firmen-Scan</a>
				<a href="/about" class="transition hover:text-neutral-100">Über</a>
			</nav>
		</header>

		<main class="mx-auto flex min-h-[calc(100vh-4rem)] max-w-3xl flex-col justify-center px-6 py-16">
			<p class="mb-6 text-sm uppercase tracking-widest text-neutral-500">Kaizen × KI</p>

			<h1 class="text-4xl font-semibold leading-tight tracking-tight sm:text-6xl">
				KI-Automation für deinen Betrieb —<br />
				<span class="text-neutral-400">nicht für einen Konzern.</span>
			</h1>

			<p class="mt-8 max-w-xl text-lg leading-relaxed text-neutral-300">
				k-AIzen baut individuelle KI-Workflows für KMUs mit 10–50 Mitarbeitern.
				Lokal. Persönlich. Ohne Enterprise-Overhead.
			</p>

			<div class="mt-12 flex flex-col gap-4 sm:flex-row sm:items-center">
				<a
					href="/firmen-scan"
					class="inline-flex items-center justify-center rounded-md bg-neutral-100 px-6 py-3 font-medium text-neutral-900 transition hover:bg-white"
				>
					Firmen-Scan buchen
				</a>
				<span class="text-sm text-neutral-500">30 Min · unverbindlich · kostenlos</span>
			</div>
		</main>
	</body>
</html>
