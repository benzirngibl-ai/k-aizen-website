---
import DiscordMockup from './DiscordMockup.astro';

interface DiscordData {
  channel: string;
  author: string;
  timestamp: string;
  content: string;
}

interface Props {
  type: 'hook' | 'scene' | 'cta';
  time?: string;
  scene_label?: string;
  imageUrl: string;
  imageAlt: string;
  headline: string;
  subheadline?: string;
  body?: string;
  discord?: DiscordData;
  cta_label?: string;
  cta_href?: string;
}

const {
  type,
  time,
  scene_label,
  imageUrl,
  imageAlt,
  headline,
  subheadline,
  body,
  discord,
  cta_label,
  cta_href,
} = Astro.props;
---

<section class={`pitch-slide pitch-slide--${type}`} data-slide-type={type}>
  {type === 'scene' && (
    <div class="pitch-grid">
      <div class="pitch-col pitch-col--character" data-reveal="left">
        <div class="pitch-char-frame">
          <img src={imageUrl} alt={imageAlt} loading="lazy" />
          <div class="pitch-char-glow"></div>
        </div>
      </div>

      <div class="pitch-col pitch-col--story" data-reveal="up">
        {time && (
          <div class="pitch-time">
            <span class="pitch-time-dot"></span>
            <span>{time}{scene_label ? ` · ${scene_label}` : ''}</span>
          </div>
        )}
        <h2 class="pitch-headline">{headline}</h2>
        {body && <p class="pitch-body">{body}</p>}
      </div>

      <div class="pitch-col pitch-col--discord" data-reveal="right">
        {discord && <DiscordMockup {...discord} />}
      </div>
    </div>
  )}

  {type === 'hook' && (
    <div class="pitch-hook">
      <div class="pitch-hook-bg" aria-hidden="true"></div>
      <div class="pitch-hook-content" data-reveal="up">
        <img src={imageUrl} alt={imageAlt} class="pitch-hook-img" />
        <h1 class="pitch-hook-headline">{headline}</h1>
        {subheadline && <p class="pitch-hook-sub">{subheadline}</p>}
        <div class="pitch-hook-scroll-hint" aria-hidden="true">
          <span>scrollen</span>
          <svg width="14" height="22" viewBox="0 0 14 22" fill="none"><path d="M7 1v20m0 0l5-5m-5 5l-5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
      </div>
    </div>
  )}

  {type === 'cta' && (
    <div class="pitch-cta" data-reveal="up">
      <img src={imageUrl} alt={imageAlt} class="pitch-cta-img" />
      <h2 class="pitch-cta-headline">{headline}</h2>
      {body && <p class="pitch-cta-body">{body}</p>}
      {cta_label && cta_href && (
        <a href={cta_href} class="pitch-cta-button">
          <span>{cta_label}</span>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12m0 0l-5-5m5 5l-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      )}
    </div>
  )}
</section>

<style>
  :root {
    --pitch-ease: cubic-bezier(0.16, 1, 0.3, 1);
    --pitch-ease-fast: cubic-bezier(0.22, 0.61, 0.36, 1);
    --pitch-bg: #F5F0E8;
    --pitch-bg-deep: #EFE8DC;
    --pitch-ink: #1a1a1a;
    --pitch-ink-soft: #3a3a3a;
    --pitch-ember: #FF5500;
    --pitch-ember-soft: rgba(255, 85, 0, 0.08);
  }

  .pitch-slide {
    min-height: 100vh;
    padding: clamp(40px, 8vh, 100px) clamp(24px, 5vw, 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    position: relative;
    background: var(--pitch-bg);
  }

  .pitch-slide-wrapper:nth-child(even) .pitch-slide {
    background: var(--pitch-bg-deep);
  }

  /* === Scene Layout (3-Column) === */
  .pitch-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr 0.95fr;
    gap: clamp(32px, 4vw, 64px);
    max-width: 1480px;
    width: 100%;
    align-items: center;
  }

  .pitch-col {
    min-width: 0;
  }

  .pitch-char-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 24px;
    box-shadow:
      0 30px 60px -20px rgba(26, 26, 26, 0.28),
      0 0 0 1px rgba(26, 26, 26, 0.05),
      inset 0 0 80px rgba(26, 26, 26, 0.04);
  }

  .pitch-char-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.04);
    transition: transform 1.6s var(--pitch-ease);
    will-change: transform;
  }

  .pitch-char-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    box-shadow: inset 0 -120px 80px -60px rgba(0, 0, 0, 0.2);
    border-radius: 24px;
  }

  .pitch-time {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--pitch-ember);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 24px;
    padding: 8px 14px;
    border-radius: 999px;
    background: var(--pitch-ember-soft);
  }

  .pitch-time-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--pitch-ember);
    box-shadow: 0 0 0 4px rgba(255, 85, 0, 0.15);
    animation: pitch-pulse 2.4s ease-in-out infinite;
  }

  @keyframes pitch-pulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(255, 85, 0, 0.15); }
    50% { box-shadow: 0 0 0 10px rgba(255, 85, 0, 0); }
  }

  .pitch-headline {
    font-size: clamp(1.8rem, 3.2vw, 2.8rem);
    line-height: 1.1;
    color: var(--pitch-ink);
    margin: 0 0 24px 0;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .pitch-body {
    font-size: clamp(1.05rem, 1.3vw, 1.2rem);
    line-height: 1.65;
    color: var(--pitch-ink-soft);
    margin: 0;
    max-width: 42ch;
  }

  /* === Hook Layout === */
  .pitch-hook {
    position: relative;
    text-align: center;
    max-width: 1000px;
    width: 100%;
    z-index: 1;
  }

  .pitch-hook-bg {
    position: absolute;
    inset: -100px -200px;
    background:
      radial-gradient(ellipse at 30% 30%, rgba(255, 85, 0, 0.12), transparent 50%),
      radial-gradient(ellipse at 70% 70%, rgba(255, 85, 0, 0.06), transparent 60%);
    z-index: -1;
    filter: blur(40px);
  }

  .pitch-hook-content {
    position: relative;
  }

  .pitch-hook-img {
    width: 100%;
    max-width: 520px;
    height: auto;
    margin: 0 auto 56px;
    display: block;
    border-radius: 24px;
    box-shadow:
      0 40px 80px -20px rgba(26, 26, 26, 0.3),
      0 0 0 1px rgba(26, 26, 26, 0.05);
  }

  .pitch-hook-headline {
    font-size: clamp(2.4rem, 5vw, 4.2rem);
    line-height: 1.05;
    color: var(--pitch-ink);
    margin: 0 0 24px 0;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .pitch-hook-sub {
    font-size: clamp(1.1rem, 1.6vw, 1.4rem);
    color: var(--pitch-ink-soft);
    line-height: 1.5;
    margin: 0 auto;
    max-width: 36ch;
  }

  .pitch-hook-scroll-hint {
    margin-top: 64px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: var(--pitch-ink-soft);
    opacity: 0.6;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    animation: pitch-float 2.8s ease-in-out infinite;
  }

  @keyframes pitch-float {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(8px); opacity: 0.9; }
  }

  /* === CTA Layout === */
  .pitch-cta {
    text-align: center;
    max-width: 760px;
  }

  .pitch-cta-img {
    width: 100%;
    max-width: 380px;
    height: auto;
    margin: 0 auto 40px;
    display: block;
    border-radius: 20px;
    box-shadow: 0 30px 60px -20px rgba(26, 26, 26, 0.28);
  }

  .pitch-cta-headline {
    font-size: clamp(2rem, 3.6vw, 3rem);
    margin: 0 0 20px 0;
    color: var(--pitch-ink);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .pitch-cta-body {
    font-size: clamp(1.05rem, 1.3vw, 1.2rem);
    margin: 0 auto 40px;
    line-height: 1.55;
    color: var(--pitch-ink-soft);
    max-width: 38ch;
  }

  .pitch-cta-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--pitch-ink);
    color: var(--pitch-bg);
    padding: 18px 32px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    position: relative;
    overflow: hidden;
    transition: transform 0.6s var(--pitch-ease), box-shadow 0.6s var(--pitch-ease);
    box-shadow: 0 10px 30px -10px rgba(26, 26, 26, 0.4);
  }

  .pitch-cta-button::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 30%, rgba(255, 255, 255, 0.14) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.9s var(--pitch-ease);
  }

  .pitch-cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px -10px rgba(26, 26, 26, 0.5);
  }

  .pitch-cta-button:hover::before {
    transform: translateX(100%);
  }

  .pitch-cta-button svg {
    transition: transform 0.5s var(--pitch-ease);
  }

  .pitch-cta-button:hover svg {
    transform: translateX(4px);
  }

  /* === Reveal Animations (controlled by IntersectionObserver in [variant].astro) === */
  [data-reveal] {
    opacity: 0;
    transition:
      opacity 1s var(--pitch-ease),
      transform 1.1s var(--pitch-ease);
    will-change: opacity, transform;
  }

  [data-reveal="left"]  { transform: translateX(-40px); }
  [data-reveal="right"] { transform: translateX(40px); transition-delay: 180ms; }
  [data-reveal="up"]    { transform: translateY(32px); transition-delay: 90ms; }

  .pitch-slide.is-visible [data-reveal] {
    opacity: 1;
    transform: translate(0, 0);
  }

  .pitch-slide.is-visible .pitch-char-frame img {
    transform: scale(1);
  }

  /* === Mobile === */
  @media (max-width: 1024px) {
    .pitch-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .pitch-char-frame {
      aspect-ratio: 16 / 11;
      max-height: 48vh;
    }
    .pitch-slide {
      padding: 56px 20px;
      min-height: auto;
    }
    [data-reveal="left"], [data-reveal="right"] {
      transform: translateY(32px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    .pitch-char-frame img,
    .pitch-cta-button,
    .pitch-cta-button::before,
    .pitch-cta-button svg {
      transition: none !important;
      animation: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
    .pitch-time-dot,
    .pitch-hook-scroll-hint {
      animation: none !important;
    }
  }
</style>
