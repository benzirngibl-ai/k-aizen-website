---
interface Props {
  size?: number;
  class?: string;
  animate?: boolean;
}

const { size = 32, class: className = "", animate = false } = Astro.props;
const animClass = animate ? "rune-draw" : "";
---

<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={`${className} ${animClass}`}
  stroke="currentColor"
  stroke-width="1.25"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <circle cx="32" cy="32" r="28" opacity="0.35" />
  <circle cx="32" cy="32" r="22" />
  <circle cx="32" cy="32" r="8" opacity="0.5" />

  <line x1="32" y1="4" x2="32" y2="10" />
  <line x1="32" y1="54" x2="32" y2="60" />
  <line x1="4" y1="32" x2="10" y2="32" />
  <line x1="54" y1="32" x2="60" y2="32" />

  <line x1="12" y1="12" x2="16" y2="16" opacity="0.6" />
  <line x1="52" y1="12" x2="48" y2="16" opacity="0.6" />
  <line x1="12" y1="52" x2="16" y2="48" opacity="0.6" />
  <line x1="52" y1="52" x2="48" y2="48" opacity="0.6" />

  <path d="M 32 18 L 42 32 L 32 46 L 22 32 Z" />
  <line x1="32" y1="22" x2="32" y2="42" opacity="0.7" />
  <line x1="26" y1="32" x2="38" y2="32" opacity="0.7" />
</svg>
