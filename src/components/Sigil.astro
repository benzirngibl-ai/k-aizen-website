---
interface Props {
  size?: number;
  class?: string;
}

const { size = 120, class: className = "" } = Astro.props;
---

<img
  src="/images/sigil.png"
  alt=""
  width={size}
  height={size}
  class={className}
  style={`width: ${size}px; height: ${size}px; mix-blend-mode: multiply;`}
  aria-hidden="true"
/>
