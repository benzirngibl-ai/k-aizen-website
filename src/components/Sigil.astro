---
interface Props {
  size?: number;
  class?: string;
  flame?: boolean;
}

const { size = 120, class: className = "", flame = false } = Astro.props;
---

{flame ? (
  <span
    class={`sigil-flame ${className}`}
    style={`width: ${size}px; height: ${size}px;`}
    aria-hidden="true"
  ></span>
) : (
  <img
    src="/images/sigil.png"
    alt=""
    width={size}
    height={size}
    class={className}
    style={`width: ${size}px; height: ${size}px;`}
    aria-hidden="true"
  />
)}
